@{
    ViewData["Title"] = "Circulars";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-6 space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 bg-white dark:bg-slate-800 p-5 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700">
        <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-white tracking-tight">Organization Circulars</h1>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Stay updated with the latest announcements and notices.</p>
        </div>
        <div>
            <button onclick="openCircularModal()" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-xl shadow-md shadow-indigo-200 dark:shadow-none transition-all duration-200 flex items-center gap-2">
                <i class="fas fa-plus"></i>
                Post New Circular
            </button>
        </div>
    </div>

    <!-- Circulars Grid -->
    <div id="circularsContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Circular items will be injected here by JS -->
    </div>

    <!-- Empty State (Hidden by default) -->
    <div id="emptyState" class="hidden flex flex-col items-center justify-center p-12 bg-white dark:bg-slate-800 rounded-2xl border border-dashed border-slate-300 dark:border-slate-600">
        <div class="w-16 h-16 bg-slate-100 dark:bg-slate-700 rounded-full flex items-center justify-center mb-4">
            <i class="fas fa-bullhorn text-2xl text-slate-400 dark:text-slate-500"></i>
        </div>
        <h3 class="text-lg font-semibold text-slate-800 dark:text-white">No Circulars Found</h3>
        <p class="text-slate-500 dark:text-slate-400 text-center max-w-md mt-2">There are currently no circulars or announcements posted. Click the button above to post a new one.</p>
    </div>
</div>

<!-- Modal Overlay -->
<div id="circularModalOverlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[1050] hidden opacity-0 transition-opacity duration-300"></div>

<!-- Post Circular Modal -->
<div id="circularModal" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[90vh] flex flex-col bg-white dark:bg-slate-800 rounded-2xl shadow-2xl z-[1055] hidden scale-95 opacity-0 transition-all duration-300 border-2 border-indigo-100 dark:border-slate-700">
    <div class="px-6 py-5 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center bg-gradient-to-r from-indigo-50/50 to-white dark:from-slate-800 dark:to-slate-800 rounded-t-2xl">
        <h3 class="text-xl font-bold text-indigo-900 dark:text-white flex items-center gap-2">
            <i class="fas fa-bullhorn text-indigo-600 dark:text-indigo-400"></i> Post a Circular
        </h3>
        <button onclick="closeCircularModal()" class="w-8 h-8 flex items-center justify-center rounded-full text-slate-400 hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-700 dark:hover:text-slate-200 transition-colors">
            <i class="fas fa-times"></i>
        </button>
    </div>
    
    <div class="p-6 space-y-5 overflow-y-auto">
        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Circular Title</label>
            <input type="text" id="circularTitle" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900 border-2 border-slate-300 dark:border-slate-600 rounded-xl focus:ring-0 focus:border-indigo-500 outline-none transition-all text-slate-800 dark:text-white placeholder-slate-400" placeholder="E.g., Office Holiday Announcement" />
        </div>
        
        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Detailed Description</label>
            <textarea id="circularDesc" rows="6" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900 border-2 border-slate-300 dark:border-slate-600 rounded-xl focus:ring-0 focus:border-indigo-500 outline-none transition-all text-slate-800 dark:text-white resize-none placeholder-slate-400" placeholder="Type the complete circular details here..."></textarea>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mb-1.5">Valid Until (Optional)</label>
            <input type="date" id="circularExpiryDate" class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900 border-2 border-slate-300 dark:border-slate-600 rounded-xl focus:ring-0 focus:border-indigo-500 outline-none transition-all text-slate-800 dark:text-white" />
            <p class="text-xs text-slate-500 mt-1.5"><i class="fas fa-info-circle"></i> If set, the circular will be automatically hidden after this date.</p>
        </div>
    </div>
    
    <div class="px-6 py-4 border-t border-slate-100 dark:border-slate-700 flex justify-end gap-3 bg-slate-50 dark:bg-slate-800/80 rounded-b-2xl">
        <button onclick="closeCircularModal()" class="btn-cancel">Cancel</button>
        <button onclick="submitCircular()" id="btnSubmitCircular" class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl shadow-md shadow-indigo-200 dark:shadow-none transition-all flex items-center gap-2">
            <span>Publish Circular</span>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadCirculars();
        });

        function loadCirculars() {
            $.ajax({
                url: '@Url.Action("GetCirculars", "Circular")',
                type: 'GET',
                success: function(res) {
                    if(res.status) {
                        renderCirculars(res.data);
                    } else {
                        alert("Error: " + res.msg);
                    }
                },
                error: function() {
                    alert("Failed to load circulars. Server error.");
                }
            });
        }

        function renderCirculars(data) {
            const container = $('#circularsContainer');
            const emptyState = $('#emptyState');
            
            container.empty();
            
            if(data.length === 0) {
                container.hide();
                emptyState.removeClass('hidden');
                return;
            }
            
            emptyState.addClass('hidden');
            container.show();
            
            data.forEach(item => {
                const card = `
                    <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-md hover:shadow-xl border-2 border-slate-100 dark:border-slate-700 hover:border-indigo-300 dark:hover:border-indigo-500 transition-all duration-300 group flex flex-col h-full relative overflow-hidden transform hover:-translate-y-1">
                        <!-- Top Accent Line -->
                        <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-indigo-500 to-purple-500"></div>
                        
                        <div class="flex items-start justify-between mb-4 mt-2">
                            <div class="w-12 h-12 rounded-xl bg-indigo-50 dark:bg-indigo-900/40 flex items-center justify-center text-indigo-600 dark:text-indigo-400 group-hover:scale-110 transition-transform duration-300 border border-indigo-100 dark:border-indigo-800">
                                <i class="fas fa-file-alt text-xl"></i>
                            </div>
                            <span class="text-xs font-semibold px-3 py-1.5 bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded-full border border-slate-200 dark:border-slate-600 shadow-sm">
                                ${item.postedDate}
                            </span>
                        </div>
                        
                        <h4 class="text-lg font-bold text-slate-800 dark:text-white mb-3 line-clamp-2 leading-snug">${item.title}</h4>
                        
                        <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 flex-grow whitespace-pre-wrap leading-relaxed">${item.description}</p>
                        
                        <div class="flex items-center gap-3 pt-5 border-t border-slate-100 dark:border-slate-700 mt-auto">
                            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 dark:from-slate-600 dark:to-slate-700 flex items-center justify-center text-slate-700 dark:text-slate-200 text-xs font-bold uppercase shadow-sm border border-slate-300 dark:border-slate-500">
                                ${(item.postedBy || 'OR').substring(0, 2)}
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-slate-800 dark:text-slate-200 leading-none">${item.postedBy}</p>
                                <p class="text-[11px] text-slate-500 dark:text-slate-400 mt-1 uppercase tracking-wide font-medium">Author</p>
                            </div>
                        </div>
                    </div>
                `;
                container.append(card);
            });
        }

        // Modal Functions
        function openCircularModal() {
            $('#circularTitle').val('');
            $('#circularDesc').val('');
            $('#circularExpiryDate').val('');
            
            $('#circularModalOverlay').removeClass('hidden').delay(10).queue(function(next) {
                $(this).removeClass('opacity-0');
                next();
            });
            
            $('#circularModal').removeClass('hidden').delay(10).queue(function(next) {
                $(this).removeClass('opacity-0 scale-95').addClass('scale-100');
                next();
            });
        }

        function closeCircularModal() {
            $('#circularModalOverlay').addClass('opacity-0').delay(300).queue(function(next) {
                $(this).addClass('hidden');
                next();
            });
            
            $('#circularModal').removeClass('scale-100').addClass('opacity-0 scale-95').delay(300).queue(function(next) {
                $(this).addClass('hidden');
                next();
            });
        }

        function submitCircular() {
            const title = $('#circularTitle').val().trim();
            const desc = $('#circularDesc').val().trim();
            const expiryDate = $('#circularExpiryDate').val();
            
            if(!title || !desc) {
                alert("Please fill in both title and description.");
                return;
            }
            
            const btn = $('#btnSubmitCircular');
            const originalText = btn.html();
            btn.html('<i class="fas fa-spinner fa-spin"></i> Posting...');
            btn.prop('disabled', true);
            
            $.ajax({
                url: '@Url.Action("AddCircular", "Circular")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Title: title,
                    Description: desc,
                    ExpiryDate: expiryDate
                }),
                success: function(res) {
                    btn.html(originalText);
                    btn.prop('disabled', false);
                    
                    if(res.status) {
                        alert("Success: " + res.msg);
                        closeCircularModal();
                        loadCirculars();
                    } else {
                        alert("Error: " + res.msg);
                    }
                },
                error: function() {
                    btn.html(originalText);
                    btn.prop('disabled', false);
                    alert("Failed to post circular. Server error.");
                }
            });
        }
    </script>
}
