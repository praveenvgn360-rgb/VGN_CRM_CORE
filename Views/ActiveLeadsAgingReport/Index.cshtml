@{
    ViewBag.Title = "Active Leads Aging Report - VGN ERP";
}

<style>
    /* Tabs */
    .tab-btn {
        transition: all 0.3s ease;
    }
    .tab-btn.active {
        border-bottom-color: var(--primary);
        color: var(--primary);
    }
    .tab-btn:hover:not(.active) {
        color: var(--primary);
        border-bottom-color: var(--primary);
        opacity: 0.7;
    }

    /* Content Sections */
    .content-section {
        display: none;
        animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .content-section.active {
        display: block;
    }

    @@keyframes slideUpFade {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Custom Scrollbar */
    .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--border, #cbd5e1); border-radius: 10px; }

    /* Layout Specifics */
    .stat-card-input {
        background: transparent; border: 0; padding: 0; outline: none;
        font-weight: 900; font-size: 1.25rem; line-height: 1; text-align: right;
        color: var(--text);
    }
    .stat-card-input:focus { outline: none; box-shadow: none; }
    
    /* Theme Integration */
    .theme-card {
        background-color: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
    }
    .theme-text {
        color: var(--text);
    }
    .theme-text-muted {
        color: var(--text-muted);
    }
    .theme-bg {
        background-color: var(--bg);
    }

    /* ── Loader overlay ── */
    .sa-loader-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 1rem;
    }

    .sa-loader-overlay.show {
        display: flex;
    }

    .sa-loader-overlay .spinner-ring {
        width: 60px;
        height: 60px;
        border: 5px solid rgba(255,255,255,.25);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: sa-spin .8s linear infinite;
    }

    .sa-loader-overlay .msg {
        color: #fff;
        font-size: .92rem;
        font-weight: 600;
        letter-spacing: .3px;
    }

    @@keyframes sa-spin {
        to { transform: rotate(360deg); }
    }
</style>

<!-- Hidden fields -->
<input type="hidden" id="HEnquiryNo" value="@Context.Request.Query["EnquiryNo"]" />

<!-- Loader -->
<div class="sa-loader-overlay" id="loader">
    <div class="spinner-ring"></div>
    <div class="msg">Loading Data Please Wait...</div>
</div>

<!-- Tabs -->
<div class="flex border-b border-gray-200 dark:border-gray-700 mb-6 overflow-x-auto">
    <button class="tab-btn active px-4 py-2 border-b-2 font-medium text-sm border-primary text-primary whitespace-nowrap" data-section="activeleads">
        <i class="bi bi-person-lines-fill me-2"></i>Active Leads
    </button>
    <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-sm text-gray-500 whitespace-nowrap" data-section="ManualLeads">
        <i class="bi bi-person-fill-add me-2"></i>Manual Leads
    </button>
</div>

<!-- ACTIVE LEADS SECTION -->
<div id="activeleads" class="content-section active">
    
    <!-- Top: Horizontal Filters -->
    <div class="theme-card rounded-2xl shadow-sm p-5 mb-5 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-2xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

        <div class="flex items-center gap-3 mb-4 pb-3 border-b relative z-10" style="border-color: var(--border);">
            <div class="w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center text-primary">
                <i class="bi bi-funnel-fill"></i>
            </div>
            <h3 class="font-bold theme-text uppercase text-sm tracking-wider">Filters</h3>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 items-end relative z-10">
            <div class="group">
                <label class="block text-xs font-bold theme-text-muted uppercase tracking-wider mb-1.5">EXECUTIVE</label>
                <select class="select2 form-select w-full" id="dd_ExecutiveName"></select>
            </div>
            <div class="group">
                <label class="block text-xs font-bold theme-text-muted uppercase tracking-wider mb-1.5">TEAM MANAGER</label>
                <select class="select2 form-select w-full" id="dd_Teammanager"></select>
            </div>
            <div class="group">
                <label class="block text-xs font-bold theme-text-muted uppercase tracking-wider mb-1.5">TEAM HEAD</label>
                <select class="select2 form-select w-full" id="dd_TeamHead"></select>
            </div>
            
            <div>
                <label class="block text-xs font-bold theme-text-muted uppercase tracking-wider mb-1.5">CATEGORY</label>
                <div class="flex theme-bg rounded-lg p-1 border shadow-inner" style="border-color: var(--border);">
                    <label class="flex-1 text-center relative cursor-pointer m-0">
                        <input type="radio" name="EnquiryType" value="PRIMARY" checked class="peer sr-only">
                        <div class="py-1.5 text-xs font-bold theme-text-muted rounded-md peer-checked:bg-[var(--surface)] peer-checked:text-primary peer-checked:shadow-sm transition-all duration-200">PRIMARY</div>
                    </label>
                    <label class="flex-1 text-center relative cursor-pointer m-0">
                        <input type="radio" name="EnquiryType" value="SECONDARY" class="peer sr-only">
                        <div class="py-1.5 text-xs font-bold theme-text-muted rounded-md peer-checked:bg-[var(--surface)] peer-checked:text-primary peer-checked:shadow-sm transition-all duration-200">SECONDARY</div>
                    </label>
                </div>
            </div>
            
            <div class="flex items-center gap-2">
                <button type="button" class="btn-load flex-1 justify-center py-2 h-[38px]" id="btn_refresh">
                    <i class="bi bi-arrow-repeat"></i> LOAD
                </button>
                <button type="button" class="btn-clear flex-1 justify-center py-2 h-[38px]" id="btn_clear">
                    <i class="bi bi-eraser"></i> CLEAR
                </button>
            </div>
        </div>
    </div>

    <!-- Middle: Compact Stats Row (4 cards) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-5">
        
        <!-- Site Visit Card -->
        <div class="theme-card rounded-xl shadow-sm p-4 flex flex-col relative overflow-hidden group transition-all" style="border-left: 3px solid rgba(59, 130, 246, 0.5);">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <span class="font-black text-[11px] tracking-widest theme-text uppercase">Site Visit</span>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-2">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">Not Updated</span>
                <input type="text" id="SvNotUpdated" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-4">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">In Progress</span>
                <input type="text" id="SvInprogress" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="mt-auto rounded-lg p-2.5 flex justify-between items-center" style="background: rgba(249, 115, 22, 0.1); border: 1px solid rgba(249, 115, 22, 0.2);">
                <div class="flex items-center gap-1.5" style="color: #f97316;"><i class="bi bi-fire text-xs animate-pulse"></i><span class="text-[9px] font-black tracking-widest">HOT LEADS</span></div>
                <input type="text" id="Hotleads" disabled class="stat-card-input w-10" style="color: #f97316;" value="0"/>
            </div>
        </div>

        <!-- Negotiation Card -->
        <div class="theme-card rounded-xl shadow-sm p-4 flex flex-col relative overflow-hidden group transition-all" style="border-left: 3px solid rgba(99, 102, 241, 0.5);">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <i class="bi bi-chat-dots"></i>
                </div>
                <span class="font-black text-[11px] tracking-widest theme-text uppercase">Negotiation</span>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-2">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">Not Updated</span>
                <input type="text" id="NegoNotUpdated" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-4">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">In Progress</span>
                <input type="text" id="NegoInprogress" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="mt-auto rounded-lg p-2.5 flex justify-between items-center" style="background: rgba(59, 130, 246, 0.1); border: 1px solid rgba(59, 130, 246, 0.2);">
                <div class="flex items-center gap-1.5" style="color: #3b82f6;"><i class="bi bi-thermometer-half text-xs"></i><span class="text-[9px] font-black tracking-widest">WARM LEADS</span></div>
                <input type="text" id="WarmLeads" disabled class="stat-card-input w-10" style="color: #3b82f6;" value="0"/>
            </div>
        </div>

        <!-- Booking Advance Card -->
        <div class="theme-card rounded-xl shadow-sm p-4 flex flex-col relative overflow-hidden group transition-all" style="border-left: 3px solid rgba(16, 185, 129, 0.5);">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <span class="font-black text-[11px] tracking-widest theme-text uppercase">Booking Adv.</span>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-2">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">Not Updated</span>
                <input type="text" id="BookNotUpdated" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-4">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">In Progress</span>
                <input type="text" id="BookInprogress" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="mt-auto rounded-lg p-2.5 flex justify-between items-center" style="background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.2);">
                <div class="flex items-center gap-1.5" style="color: #0ea5e9;"><i class="bi bi-snow text-xs"></i><span class="text-[9px] font-black tracking-widest">COLD LEADS</span></div>
                <input type="text" id="ColdLeads" disabled class="stat-card-input w-10" style="color: #0ea5e9;" value="0"/>
            </div>
        </div>

        <!-- Future Project Card -->
        <div class="theme-card rounded-xl shadow-sm p-4 flex flex-col relative overflow-hidden group transition-all" style="border-left: 3px solid rgba(168, 85, 247, 0.5);">
            <div class="flex items-center gap-2 mb-4">
                <div class="w-8 h-8 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center">
                    <i class="bi bi-building"></i>
                </div>
                <span class="font-black text-[11px] tracking-widest theme-text uppercase">Future Proj.</span>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-2">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">Not Updated</span>
                <input type="text" id="FutNotUpdated" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="flex items-center justify-between text-xs font-semibold mb-4">
                <span class="theme-text-muted uppercase tracking-wider text-[10px]">In Progress</span>
                <input type="text" id="FutInprogress" disabled class="stat-card-input w-12" value="0"/>
            </div>
            <div class="mt-auto rounded-lg p-2.5 flex justify-between items-center" style="background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.2);">
                <div class="flex items-center gap-1.5" style="color: #8b5cf6;"><i class="bi bi-three-dots text-xs"></i><span class="text-[9px] font-black tracking-widest">OTHERS</span></div>
                <input type="text" id="OtherLeads" disabled class="stat-card-input w-10" style="color: #8b5cf6;" value="0"/>
            </div>
        </div>

    </div>

    <!-- Bottom: Grid Section -->
    <div class="theme-card rounded-2xl shadow-sm p-5 flex flex-col relative overflow-hidden">
        <div class="absolute top-0 left-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 -translate-x-1/3 pointer-events-none"></div>

        <div class="flex justify-between items-center mb-4 pb-3 border-b relative z-10" style="border-color: var(--border);">
            <h3 class="font-bold theme-text uppercase text-sm tracking-wider flex items-center gap-2">
                <i class="bi bi-table text-primary"></i>
                Active Leads Data
            </h3>
            <div class="flex items-center gap-2 text-xs font-semibold theme-text-muted theme-bg border px-3 py-1.5 rounded-lg shadow-inner" style="border-color: var(--border);">
                <span>Total Records:</span>
                <span id="grid_count" class="text-primary font-black text-base leading-none">0</span>
            </div>
        </div>
        <div id="gridContainer" class="w-full custom-scrollbar flex-1 relative z-10"></div>
    </div>
    
</div>

<!-- MANUAL LEADS SECTION -->
<div id="ManualLeads" class="content-section">
    <div class="theme-card rounded-2xl shadow-sm p-5 flex flex-col relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        
        <div class="flex justify-between items-center mb-4 pb-3 border-b flex-wrap gap-4 relative z-10" style="border-color: var(--border);">
            <h3 class="font-bold theme-text uppercase text-sm tracking-wider flex items-center gap-2">
                <i class="bi bi-person-lines-fill text-primary"></i>
                Manual Leads Data
            </h3>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 text-xs font-semibold theme-text-muted theme-bg border px-3 py-1.5 rounded-lg shadow-inner" style="border-color: var(--border);">
                    <span>Total Records:</span>
                    <span id="summary_grid_count" class="text-primary font-black text-base leading-none">0</span>
                </div>
                <div class="flex items-center gap-2 border-l pl-4" style="border-color: var(--border);">
                    <button type="button" class="btn-load py-1.5" id="btn_LoadManualLeads">
                        <i class="bi bi-arrow-repeat"></i> LOAD
                    </button>
                    <button type="button" class="btn-clear py-1.5" id="btn_ManualLeadclear">
                        <i class="bi bi-eraser"></i> CLEAR
                    </button>
                </div>
            </div>
        </div>
        <div id="gridContainer1" class="w-full custom-scrollbar flex-1 relative z-10"></div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Tab switching logic
            $('.tab-btn').click(function (e) {
                e.preventDefault();
                const section = $(this).data('section');
                
                // Update tabs styling
                $('.tab-btn').removeClass('active border-primary text-primary').addClass('border-transparent text-gray-500');
                $(this).removeClass('border-transparent text-gray-500').addClass('active border-primary text-primary');

                // Switch section display
                $('.content-section').removeClass('active');
                setTimeout(() => {
                    $(`#${section}`).addClass('active');
                }, 50); // slight delay for smooth animation trigger
            });
        });
    </script>
    <script src="~/js/applicationjs/activeleads_agingreport.js"></script>
}