@{
    ViewBag.Title = "Active Leads Aging Report - VGN ERP";
}

<!-- Hidden fields for session values -->
@* <input type="hidden" id="HUserType" value="@Session["UserType"]" />
<input type="hidden" id="Huser_name" value="@Session["UserName"]" /> *@
<input type="hidden" id="HEnquiryNo" value="@Context.Request.Query["EnquiryNo"]" />

<!-- Loader Overlay -->
<div id="loader" class="fixed inset-0 z-50 flex items-center justify-center bg-black/30 backdrop-blur-sm transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-8 flex flex-col items-center space-y-4">
        <div class="w-12 h-12 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
        <div class="text-gray-700 dark:text-gray-300 font-medium">Loading Data, Please wait...</div>
    </div>
</div>

<!-- Tabs -->
<div class="bg-white dark:bg-gray-800 rounded-t-xl shadow-sm border-b border-gray-200 dark:border-gray-700">
    <div class="flex flex-wrap px-4 pt-2">
        <ul class="flex space-x-2" id="pills-tab" role="tablist">
            <li class="nav-item">
                <a class="nav-link active inline-block px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-primary text-primary"
                   id="active-leads-tab" data-toggle="tab" href="#activeleads" role="tab">
                    ACTIVE LEADS
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link inline-block px-4 py-2 text-sm font-medium rounded-t-lg border-b-2 border-transparent text-gray-600 dark:text-gray-400 hover:border-gray-300 dark:hover:border-gray-600"
                   id="second-grid-tab" data-toggle="tab" href="#ManualLeads" role="tab">
                    MANUAL LEADS
                </a>
            </li>
        </ul>
    </div>
</div>

<!-- Tab Content -->
<div class="tab-content bg-white dark:bg-gray-800 rounded-b-xl shadow-sm p-4">
    <!-- ACTIVE LEADS TAB -->
    <div class="tab-pane fade show active" id="activeleads" role="tabpanel">
        <!-- Filter & Status Section -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mb-4">
            <!-- Left: Filters -->
            <div class="lg:col-span-4 space-y-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">EXECUTIVE</label>
                    <select class="select2 w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" id="dd_ExecutiveName"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">TEAM MANAGER</label>
                    <select class="select2 w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" id="dd_Teammanager"></select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">TEAM HEAD</label>
                    <select class="select2 w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" id="dd_TeamHead"></select>
                </div>
                <!-- CATEGORY Radio -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">CATEGORY</label>
                    <div class="flex flex-wrap gap-4">
                        <label class="inline-flex items-center">
                            <input type="radio" name="EnquiryType" value="PRIMARY" checked class="form-radio text-primary focus:ring-primary border-gray-300 dark:border-gray-600">
                            <span class="ml-2 text-sm text-gray-700 dark:text-gray-300">PRIMARY</span>
                        </label>
                        <label class="inline-flex items-center">
                            <input type="radio" name="EnquiryType" value="SECONDARY" class="form-radio text-primary focus:ring-primary border-gray-300 dark:border-gray-600">
                            <span class="ml-2 text-sm text-gray-700 dark:text-gray-300">SECONDARY</span>
                        </label>
                    </div>
                </div>
                <!-- Action Buttons -->
                <div class="flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="btn-load" id="btn_refresh">
                        <i class="bi bi-arrow-repeat mr-1"></i> LOAD
                    </button>
                    <button type="submit" class="btn-clear" id="btn_clear">
                        <i class="bi bi-eraser mr-1"></i> CLEAR
                    </button>
                </div>
            </div>

            <!-- Right: Lead Status Boxes -->
            <div class="lg:col-span-8 border border-gray-300 dark:border-gray-600 rounded-xl p-4 flex flex-wrap items-center justify-center gap-3">
                <div class="leads font-semibold text-gray-700 dark:text-gray-300 mr-2">LEAD STATUS</div>
                <div class="flex flex-wrap gap-3">
                    <!-- Site Visit -->
                    <div class="w-40 border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden">
                        <div class="bg-blue-600 text-white text-center py-1 text-xs font-bold">SITE VISIT</div>
                        <div class="p-2 space-y-1">
                            <div class="flex justify-between text-sm"><span>NOT UPDATED</span><input type="text" id="SvNotUpdated" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>INPROGRESS</span><input type="text" id="SvInprogress" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>HOT LEADS</span><input type="text" id="Hotleads" disabled class="w-12 text-center bg-orange-200 dark:bg-orange-900/30 border-0 rounded" /></div>
                        </div>
                    </div>
                    <!-- Negotiation -->
                    <div class="w-40 border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden">
                        <div class="bg-gray-700 text-white text-center py-1 text-xs font-bold">NEGOTIATION</div>
                        <div class="p-2 space-y-1">
                            <div class="flex justify-between text-sm"><span>NOT UPDATED</span><input type="text" id="NegoNotUpdated" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>INPROGRESS</span><input type="text" id="NegoInprogress" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>WARM LEADS</span><input type="text" id="WarmLeads" disabled class="w-12 text-center bg-blue-100 dark:bg-blue-900/30 border-0 rounded" /></div>
                        </div>
                    </div>
                    <!-- Booking Advance -->
                    <div class="w-40 border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden">
                        <div class="bg-red-400 text-white text-center py-1 text-xs font-bold">BOOKING ADVANCE</div>
                        <div class="p-2 space-y-1">
                            <div class="flex justify-between text-sm"><span>NOT UPDATED</span><input type="text" id="BookNotUpdated" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>INPROGRESS</span><input type="text" id="BookInprogress" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>COLD LEADS</span><input type="text" id="ColdLeads" disabled class="w-12 text-center bg-yellow-200 dark:bg-yellow-900/30 border-0 rounded" /></div>
                        </div>
                    </div>
                    <!-- Future Project -->
                    <div class="w-40 border border-gray-300 dark:border-gray-600 rounded-lg overflow-hidden">
                        <div class="bg-pink-400 text-white text-center py-1 text-xs font-bold">FUTURE PROJECT</div>
                        <div class="p-2 space-y-1">
                            <div class="flex justify-between text-sm"><span>NOT UPDATED</span><input type="text" id="FutNotUpdated" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>INPROGRESS</span><input type="text" id="FutInprogress" disabled class="w-12 text-center bg-gray-100 dark:bg-gray-700 border-0 rounded" /></div>
                            <div class="flex justify-between text-sm"><span>OTHERS LEADS</span><input type="text" id="OtherLeads" disabled class="w-12 text-center bg-purple-100 dark:bg-purple-900/30 border-0 rounded" /></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid Section -->
        <div class="card border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm">
            <div class="card-body p-4">
                <div class="flex justify-between items-center mb-2">
                    <label class="text-sm font-medium text-gray-700 dark:text-gray-300">
                        ROW COUNT: <span id="grid_count" class="text-primary font-bold">0</span>
                    </label>
                </div>
                <div id="gridContainer"></div>
            </div>
        </div>
    </div>

    <!-- MANUAL LEADS TAB -->
    <div class="tab-pane fade" id="ManualLeads" role="tabpanel">
        <div class="mt-2">
            <div class="card border border-gray-200 dark:border-gray-700 rounded-xl shadow-sm">
                <div class="card-body p-4">
                    <div class="flex flex-wrap gap-2 mb-4">
                        <button type="submit" class="btn-load" id="btn_LoadManualLeads">
                            <i class="bi bi-arrow-repeat mr-1"></i> LOAD
                        </button>
                        <button type="submit" class="btn-clear" id="btn_ManualLeadclear">
                            <i class="bi bi-eraser mr-1"></i> CLEAR
                        </button>
                    </div>
                    <div id="gridContainer1"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/applicationjs/activeleads_agingreport.js"></script>