@section Scripts {
    <script>
        $(document).ready(function () {
            // Tab Switch Logic aligned with minimalist design
            $('.tab-btn-minimal').click(function () {
                $('.tab-btn-minimal').removeClass('active');
                $(this).addClass('active');

                // Toggle visibility
                $('.tab-pane').removeClass('block').addClass('hidden');
                
                let targetId = $(this).attr('id');
                if (targetId === 'tab_flat') $('#divFlat').removeClass('hidden').addClass('block');
                if (targetId === 'tab_plot') $('#divPlot').removeClass('hidden').addClass('block');
                if (targetId === 'tab_villa') $('#divVilla').removeClass('hidden').addClass('block');

                // Trigger resize for grid to fit properly after display:block
                setTimeout(function() {
                    window.dispatchEvent(new Event('resize'));
                }, 100);
            });
            
            // Initialize select2
            $('.select2').select2({
                width: '100%',
                placeholder: "-- SELECT --"
            });
        });
    </script>
    <script src="~/js/ApplicationJs/StockDetails.js" asp-append-version="true"></script>
}
