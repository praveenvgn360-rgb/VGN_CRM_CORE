        }

            /* Hover on item */
            .dx-column-chooser-list .dx-list-item.dx-state-hover,
            .dx-column-chooser-list .dx-list-item.dx-state-focused {
                background-color: rgba(var(--primary-rgb), 0.12) !important;
                color: var(--text) !important;
            }

        /* Checkbox inside column chooser */
        .dx-column-chooser .dx-checkbox-icon {
            border: 2px solid var(--primary) !important;
            background-color: var(--bg) !important;
        }

        .dx-column-chooser .dx-checkbox-checked .dx-checkbox-icon {
            background-color: var(--primary) !important;
            border-color: var(--primary) !important;
        }

            .dx-column-chooser .dx-checkbox-checked .dx-checkbox-icon::before {
                color: #ffffff !important;
            }

        /* Search box inside column chooser */
        .dx-column-chooser .dx-texteditor,
        .dx-column-chooser .dx-texteditor-input {
            background-color: var(--bg) !important;
            color: var(--text) !important;
            border: 1px solid var(--border) !important;
        }

        /* Scrollbar in column chooser */
        .dx-column-chooser .dx-scrollable-scroll-content {
            background-color: var(--primary) !important;
        }

        /* ── DevExtreme Filter Panel / Builder ────────────────── */
        .dx-filterbuilder,
        .dx-filterbuilder-group,
        .dx-filterbuilder-item-value,
        .dx-filterbuilder-item-field {
            background-color: var(--surface) !important;
            color: var(--text) !important;
        }

        .dx-filter-menu .dx-menu-item-content,
        .dx-filterpanel-text {
            color: var(--text) !important;
        }

        /* ── DevExtreme Overlay / Tooltip ─────────────────────── */
        .dx-overlay-content,
        .dx-tooltip .dx-popup-content {
            background-color: var(--surface) !important;
            color: var(--text) !important;
            border: 1px solid var(--border) !important;
        }

        /* ── LIST VIEW: FORCE SUBMENU ITEMS TO STACK ONE PER ROW ── */
        [data-sidebar-view="list"] .nav-sub.show,
        [data-sidebar-view="list"] .nav-sub.collapsing {
            display: flex !important;
            flex-direction: column !important;
            width: 100%;
        }

        [data-sidebar-view="list"] .nav-sub .nav-link {
            width: 100%;
            flex: 0 0 auto;
        }

        /* ════════════════════════════════════════════════════
                   FIX #3: GRID-VIEW DETAIL/SUBMENU PANEL — clean spacing
                   Previously the items injected into #detail-view-body
                   had no dedicated padding/spacing rules at all (they
                   only inherited the bare `.nav-link` color rule), so
                   everything rendered edge-to-edge and cramped. This
                   gives each item breathing room, a rounded hover
                   state, and clear separation between module-type
                   groups (MASTER / ACTIVITIES / REPORTS etc).
                ════════════════════════════════════════════════════ */
        .sidebar-detail-view #detail-view-body {
            padding: .6rem .75rem 80px;
        }

        .sidebar-detail-view .nav-section {
            padding: 1rem .5rem .5rem;
            margin-top: .25rem;
        }

            .sidebar-detail-view .nav-section:first-child {
                margin-top: 0;
                padding-top: .5rem;
            }

            .sidebar-detail-view .nav-section:not(:first-child) {
                border-top: 1px solid rgba(255,255,255,.07);
            }

            .sidebar-detail-view .nav-section .nav-label {
                font-size: .68rem;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: rgba(255,255,255,.4) !important;
            }

        .sidebar-detail-view .nav-link {
            padding: .7rem .85rem;
            margin-bottom: 4px;
            border-radius: 10px;
            font-size: .85rem;
            font-weight: 500;
            align-items: center;
            gap: .65rem;
            line-height: 1.3;
        }

            .sidebar-detail-view .nav-link:hover {
                background: rgba(255,255,255,.08);
            }

            .sidebar-detail-view .nav-link span {
                flex: 1;
                white-space: normal;
            }

            .sidebar-detail-view .nav-link .bi-circle-fill,
            .sidebar-detail-view .nav-link .bi-chevron-right {
                flex-shrink: 0;
            }

        /* ════════════════════════════════════════════════════
                   FIX #4: MINI SIDEBAR BEHAVIOR
                   - Tiles view  → icons only, no text, single column
                   - List view   → keep full text, scroll horizontally
                                   to read it instead of wrapping/clipping
                ════════════════════════════════════════════════════ */
        [data-sidebar="mini"][data-sidebar-view="tiles"] #sidebar-home {
            grid-template-columns: 1fr;
            padding: 10px 8px 80px 8px;
            gap: 8px;
        }

        [data-sidebar="mini"][data-sidebar-view="tiles"] .nav-link-tile {
            flex-direction: row;
            height: 48px;
            padding: 0;
            gap: 0;
        }

            [data-sidebar="mini"][data-sidebar-view="tiles"] .nav-link-tile span {
                display: none;
            }

            [data-sidebar="mini"][data-sidebar-view="tiles"] .nav-link-tile i {
                font-size: 1.3rem;
            }

        [data-sidebar="mini"][data-sidebar-view="list"] .sidebar-nav {
            overflow-x: auto !important;
        }

        [data-sidebar="mini"][data-sidebar-view="list"] #sidebar-home,
        [data-sidebar="mini"][data-sidebar-view="list"] .nav-sub.show,
        [data-sidebar="mini"][data-sidebar-view="list"] .nav-sub.collapsing {
            width: max-content;
            min-width: 100%;
        }

        [data-sidebar="mini"][data-sidebar-view="list"] .nav-link,
        [data-sidebar="mini"][data-sidebar-view="list"] .nav-section-sub,
        [data-sidebar="mini"][data-sidebar-view="list"] .nav-section {
            white-space: nowrap;
            width: max-content;
            min-width: 220px;
        }

        [data-sidebar="mini"][data-sidebar-view="list"] .sidebar-nav::-webkit-scrollbar {
            height: 8px;
        }

        [data-sidebar="mini"][data-sidebar-view="list"] .sidebar-nav::-webkit-scrollbar-thumb {
            background: var(--primary) !important;
            border-radius: 4px;
        }

        /* ── GLOBAL ACTION BUTTONS (semantic colours — do NOT use --primary here) ── */
        /* All colours come from CSS variables set in :root and [data-theme="dark"]  */
        /* Load=Blue  Save=Green  Cancel=Grey  Clear=Grey  Delete=Red  Update=Green  Edit=SoftOrange */
        .btn-load {
            background-color: var(--btn-load-bg) !important;
            color:            var(--btn-load-color) !important;
            border-color:     var(--btn-load-border) !important;
        }
        .btn-load:hover {
            background-color: var(--btn-load-bg-hover) !important;
            border-color:     var(--btn-load-bg-hover) !important;
            color:            var(--btn-load-color) !important;
        }
        .btn-save {
            background-color: var(--btn-save-bg) !important;
            color:            var(--btn-save-color) !important;
            border-color:     var(--btn-save-border) !important;
        }
        .btn-save:hover {
            background-color: var(--btn-save-bg-hover) !important;
            border-color:     var(--btn-save-bg-hover) !important;
            color:            var(--btn-save-color) !important;
        }
        .btn-cancel {
            background-color: var(--btn-cancel-bg) !important;
            color:            var(--btn-cancel-color) !important;
            border-color:     var(--btn-cancel-border) !important;
        }
        .btn-cancel:hover {
            background-color: var(--btn-cancel-bg-hover) !important;
            border-color:     var(--btn-cancel-bg-hover) !important;
            color:            var(--btn-cancel-color) !important;
        }
        .btn-clear {
            background-color: var(--btn-clear-bg) !important;
            color:            var(--btn-clear-color) !important;
            border-color:     var(--btn-clear-border) !important;
        }
        .btn-clear:hover {
            background-color: var(--btn-clear-bg-hover) !important;
            border-color:     var(--btn-clear-bg-hover) !important;
            color:            var(--btn-clear-color) !important;
        }
        .btn-delete {
            background-color: var(--btn-delete-bg) !important;
            color:            var(--btn-delete-color) !important;
            border-color:     var(--btn-delete-border) !important;
        }
        .btn-delete:hover {
            background-color: var(--btn-delete-bg-hover) !important;
            border-color:     var(--btn-delete-bg-hover) !important;
            color:            var(--btn-delete-color) !important;
        }
        .btn-update {
            background-color: var(--btn-update-bg) !important;
            color:            var(--btn-update-color) !important;
            border-color:     var(--btn-update-border) !important;
        }
        .btn-update:hover {
            background-color: var(--btn-update-bg-hover) !important;
            border-color:     var(--btn-update-bg-hover) !important;
            color:            var(--btn-update-color) !important;
        }
        .btn-edit {
            background-color: var(--btn-edit-bg) !important;
            color:            var(--btn-edit-color) !important;
            border-color:     var(--btn-edit-border) !important;
        }
        .btn-edit:hover {
            background-color: var(--btn-edit-bg-hover) !important;
            border-color:     var(--btn-edit-bg-hover) !important;
            color:            var(--btn-edit-color) !important;
        }
    </style>
    @RenderSection("styles", required: false)
</head>
<body>

    <!-- ██ CIRCULAR / ANNOUNCEMENT SCROLLING BAR ████████████ -->
    <div class="circular-bar" id="circularBar">
        <div class="circular-bar-label">
            <i class="bi bi-megaphone-fill"></i> CIRCULARS
        </div>
        <div class="circular-bar-track">
            <div class="circular-bar-inner" id="circularBarInner">
                <!-- items injected by JS — duplicated for seamless loop -->
            </div>
        </div>
    </div>

    <!-- ██ SIDEBAR ████████████████████████████████████████████ -->
    <nav id="sidebar">
        <!-- 1. TABS AT THE TOP (as per Screenshot 1) -->
        <div class="sidebar-tabs">
            <button class="sb-tab active" id="tab-grid" onclick="switchSidebarView('tiles', this)" title="Tiles View">
                <i class="bi bi-grid-3x3-gap-fill"></i>
            </button>
            <button class="sb-tab" id="tab-list" onclick="switchSidebarView('list', this)" title="List View">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <!-- 2. LOGO AREA -->
        <div class="sidebar-logo">
            <img src="~/images/VGN360.png" alt="VGN360" style="max-height:56px; max-width:100%; object-fit:contain;" />
        </div>

        <!-- 2.5 MENU SEARCH BOX -->
        <div class="sidebar-search-wrap">
            <div class="sidebar-search">
                <i class="bi bi-search"></i>
                <input type="text" id="menuSearch" placeholder="Search menus..." onkeyup="filterMenus()">
            </div>
        </div>

        <!-- 3. MAIN NAVIGATION CONTENT -->
        <div class="sidebar-nav" id="sidebar-home">
            <div class="nav-section list-only-item"><span class="nav-label">Main</span></div>

            <!-- Dashboard (Tiles View) -->
            <a class="nav-link-tile tile-blue grid-only-item @(ViewBag.ActiveMenu=="Dashboard"?"active":"")" href="/GeneralDashboard/Index" title="Dashboard">
                <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
            </a>

            <!-- Dashboard (List View) -->
            <a class="nav-link list-only-item @(ViewBag.ActiveMenu=="Dashboard"?"active":"")" href="/GeneralDashboard/Index" title="Dashboard">
                <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
            </a>

            @if (dynamicMenus != null && dynamicMenus.Any())
            {
                var departments = dynamicMenus.GroupBy(m => m.Department).OrderBy(g => g.Key).ToList();
                string[] tileColors = { "tile-cyan", "tile-purple", "tile-green", "tile-blue", "tile-brown", "tile-pink", "tile-red", "tile-lime", "tile-orange", "tile-teal" };

                // FIX #4: shared module-type display order used for BOTH list view and detail-template view
                string[] moduleTypeOrder = { "DASHBOARD", "MASTER", "ACTIVITY", "REPORT" };

                for (int i = 0; i < departments.Count; i++)
                {
                    var deptGroup = departments[i];
                    string deptName = deptGroup.Key ?? "COMMON";
                    string safeDeptId = "dept-" + i;
                    string colorClass = tileColors[i % tileColors.Length];

                    // Icon Mapping
                    string icon = "bi-folder2-open";
                    if (deptName.Contains("ADMINISTRATION")) { icon = "bi-person-badge"; }
                    else if (deptName.Contains("HR") || deptName.Contains("HUMAN")) { icon = "bi-people"; }
                    else if (deptName.Contains("SALES")) { icon = "bi-cart3"; }
                    else if (deptName.Contains("CIVIL")) { icon = "bi-building-gear"; }
                    else if (deptName.Contains("PURCHASE")) { icon = "bi-bag-check"; }
                    else if (deptName.Contains("IT")) { icon = "bi-cpu"; }
                    else if (deptName.Contains("FINANCE") || deptName.Contains("ACCOUNTS")) { icon = "bi-cash-stack"; }
                    else if (deptName.Contains("CRM")) { icon = "bi-headset"; }

                    <!-- LIST VIEW ITEM (Accordion) -->
                    <a class="nav-link list-only-item" data-bs-toggle="collapse" data-bs-target="#@safeDeptId" aria-expanded="false" style="justify-content:space-between" title="@deptName">
                        <span class="flex items-center gap-2">
                            <i class="bi @icon"></i>
                            <span>@deptName</span>
                        </span>
                        <i class="bi bi-chevron-down text-sm"></i>
                    </a>

                    <div class="collapse nav-sub list-only-item" id="@safeDeptId" data-bs-parent="#sidebar-home">
                        @{
                            var moduleTypes = deptGroup
                                .GroupBy(m => m.ModuleType)
                                .OrderBy(g =>
                                {
                                    int idx = Array.IndexOf(moduleTypeOrder, (g.Key ?? "").ToUpper());
                                    return idx == -1 ? int.MaxValue : idx;
                                });
                        }
                        @foreach (var modGroup in moduleTypes)
                        {
                            string modType = modGroup.Key ?? "OTHER";
                            <!-- FIX #4: module-type sub-header now rendered in LIST view too -->
                            <div class="nav-section-sub list-only-item"><span class="nav-label-sub">@modType</span></div>
                            @foreach (var item in modGroup.OrderBy(m => m.ModuleCaptionName))
                            {
                                string url = "/" + item.ControllerName + "/" + item.ActionName;
                                <a class="nav-link list-only-item" href="@url" style="font-size: 0.82rem; padding: 0.4rem 1rem 0.4rem 2rem">
                                    <span>@item.ModuleCaptionName</span>
                                </a>
                            }
                        }
                    </div>

                    <!-- GRID VIEW TILE -->
                    <div class="nav-link-tile @colorClass grid-only-item" onclick="openSidebarDetail('@deptName', '@safeDeptId')" title="@deptName">
                        <i class="bi @icon"></i>
                        <span>@deptName</span>
                    </div>
                }
            }
        </div>

        <!-- 4. DETAIL / SUBMENU VIEW (Overlays Main Nav) -->
        <div class="sidebar-detail-view" id="sidebar-detail">
            <div class="detail-header">
                <button class="detail-back-btn" onclick="closeSidebarDetail()">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <h5 class="detail-title" id="detail-view-title">Menu</h5>
            </div>
            <div class="sidebar-nav" id="detail-view-body">
                <!-- Submenus dynamic injection -->
            </div>
        </div>

        <!-- 5. TEMPLATES FOR GRID DETAIL VIEWS -->
        @if (dynamicMenus != null && dynamicMenus.Any())
        {
            <div id="detail-templates" style="display:none">
                @{
                    var depts_t = dynamicMenus.GroupBy(m => m.Department).OrderBy(g => g.Key).ToList();
                    string[] moduleTypeOrder_t = { "DASHBOARD", "MASTER", "ACTIVITY", "REPORT" };
                    for (int i = 0; i < depts_t.Count; i++)
                    {
                        var deptGroup = depts_t[i];
                        string safeDeptId = "dept-" + i;
                        <div id="@safeDeptId-template">
                            @{
                                // FIX #4: use the SAME priority order here as in the live list view
                                // (previously this block sorted alphabetically by g.Key, which made
                                // tile-detail order disagree with list-view order)
                                var moduleTypes = deptGroup
                                    .GroupBy(m => m.ModuleType)
                                    .OrderBy(g =>
                                    {
                                        int idx = Array.IndexOf(moduleTypeOrder_t, (g.Key ?? "").ToUpper());
                                        return idx == -1 ? int.MaxValue : idx;
                                    });
                            }
                            @foreach (var modGroup in moduleTypes)
                            {
                                string modType = modGroup.Key ?? "OTHER";
                                <div class="nav-section"><span class="nav-label">@modType</span></div>
                                @foreach (var item in modGroup.OrderBy(m => m.ModuleCaptionName))
                                {
                                    string url = "/" + item.ControllerName + "/" + item.ActionName;
                                    <a class="nav-link" href="@url">
                                        <i class="bi bi-circle-fill" style="font-size:0.4rem;opacity:0.5"></i>
                                        <span>@item.ModuleCaptionName</span>
                                        <i class="bi bi-chevron-right ml-auto text-sm opacity-30"></i>
                                    </a>
                                }
                            }
                        </div>
                    }
                }
            </div>
        }
    </nav>

    <!-- ██ TOPBAR ████████████████████████████████████████████ -->
    <header id="topbar">
        <button class="topbar-toggle" id="sidebarToggle" title="Toggle sidebar">
            <i class="bi bi-list"></i>
        </button>

        @{
            string rawTitle = ViewBag.Title?.ToString() ?? "";
            // Strip " - VGN ERP" suffix if present
            string pageTitle = rawTitle.Contains(" - ") ? rawTitle.Substring(0, rawTitle.LastIndexOf(" - ")) : rawTitle;
        }
        @if (!string.IsNullOrEmpty(pageTitle))
        {
            <span class="topbar-page-title">@pageTitle</span>
        }

        <div class="topbar-right">
            <!-- CHAT BTN -->
            <div class="notif-btn-wrap">
                <button class="topbar-btn" id="openChatBtn" title="Live Chat" onclick="openChatPanel()">
                    <i class="bi bi-chat-dots"></i>
                </button>
                <span class="notif-badge" id="chatUnreadTotal" style="display:none;">0</span>
            </div>

            <!-- NOTIFICATION BELL -->
            <div class="notif-btn-wrap">
                <button class="topbar-btn" id="openNotif" title="Notifications">
                    <i class="bi bi-bell"></i>
                </button>
                <span class="notif-badge" id="notifCount">3</span>
            </div>

            <!-- SHORTCUTS DROPDOWN -->
            <div class="dropdown inline-block relative">
                <button class="topbar-btn" title="Shortcuts" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-grid"></i>
                </button>
                <div class="dropdown-menu absolute right-0 shadow-xl border-0 p-3" style="min-width: 280px; border-radius: 12px; background: var(--surface); z-index: 1000;">
                    <h6 class="uppercase font-bold mb-3 px-1" style="font-size: 0.75rem; letter-spacing: 0.5px; color: var(--text-muted);">Quick Shortcuts</h6>
                    <div class="grid grid-cols-3 gap-2">
                        <div>
                            <a class="dropdown-item block p-2 rounded-lg text-center flex flex-col items-center justify-center h-full hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="/GeneralDashboard/Index" style="white-space: normal; background: transparent;">
                                <div class="rounded-full flex items-center justify-center mb-2" style="width: 42px; height: 42px; background: rgba(70,128,255,0.1); color: var(--primary);">
                                    <i class="bi bi-journal-bookmark text-xl"></i>
                                </div>
                                <span style="font-size: 0.72rem; font-weight: 600; color: var(--text);">Daybook</span>
                            </a>
                        </div>
                        <div>
                            <a class="dropdown-item block p-2 rounded-lg text-center flex flex-col items-center justify-center h-full hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="#" style="white-space: normal; background: transparent;">
                                <div class="rounded-full flex items-center justify-center mb-2" style="width: 42px; height: 42px; background: rgba(249,115,22,0.1); color: #f97316;">
                                    <i class="bi bi-calendar2-x text-xl"></i>
                                </div>
                                <span style="font-size: 0.72rem; font-weight: 600; color: var(--text);">Leave</span>
                            </a>
                        </div>
                        <div>
                            <a class="dropdown-item block p-2 rounded-lg text-center flex flex-col items-center justify-center h-full hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="#" style="white-space: normal; background: transparent;">
                                <div class="rounded-full flex items-center justify-center mb-2" style="width: 42px; height: 42px; background: rgba(16,185,129,0.1); color: #10b981;">
                                    <i class="bi bi-receipt text-xl"></i>
                                </div>
                                <span style="font-size: 0.72rem; font-weight: 600; color: var(--text);">Payslip</span>
                            </a>
                        </div>
                        <div>
                            <a class="dropdown-item block p-2 rounded-lg text-center flex flex-col items-center justify-center h-full hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="#" style="white-space: normal; background: transparent;">
                                <div class="rounded-full flex items-center justify-center mb-2" style="width: 42px; height: 42px; background: rgba(139,92,246,0.1); color: #8b5cf6;">
                                    <i class="bi bi-ticket-detailed text-xl"></i>
                                </div>
                                <span style="font-size: 0.72rem; font-weight: 600; color: var(--text);">Tickets</span>
                            </a>
                        </div>
                        <div>
                            <a class="dropdown-item block p-2 rounded-lg text-center flex flex-col items-center justify-center h-full hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="#" style="white-space: normal; background: transparent;">
                                <div class="rounded-full flex items-center justify-center mb-2" style="width: 42px; height: 42px; background: rgba(236,72,153,0.1); color: #ec4899;">
                                    <i class="bi bi-paperclip text-xl"></i>
                                </div>
                                <span style="font-size: 0.72rem; font-weight: 600; color: var(--text);">Attach</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- MAP LOCATION (BOUNCING) -->
            <button class="topbar-btn" title="Location">
                <i class="bi bi-geo-alt-fill text-red-500 bounce-icon"></i>
            </button>

            <!-- FULL SCREEN -->
            <button class="topbar-btn" id="fullScreenBtn" title="Full Screen" onclick="toggleFullScreen()">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>

            <!-- SETTINGS TRIGGER -->
            <button class="topbar-btn" id="openSettings" title="Customize">
                <i class="bi bi-sliders"></i>
            </button>

            <!-- USER DROPDOWN -->
            <div class="dropdown relative">
                <div class="topbar-user" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="user-avatar" style="width:34px;height:34px;font-size:.8rem">@(userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U")</div>
                    <div class="u-info hidden md:block">
                        <div class="name">@userName</div>
                        <div class="role">@userDesignation</div>
                    </div>
                    <i class="bi bi-chevron-down text-sm ml-1 text-gray-400"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end absolute right-0 shadow-xl border-0 bg-[var(--surface)] text-[var(--text)] rounded-lg py-2" style="min-width:200px; z-index: 1000;">
                    <li class="px-2">
                        <a class="dropdown-item block rounded-lg px-4 py-2 hover:bg-black/5 dark:hover:bg-white/5 transition-colors" href="#" data-bs-toggle="modal" data-bs-target="#profileModal">
                            <i class="bi bi-person mr-2"></i>My Profile
                        </a>
                    </li>
                    <li class="my-1"><hr class="border-t border-gray-200/20 m-0"></li>
                    <li class="px-2">
                        <a class="dropdown-item block text-red-500 rounded-lg px-4 py-2 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" href="/Account/Logout">
                            <i class="bi bi-box-arrow-left mr-2"></i>Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <!-- PROFILE MODAL -->
    <div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl rounded-2xl overflow-hidden bg-[var(--surface)] text-[var(--text)]">
                <div class="modal-header bg-primary text-white border-0 px-5 py-4 flex justify-between items-center">
                    <h5 class="modal-title font-bold text-lg"><i class="bi bi-person-badge mr-2"></i>My Profile</h5>
                    <button type="button" class="text-white hover:opacity-75 transition-opacity" data-bs-dismiss="modal" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="modal-body p-6">
                    <div class="text-center mb-6">
                        <div class="user-avatar mx-auto mb-3" style="width:80px;height:80px;font-size:2rem;box-shadow:0 4px 10px rgba(0,0,0,0.1)">@(userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U")</div>
                        <h5 class="mb-1 font-bold text-xl" style="color:var(--text)">@userName</h5>
                        <p class="mb-0 text-sm text-[var(--text-muted)]">@userDesignation</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Department</label>
                            <div class="font-medium">@(user?.Department ?? "N/A")</div>
                        </div>
                        <div>
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Mobile No</label>
                            <div class="font-medium">@(user?.MobileNo ?? "N/A")</div>
                        </div>
                        <div class="col-span-1 sm:col-span-2">
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Email ID</label>
                            <div class="font-medium">@(user?.Email ?? "N/A")</div>
                        </div>
                        <div class="col-span-1 sm:col-span-2 mt-4 pt-4 border-t border-gray-200/20">
                            <h6 class="font-bold mb-4 text-sm"><i class="bi bi-diagram-3 mr-2 text-primary"></i>Reporting Manager</h6>
                        </div>
                        <div>
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Name</label>
                            <div class="font-medium">@(user?.RptEmpName ?? "N/A")</div>
                        </div>
                        <div>
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Mobile No</label>
                            <div class="font-medium">@(user?.ReportingMobileNum ?? "N/A")</div>
                        </div>
                        <div class="col-span-1 sm:col-span-2">
                            <label class="text-xs text-[var(--text-muted)] mb-1 block">Email ID</label>
                            <div class="font-medium">@(user?.ReprotingMailId ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ██ MAIN CONTENT ████████████████████████████████████ -->
    <main id="main-content">
        @RenderBody()
        <!-- Spacer to prevent content from hiding behind the fixed footer -->
        <div style="height: 80px; width: 100%;"></div>
        @await Html.PartialAsync("_footer")
    </main>

