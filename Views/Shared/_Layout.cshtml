                    <div class="notif-body">
                        <div class="notif-title">New user registered</div>
                        <div class="notif-desc">PRAVEEN L has been approved as Employee</div>
                        <div class="notif-time"><i class="bi bi-clock mr-1"></i>Yesterday</div>
                    </div>
                </div>
                <div class="notif-item" onclick="markRead(this)">
                    <div class="notif-icon red"><i class="bi bi-file-earmark-x"></i></div>
