        /* ── SIDEBAR VISIBILITY FIXES ────────────────────── */
        @@keyframes bounce-subtle {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); }
        }
        .bounce-icon {
            display: inline-block;
            animation: bounce-subtle 1.5s infinite ease-in-out;
