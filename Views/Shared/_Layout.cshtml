        }

        /* ════════════════════════════════════════════════════
               FIX #1: SIDEBAR TEXT COLOR — sidebar is always dark
               navy, so all sidebar text/icons must always be light,
               regardless of the light/dark THEME toggle.
               (Previously .nav-link had no color rule at all and
               silently inherited var(--text), which is near-black
               in light mode → invisible text on dark sidebar.)
            ════════════════════════════════════════════════════ */
        #sidebar .nav-link {
            color: var(--sidebar-text);
        }

            #sidebar .nav-link i {
                color: var(--sidebar-text);
            }

            #sidebar .nav-link span {
                color: inherit;
            }

            #sidebar .nav-link:hover,
            #sidebar .nav-link:hover i,
            #sidebar .nav-link:hover span {
                background: var(--sidebar-hover-bg);
                color: var(--sidebar-hover-color) !important;
            }

            #sidebar .nav-link.active {
                background: var(--sidebar-active);
                color: var(--primary) !important;
                border-left: 3px solid var(--primary);
            }

                #sidebar .nav-link.active i,
                #sidebar .nav-link.active span {
                    color: var(--primary) !important;
                }

        #sidebar .nav-label {
            color: var(--sidebar-label-color) !important;
        }

        /* Section header for module-type groups inside list view (Dashboard/Master/Activity/Report) */
        #sidebar .nav-section-sub {
            padding: .55rem 1.25rem .25rem 1.6rem;
        }

            #sidebar .nav-section-sub .nav-label-sub {
                font-size: .64rem;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: var(--sidebar-label-color);
            }

        /* ── PROFILE DROPDOWN COMPACT FIX ────────────────── */
        .dropdown-menu-user {
            min-width: 260px !important;
            max-width: 90vw !important;
            max-height: min(75vh, 480px) !important;
            overflow-y: auto !important;
            overflow-x: hidden;
            padding: 0 !important;
            border-radius: 12px !important;
            box-shadow: 0 10px 40px rgba(0,0,0,0.15) !important;
        }

        .user-header-compact {
            padding: 1.25rem !important;
            background: var(--bg) !important;
            border-bottom: 1px solid var(--border) !important;
            border-radius: 12px 12px 0 0 !important;
        }

            .user-header-compact .user-avatar {
                width: 54px !important;
                height: 54px !important;
                font-size: 1.4rem !important;
                margin-bottom: 0.75rem !important;
            }

        /* ── HIGH CONTRAST ───────────────────────────────── */
        [data-contrast="high"] {
            --border: #000000;
        }

            [data-contrast="high"][data-theme="dark"] {
                --border: #ffffff;
            }

        /* ── GLOBAL FORM STYLING ────────────────────────── */
        /* Force borders on all form fields dynamically */
        .form-control, .form-select, .form-check-input, .form-range {
            border: 1px solid var(--border) !important;
            background-color: var(--surface) !important;
            color: var(--text) !important;
            transition: border-color var(--trans), box-shadow var(--trans);
        }

            .form-control::placeholder {
                color: var(--text-muted);
                opacity: 0.6;
            }

            .form-control:focus, .form-select:focus, .form-check-input:focus {
                border-color: var(--primary) !important;
                box-shadow: 0 0 0 0.25rem rgba(var(--primary-rgb), 0.25) !important;
                outline: none;
            }

        .form-label, .form-check-label {
            color: var(--text);
            font-weight: 500;
        }

        /* Radio buttons and Checkboxes */
        .form-check-input:checked {
            background-color: var(--primary) !important;
            border-color: var(--primary) !important;
        }

        /* ── DYNAMIC THEME FIXES ────────────────────────── */
        /* DevExtreme Grid Global Text Color Fix */
        .dx-datagrid,
        .dx-datagrid-content .dx-datagrid-table .dx-row > td,
        .dx-datagrid-rowsview .dx-row > td,
        .dx-datagrid-headers .dx-header-row > td {
            color: var(--text) !important;
        }
        
        /* Disable hover on empty/freespace rows globally */
        .dx-datagrid-rowsview .dx-freespace-row:hover > td,
        .dx-datagrid-rowsview .dx-freespace-row.dx-state-hover > td,
        .dx-datagrid-rowsview .dx-empty-message:hover > td,
        .dx-datagrid-rowsview .dx-empty-message.dx-state-hover > td {
            background-color: transparent !important;
        }

        /* Select2 Dropdown Dynamic Theme Support */
        .select2-container--default .select2-selection--single,
        .select2-container--default .select2-selection--multiple,
        .select2-dropdown {
            background-color: var(--surface) !important;
            border-color: var(--border) !important;
            color: var(--text) !important;
        }
        /* Single select rendered value */
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            color: var(--text) !important;
        }
        /* Multi-select: the choice chip (tag) — must override Select2's hardcoded #e4e4e4 bg */
        .select2-container--default .select2-selection--multiple .select2-selection__choice {
            background-color: rgba(var(--primary-rgb), 0.15) !important;
            border-color: rgba(var(--primary-rgb), 0.35) !important;
            color: var(--text) !important;
        }
        /* The text label inside the chip */
        .select2-container--default .select2-selection--multiple .select2-selection__choice__display {
            color: var(--text) !important;
        }
        /* The remove × inside the chip */
        .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
            color: var(--text-muted) !important;
            border-right-color: rgba(var(--primary-rgb), 0.35) !important;
        }
        .select2-container--default .select2-selection--multiple .select2-selection__choice__remove:hover {
            background-color: rgba(var(--primary-rgb), 0.25) !important;
            color: var(--text) !important;
        }
        /* The inline search input inside multi-select */
        .select2-container--default .select2-selection--multiple .select2-search__field {
            color: var(--text) !important;
        }
        .select2-container--default .select2-results__option {
            color: var(--text) !important;
            background-color: var(--surface) !important;
        }
        .select2-container--default .select2-results__option[aria-selected=true] {
            background-color: rgba(128, 128, 128, 0.2) !important;
            color: var(--text) !important;
        }
        .select2-container--default .select2-results__option--highlighted[aria-selected] {
            background-color: var(--primary) !important;
            color: #fff !important;
        }
        .select2-search--dropdown .select2-search__field {
            background-color: var(--bg) !important;
            color: var(--text) !important;
            border-color: var(--border) !important;
        }

        /* Datetime Picker Dark Mode Support */
        [data-theme="dark"] input[type="date"],
        [data-theme="dark"] input[type="datetime-local"],
        [data-theme="dark"] input[type="time"],
        [data-theme="dark"] input[type="month"] {
            color-scheme: dark;
        }

        /* ── BASE ────────────────────────────────────────── */
        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            font-family: var(--font-family);
            font-size: var(--font-size-base);
            background: var(--bg);
            color: var(--text);
            transition: background var(--trans), color var(--trans);
        }

        a {
            text-decoration: none;
        }

        /* ── THEME-AWARE ICONS IN TOPBAR/MAIN ───────────── */
        /* topbar buttons, main content icons follow theme */
        .topbar-btn i,
        .topbar-toggle i,
        #main-content i,
        #main-content .bi,
        #main-content [class^="bi-"],
        #main-content [class*=" bi-"],
        #main-content .fas,
        #main-content .far,
        #main-content .fab,
        #main-content .fa,
        .page-title,
        .page-breadcrumb,
        .erp-card {
            color: var(--text);
            transition: color var(--trans);
        }
        /* force topbar icon color in dark */
        [data-theme="dark"] .topbar-btn {
            color: #e2e8f0;
        }

        [data-theme="dark"] .topbar-toggle {
            color: #e2e8f0;
        }

        [data-theme="dark"] .topbar-search {
            color: #e2e8f0;
        }

            [data-theme="dark"] .topbar-search input {
                color: #e2e8f0;
            }

        [data-theme="dark"] .topbar-user .name {
            color: #e2e8f0;
        }

        [data-theme="dark"] .topbar-user .role {
            color: #8892a4;
        }
        /* light stays default dark */
        [data-theme="light"] .topbar-btn {
            color: #1a1a2e;
        }

        [data-theme="light"] .topbar-toggle {
            color: #1a1a2e;
        }

        /* ════════════════════════════════════════════════════
                       SCROLLING CIRCULAR / ANNOUNCEMENT BAR
                    ════════════════════════════════════════════════════ */
        .circular-bar {
            background: linear-gradient(90deg, #1b2039, #2d3561, #1b2039);
            color: #fff;
            height: 36px;
            display: flex;
            align-items: center;
            overflow: hidden;
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            z-index: 950;
            transition: left var(--trans);
        }

        [data-sidebar="mini"] .circular-bar {
            left: var(--sidebar-mini);
        }

        [data-sidebar="hidden"] .circular-bar {
            left: 0;
        }

        .circular-bar-label {
            background: var(--primary);
            padding: 0 14px;
            height: 100%;
            display: flex;
            align-items: center;
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .5px;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .circular-bar-label i {
                margin-right: 5px;
            }

        .circular-bar-track {
            flex: 1;
            overflow: hidden;
            position: relative;
        }

        .circular-bar-inner {
            display: flex;
            gap: 80px;
            animation: scrollText 40s linear infinite;
            width: max-content;
        }

            .circular-bar-inner:hover {
                animation-play-state: paused;
            }

        .circular-item {
            font-size: .78rem;
            white-space: nowrap;
            opacity: .9;
        }

            .circular-item::before {
                content: '◆';
                color: var(--primary);
                margin-right: 8px;
                font-size: .6rem;
            }

        @@keyframes scrollText {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        /* ── VIEW TOGGLE LOGIC ───────────────────────────── */
        /* By default, hide tiles and detail view */
        .grid-only-item, .sidebar-detail-view {
            display: none !important;
        }

        /* Detail View Container */
        .sidebar-detail-view {
            flex-direction: column;
            height: 100%;
            background: var(--sidebar-bg);
            position: absolute;
            inset: 0;
            z-index: 1001;
            transform: translateX(100%);
            transition: transform 0.3s ease;
        }

            .sidebar-detail-view.active {
                display: flex !important;
                transform: translateX(0);
            }

        .detail-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,.1);
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(0,0,0,0.2);
        }

        .detail-back-btn {
            background: rgba(255,255,255,0.1);
            border: none;
            color: #fff;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .detail-title {
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
            margin: 0;
            text-transform: uppercase;
        }

        /* Sidebar Tabs at the very top */
        .sidebar-tabs {
            display: flex;
            border-bottom: 1px solid var(--sidebar-tabs-border);
            background: var(--sidebar-tabs-bg);
        }

        .sb-tab {
            flex: 1;
            padding: 12px;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            color: var(--sidebar-tab-color);
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .sb-tab.active {
                color: var(--sidebar-tab-active-color);
                border-bottom-color: var(--primary);
                background: var(--sidebar-tab-active-bg);
            }

        /* User Profile at the bottom (kept for potential future use; not rendered in nav now) */
        .sidebar-footer {
            padding: 1rem 1.2rem;
            border-top: 1px solid rgba(255,255,255,.06);
            display: flex;
            align-items: center;
            gap: .75rem;
            background: rgba(0,0,0,0.1);
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            min-width: 36px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: #fff;
            font-size: .9rem;
        }

        .sidebar-footer-text .u-name {
            font-size: .85rem;
            font-weight: 600;
            color: #fff;
        }

        .sidebar-footer-text .u-role {
            font-size: .72rem;
            color: rgba(255,255,255,.45);
        }

        /* ════════════════════════════════════════════════════
                       TOPBAR — sits below circular bar (top: 36px)
                    ════════════════════════════════════════════════════ */
        #topbar {
            position: fixed;
            top: 36px;
            right: 0;
            left: var(--sidebar-w);
            height: var(--topbar-h);
            background: var(--topbar-bg);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            gap: 1rem;
            z-index: 900;
            transition: left var(--trans), background var(--trans);
            box-shadow: var(--card-shadow);
        }

        [data-sidebar="mini"] #topbar {
            left: var(--sidebar-mini);
        }

        [data-sidebar="hidden"] #topbar {
            left: 0;
        }

        .topbar-toggle {
            background: none;
            border: none;
            color: var(--text);
            font-size: 1.3rem;
            cursor: pointer;
            padding: .3rem;
            border-radius: 8px;
            transition: background .15s, color .15s;
            flex-shrink: 0;
        }

        /* ── Page title shown in the topbar ── */
        .topbar-page-title {
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .5px;
            color: var(--text);
            text-transform: uppercase;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 420px;
            padding: 0 .5rem;
            opacity: .85;
        }
        [data-theme="light"] .topbar-page-title { color: #1a1a2e; }
        [data-theme="dark"]  .topbar-page-title { color: #e2e8f0; }
        @@media (max-width: 576px) { .topbar-page-title { display: none; } }

            .topbar-toggle:hover {
                background: var(--border);
                color: var(--text);
            }
        /* Light mode: dark icons. Dark mode: white icons. Always. */
        [data-theme="light"] .topbar-toggle {
            color: #1a1a2e;
        }

            [data-theme="light"] .topbar-toggle:hover {
                background: #e2e8f0;
                color: #1a1a2e;
            }

        [data-theme="dark"] .topbar-toggle {
            color: #e2e8f0;
        }

            [data-theme="dark"] .topbar-toggle:hover {
                background: #2a2f42;
                color: #ffffff;
            }

        .topbar-search {
            flex: 1;
            max-width: 320px;
            display: flex;
            align-items: center;
            gap: .5rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: .4rem .85rem;
            color: var(--text-muted);
            font-size: .88rem;
            transition: background var(--trans), border-color var(--trans);
        }

            .topbar-search input {
                border: none;
                background: transparent;
                color: var(--text);
                outline: none;
                font-size: .88rem;
                width: 100%;
            }

        .topbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .topbar-btn {
            width: 38px;
            height: 38px;
            border: none;
            background: none;
            color: var(--text);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            cursor: pointer;
            transition: background .15s, color .15s;
            position: relative;
        }
        /* Light mode topbar btn */
        [data-theme="light"] .topbar-btn {
            color: #1a1a2e;
        }

            [data-theme="light"] .topbar-btn:hover {
                background: #e2e8f0;
                color: #1a1a2e;
            }
        /* Dark mode topbar btn */
        [data-theme="dark"] .topbar-btn {
            color: #e2e8f0;
        }

            [data-theme="dark"] .topbar-btn:hover {
                background: #2a2f42;
                color: #ffffff;
            }

        .topbar-btn .dot {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #ef4444;
            border: 1.5px solid var(--topbar-bg);
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .3rem .7rem;
            border-radius: 10px;
            cursor: pointer;
            transition: background .15s;
        }

        [data-theme="light"] .topbar-user:hover {
            background: #e2e8f0;
        }

            [data-theme="light"] .topbar-user:hover .name,
            [data-theme="light"] .topbar-user:hover .role {
                color: #1a1a2e;
            }

        [data-theme="dark"] .topbar-user:hover {
            background: #2a2f42;
        }

            [data-theme="dark"] .topbar-user:hover .name {
                color: #ffffff;
            }

            [data-theme="dark"] .topbar-user:hover .role {
                color: #aab4c4;
            }

        .topbar-user .u-info .name {
            font-size: .85rem;
            font-weight: 600;
            color: var(--text);
        }

        .topbar-user .u-info .role {
            font-size: .72rem;
            color: var(--text-muted);
        }

        .dropdown-menu {
            display: none;
            background: var(--surface);
            border: 1px solid var(--border) !important;
            max-height: 85vh;
            overflow-y: auto;
        }
        .dropdown-menu.show {
            display: block;
        }

            .dropdown-menu::-webkit-scrollbar {
                width: 4px;
            }

            .dropdown-menu::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 2px;
            }

        .dropdown-item {
            color: var(--text);
        }

        [data-theme="light"] .dropdown-item:hover {
            background: #e8eeff;
            color: #1a1a2e;
        }

        [data-theme="dark"] .dropdown-item:hover {
            background: #2a2f42;
            color: #ffffff;
        }

        [data-theme="dark"] .dropdown-divider {
            border-color: var(--border);
        }

        /* ── MODAL FIX ───────────────────────────────────── */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow-x: hidden;
            overflow-y: auto;
            outline: 0;
            z-index: 1055;
        }
        .modal.show {
            display: block;
        }
        .modal-dialog {
            position: relative;
            width: auto;
            margin: .5rem;
            pointer-events: none;
        }
        .modal.fade .modal-dialog {
            transition: transform .3s ease-out;
            transform: translateY(-50px);
        }
        .modal.show .modal-dialog {
            transform: none;
        }
        .modal.fade {
            transition: opacity .15s linear;
        }
        .modal.fade:not(.show) {
            opacity: 0;
        }
        .modal-dialog-centered {
            display: flex;
            align-items: center;
            min-height: calc(100% - 1rem);
        }
        .modal-content {
            position: relative;
            display: flex;
            flex-direction: column;
            width: 100%;
            pointer-events: auto;
            background-clip: padding-box;
            outline: 0;
        }
        .modal-backdrop {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1050;
            width: 100vw;
            height: 100vh;
            background-color: #000;
        }
        .modal-backdrop.fade { opacity: 0; transition: opacity .15s linear; }
        .modal-backdrop.show { opacity: 0.5; }
        body.modal-open {
            overflow: hidden;
        }
        @@media (min-width: 576px) {
            .modal-dialog {
                max-width: 500px;
                margin: 1.75rem auto;
            }
            .modal-dialog-centered {
                min-height: calc(100% - 3.5rem);
            }
        }

        /* ════════════════════════════════════════════════════
                       MAIN CONTENT — pushed below circular bar + topbar
                    ════════════════════════════════════════════════════ */
        #main-content {
            margin-left: var(--sidebar-w);
            margin-top: calc(36px + var(--topbar-h));
            padding: 1.75rem;
            padding-bottom: 80px; /* Make space for the absolute footer */
            min-height: calc(100vh - 36px - var(--topbar-h));
            transition: margin-left var(--trans);
            position: relative;
        }

        [data-sidebar="mini"] #main-content {
            margin-left: var(--sidebar-mini);
        }

        [data-sidebar="hidden"] #main-content {
            margin-left: 0;
        }

        .page-header {
            margin-bottom: 1.5rem;
        }

        .page-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0;
            color: var(--text);
        }

        .page-breadcrumb .breadcrumb {
            font-size: .82rem;
            margin: 0;
        }

        .breadcrumb-item, .breadcrumb-item a {
            color: var(--text-muted);
        }

            .breadcrumb-item.active {
                color: var(--text);
            }

        .erp-card {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border);
            padding: 1.5rem;
            transition: background var(--trans), border-color var(--trans);
            color: var(--text);
        }

        /* ════════════════════════════════════════════════════
                       NOTIFICATION RIGHT PANEL
                    ════════════════════════════════════════════════════ */
        #notif-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.35);
            z-index: 1099;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--trans);
        }

            #notif-overlay.open {
                opacity: 1;
                pointer-events: all;
            }

        #notif-panel {
            position: fixed;
            top: 0;
            right: -380px;
            width: 360px;
            height: 100vh;
            background: var(--surface);
            border-left: 1px solid var(--border);
            z-index: 1100;
            display: flex;
            flex-direction: column;
            transition: right var(--trans);
            box-shadow: -8px 0 32px rgba(0,0,0,.12);
