    <!-- DevExtreme Global Override -->
    <script>
        DevExpress.ui.dxDataGrid.defaultOptions({
            options: {
                height: 500,
                filterRow: {
                    visible: false
                },
                onToolbarPreparing: function(e) {
                    var toolbarItems = e.toolbarOptions.items;
                    toolbarItems.unshift({
                        location: 'before',
                        template: function() {
                            return $('<div/>')
                                .addClass('sa-count-badge')
                                .html('<i class="bi bi-table"></i> <span class="grid-row-count-val">0</span> Rows');
                        }
                    });
                },
                onContentReady: function(e) {
                    var count = e.component.totalCount();
                    if(count === -1) count = e.component.getDataSource() ? e.component.getDataSource().items().length : 0;
                    
                    var formatIndian = function(n) {
                        if (n === null || n === undefined || isNaN(n)) return '0';
                        n = Math.round(n);
                        var s = n.toString();
                        if (s.length <= 3) return s;
                        var last3 = s.slice(-3);
                        var rest = s.slice(0, -3);
                        return rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + ',' + last3;
                    };
                    
                    var badge = e.element.find('.grid-row-count-val');
                    if(badge.length) {
                        badge.text(formatIndian(count));
                    }
                }
            }
        });
    </script>

