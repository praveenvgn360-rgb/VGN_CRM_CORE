@using System.Linq
@{
    var user = VGN_CRM_CORE.CommonFunctions.SessionHelper.GetUserSession(Context.Session);
    var userName = user != null ? user.UserName : "User";
    var userRole = user != null ? user.Role : "";
    var userDesignation = user != null && !string.IsNullOrEmpty(user.Designation) ? user.Designation : userRole;
    var loginTime = user != null ? user.LoginTime.ToString("hh:mm tt, dd MMM yyyy") : "";
    var ipAddr = user != null ? user.IPAddress : "";
    var hostName = user != null ? user.HostName : "";
    var dept = user != null ? user.Role : "COMMON"; // used for dept-based dashboard

    // Load dynamic menus from session
    var dynamicMenus = VGN_CRM_CORE.CommonFunctions.SessionHelper.GetMenuList(Context.Session);
}
<!DOCTYPE html>
<html lang="en" data-theme="light" data-primary="#a82024" data-sidebar="full" data-contrast="default" data-sidebar-view="tiles">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title — VGN ERP</title>
    <script>
        (function() {
            try {
                var raw = localStorage.getItem('vgn_prefs');
                if (raw) {
                    var p = JSON.parse(raw);
                    var html = document.documentElement;
                    if (p.ThemeMode) html.dataset.theme = p.ThemeMode === 'auto' ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : p.ThemeMode;
                    if (p.Contrast) html.dataset.contrast = p.Contrast;
                    if (p.MenuView) html.dataset.sidebarView = p.MenuView;
                    if (p.SidebarType) html.dataset.sidebar = p.SidebarType === 'mini' ? 'full' : p.SidebarType;
                }
            } catch(e) {}
        })();
    </script>
