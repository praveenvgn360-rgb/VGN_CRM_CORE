    /* ══ MENU SEARCH FILTER ══ */
        function filterMenus() {
            var filter = document.getElementById('menuSearch').value.toLowerCase().trim();
            var sidebar = document.getElementById('sidebar-home');
            var isListView = document.documentElement.dataset.sidebarView === 'list';

            // Remove previous search results
            sidebar.querySelectorAll('.srch-item').forEach(function (el) { el.remove(); });

            // ── CLEAR: restore everything ─────────────────────────────
            if (!filter) {
                sidebar.querySelectorAll('.list-only-item').forEach(function (el) {
                    el.style.display = '';
                });
                sidebar.querySelectorAll('.grid-only-item').forEach(function (el) {
                    el.style.display = '';
                });
                return;
            }

            // ── LIST VIEW ─────────────────────────────────────────────
            if (isListView) {
                // Hide all dept toggles and their collapse divs
                sidebar.querySelectorAll('.list-only-item').forEach(function (el) {
                    el.style.display = 'none';
                });

                // ── Read directly from the live list-view collapse divs ──
                // This is more reliable than reading from tile templates because
                // the collapse divs are the actual rendered list-view items.
                var matches = [];

                // Each dept accordion: a.nav-link[data-bs-toggle=collapse] + div.nav-sub
                sidebar.querySelectorAll('a.list-only-item[data-bs-toggle="collapse"]').forEach(function (deptToggle) {
                    // Get dept label from the inner <span><span> structure
                    var deptSpanOuter = deptToggle.querySelector('span');
                    var deptSpanInner = deptSpanOuter ? deptSpanOuter.querySelector('span') : null;
                    var deptName = (deptSpanInner || deptSpanOuter || deptToggle).textContent.trim();

                    // Find the matching collapse div
                    var targetId = deptToggle.getAttribute('data-bs-target');
                    if (!targetId) return;
                    var collapseDiv = sidebar.querySelector(targetId);
                    if (!collapseDiv) return;

                    // Scan all nav-link anchors inside the collapse
                    collapseDiv.querySelectorAll('a.nav-link').forEach(function (a) {
                        var spanEl = a.querySelector('span');
                        var label = spanEl ? spanEl.textContent.trim() : a.textContent.trim();
                        if (label.toLowerCase().includes(filter)) {
                            matches.push({
                                label: label,
                                href: a.getAttribute('href'),
                                dept: deptName
                            });
                        }
                    });
                });

                if (matches.length === 0) {
                    var noRes = document.createElement('div');
                    noRes.className = 'srch-item';
                    noRes.style.cssText = 'padding:2rem 1.25rem;text-align:center;color:var(--text-muted);font-size:.85rem;';
                    noRes.innerHTML = '<i class="bi bi-search" style="font-size:1.8rem;opacity:.25;display:block;margin-bottom:.5rem"></i>No results for <strong>"' + document.getElementById('menuSearch').value + '"</strong>';
                    sidebar.insertBefore(noRes, sidebar.firstChild);
                } else {
                    var resultsWrap = document.createElement('div');
                    resultsWrap.className = 'srch-item';
                    resultsWrap.style.cssText = 'display:flex;flex-direction:column;';
                    sidebar.insertBefore(resultsWrap, sidebar.firstChild);

                    matches.forEach(function (m) {
                        var a = document.createElement('a');
                        a.className = 'srch-item';
                        a.href = m.href || '#';
                        a.style.cssText = [
                            'display:flex',
                            'align-items:center',
                            'justify-content:space-between',
                            'padding:.65rem 1.25rem',
                            'color:var(--sidebar-text)',
                            'text-decoration:none',
                            'font-size:.85rem',
                            'border-bottom:1px solid var(--sidebar-border)',
                            'cursor:pointer'
                        ].join(';');

                        var nameSpan = document.createElement('span');
                        nameSpan.style.flex = '1';
                        nameSpan.textContent = m.label;
                        a.appendChild(nameSpan);

                        var badge = document.createElement('span');
                        badge.textContent = m.dept;
                        badge.style.cssText = [
                            'font-size:.6rem',
                            'font-weight:700',
                            'background:rgba(var(--primary-rgb),.12)',
                            'color:var(--primary)',
                            'border-radius:4px',
                            'padding:2px 6px',
                            'text-transform:uppercase',
                            'white-space:nowrap',
                            'margin-left:8px',
                            'flex-shrink:0'
                        ].join(';');
                        a.appendChild(badge);

                        a.addEventListener('mouseenter', function () {
                            this.style.background = 'var(--sidebar-hover-bg)';
                            this.style.color = 'var(--sidebar-hover-color)';
                        });
                        a.addEventListener('mouseleave', function () {
                            this.style.background = '';
                            this.style.color = 'var(--sidebar-text)';
                        });

                        resultsWrap.appendChild(a);
                    });
                }
                sidebar.scrollTop = 0;
                return;
            }

            // ── TILES VIEW ────────────────────────────────────────────
            sidebar.querySelectorAll('.nav-link-tile').forEach(function (tile) {
                var text = tile.textContent.toLowerCase();
                var onclickAttr = tile.getAttribute('onclick') || '';
                var hasMatch = text.includes(filter);

                if (!hasMatch) {
                    var m = onclickAttr.match(/'([^']+)'\s*\)$/);
                    if (m && m[1]) {
                        var tpl = document.getElementById(m[1] + '-template');
                        if (tpl) {
                            var subs = tpl.querySelectorAll('a.nav-link');
                            for (var i = 0; i < subs.length; i++) {
                                if (subs[i].textContent.toLowerCase().includes(filter)) {
                                    hasMatch = true;
                                    break;
                                }
                            }
                        }
                    }
                }
                tile.style.display = hasMatch ? 'flex' : 'none';
            });
            
            sidebar.scrollTop = 0;
        }
        /* ══ LOAD EMPLOYEE IMAGE ═════════════════════════════ */
        function loadProfileImage() {
            $.ajax({
                url: '/GeneralDashboard/LoadEmployeeDocument',
                type: 'GET',
                success: function (res) {
                    if (res.status && res.data && res.data.length > 0) {
                        var row = res.data[0];
                        if (row.ImageStatus === "Image Found" && row.binaryImg) {
                            var mimeType = row.ContentType || 'image/jpeg';
                            var src = "data:" + mimeType + ";base64," + row.binaryImg;
                            $(".user-avatar").html('<img src="' + src + '" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">');
                        } else {
                            var gender = row.Gender ? row.Gender.toUpperCase() : "MALE";
                            var iconClass = gender === "FEMALE" ? "bi-person-standing-dress" : "bi-person-standing";
                            var iconHtml = '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--primary);color:#fff;border-radius:50%;"><i class="bi ' + iconClass + '" style="font-size:1.5em;"></i></div>';
                            $(".user-avatar").html(iconHtml);
                        }
                    }
                },
                error: function (err) { console.error("Error loading profile image", err); }
            });
        }
        $(document).ready(loadProfileImage);

        /* ══ SIDEBAR VIEW SWITCHER ═══════════════════════════ */
        function switchSidebarView(view, btn) {
            html.dataset.sidebarView = view;
            document.querySelectorAll('.sb-tab').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');
            else {
                const targetId = view === 'tiles' ? 'tab-grid' : 'tab-list';
                const targetBtn = document.getElementById(targetId);
                if (targetBtn) targetBtn.classList.add('active');
            }
            closeSidebarDetail();
            // Sync with settings panel if it exists
            const settingsBtn = document.querySelector('[data-mview="' + view + '"]');
            if (settingsBtn) {
                document.querySelectorAll('[data-mview]').forEach(b => b.classList.remove('active'));
                settingsBtn.classList.add('active');
            }
            saveSettings();
        }

        function openSidebarDetail(title, templateId) {
            const detailView = document.getElementById('sidebar-detail');
            const titleEl = document.getElementById('detail-view-title');
            const bodyEl = document.getElementById('detail-view-body');
            const template = document.getElementById(templateId + '-template');

            if (detailView && titleEl && bodyEl && template) {
                titleEl.textContent = title;
                bodyEl.innerHTML = template.innerHTML;
                detailView.classList.add('active');
                // Scroll to top of detail view
                bodyEl.scrollTop = 0;

                // Re-apply Microlevel menu restriction on the cloned detail panel
                if (typeof applyMicrolevelMenuRestriction === 'function' && typeof window._preDateRowCount !== 'undefined') {
                    applyMicrolevelMenuRestriction(window._preDateRowCount);
                }
            }
        }

        function closeSidebarDetail() {
            const detailView = document.getElementById('sidebar-detail');
            if (detailView) {
                detailView.classList.remove('active');
            }
        }

