        /* Chevron Rotation */
        .nav-link .bi-chevron-down {
            transition: transform 0.25s ease;
        }

        .nav-link[aria-expanded="true"] .bi-chevron-down {
            transform: rotate(180deg);
        }

        /* Standard List View Spacing */
        [data-sidebar-view="list"] .nav-link {
            padding: 0.75rem 1.25rem;
            font-weight: 500;
        }

        [data-sidebar-view="list"] .nav-sub .nav-link {
            padding: 0.5rem 1.25rem 0.5rem 3.2rem;
            font-size: 0.85rem;
            border-left: none;
        }

        /* ════════════════════════════════════════════════════
                   FIX #2: COLLAPSE/EXPAND IN LIST VIEW
                   Bootstrap CSS is NOT loaded (only Bootstrap JS +
                   Bootstrap Icons). Without Bootstrap CSS the rule
                   `.collapse { display:none }` does not exist, so
                   every dept submenu renders expanded on page-load.
                   We add that rule manually here so Bootstrap JS can
                   properly toggle the accordion open/closed.
                ════════════════════════════════════════════════════ */

        /* ── Bootstrap collapse base (missing because Bootstrap CSS is not loaded) ── */
        .collapse:not(.show):not(.collapsing) {
            display: none !important;
        }
        .collapsing {
            height: 0;
            overflow: hidden;
            transition: height 0.2s ease;
        }

        /* ── Once Bootstrap adds .show, let the list-view flex layout take over ── */
        [data-sidebar-view="list"] .nav-sub.show,
        [data-sidebar-view="list"] .nav-sub.collapsing {
            display: flex !important;
            flex-direction: column !important;
            width: 100%;
        }

        /* ── Force all items INSIDE an expanded nav-sub to be visible ──
           These items (a.nav-link, div.nav-section-sub) have no list-only-item
           class so they need their own rule to appear when the parent is open. ── */
        [data-sidebar-view="list"] .nav-sub.show > a.nav-link,
        [data-sidebar-view="list"] .nav-sub.show > div.nav-section-sub,
        [data-sidebar-view="list"] .nav-sub.collapsing > a.nav-link,
        [data-sidebar-view="list"] .nav-sub.collapsing > div.nav-section-sub {
            display: flex !important;
            visibility: visible !important;
            opacity: 1 !important;
        }
        [data-sidebar-view="list"] .nav-sub.show > div.nav-section-sub,
        [data-sidebar-view="list"] .nav-sub.collapsing > div.nav-section-sub {
            display: block !important;
        }
        /* ── DevExtreme Theme Integration ───────────────────── */
