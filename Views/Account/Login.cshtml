@model VGN_CRM_CORE.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — VGN360</title>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link href="~/css/tailwind.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #4680FF;
            --primary-rgb: 70,128,255;
        }
    </style>
</head>
<body class="min-h-screen bg-gradient-to-br from-[#e8eeff] via-[#f8f0ff] to-[#e8f4ff] flex items-center justify-center font-[system-ui,sans-serif]">
    <div class="grid grid-cols-1 lg:grid-cols-[8fr_4fr] w-[1100px] max-w-[95vw] max-h-[96vh] min-h-[480px] rounded-[24px] overflow-hidden shadow-[0_32px_80px_rgba(70,128,255,.18),_0_4px_16px_rgba(0,0,0,.08)]">
        
        <!-- LEFT: Video -->
        <div class="relative overflow-hidden hidden lg:block">
            <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover">
                <source src="~/videos/VGN Aspire.mp4" type="video/mp4" />
            </video>
            <div class="absolute inset-0 bg-black/30 flex flex-col items-center justify-center">
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="bg-white flex flex-col justify-center py-12 px-8 md:px-14">
            <div class="flex items-center justify-center gap-3 mb-1">
                <img src="~/images/VGN360.png" alt="VGN360" class="h-14 object-contain" />
                <div class="text-[1.75rem] font-bold text-[#1a1a2e]">Welcome Back &#128075;</div>
            </div>
            <div class="text-[#6c757d] text-[0.9rem] mt-1 mb-8 text-center">Sign in to your VGN360 account</div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="bg-[#fff5f5] border border-[#fecaca] rounded-[10px] py-3 px-4 text-[0.88rem] text-[#dc3545] mb-4 flex items-center gap-2 transition-opacity duration-500" id="alertBox">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @foreach (var err in ViewData.ModelState[""].Errors)
                    {<span>@err.ErrorMessage</span>}
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                <!-- User ID -->
                <div class="mb-5">
                    <label class="block text-[0.85rem] font-semibold text-[#374151] mb-1"><i class="bi bi-person mr-1"></i>User ID</label>
                    <div class="flex items-center border-[1.5px] border-[#e2e8f0] rounded-xl bg-white focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/20 transition-all duration-200">
                        <span class="pl-4 pr-3 text-[#6c757d]"><i class="bi bi-person"></i></span>
                        <input asp-for="UserId" id="UserId" class="w-full bg-transparent border-none py-2.5 pr-4 text-[0.95rem] focus:outline-none focus:ring-0"
                               placeholder="Enter your User ID" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserId" class="text-[#dc3545] text-[0.82rem] mt-1 block"></span>
                </div>

                <!-- Password -->
                <div class="mb-5">
                    <label class="block text-[0.85rem] font-semibold text-[#374151] mb-1"><i class="bi bi-lock mr-1"></i>Password</label>
                    <div class="relative flex items-center border-[1.5px] border-[#e2e8f0] rounded-xl bg-white focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/20 transition-all duration-200">
                        <span class="pl-4 pr-3 text-[#6c757d]"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" id="PasswordInput" class="w-full bg-transparent border-none py-2.5 pr-10 text-[0.95rem] focus:outline-none focus:ring-0"
                               placeholder="Enter your password"
                               autocomplete="current-password" />
                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9ca3af] hover:text-gray-600 cursor-pointer p-0 text-base z-10 bg-transparent border-none" onclick="togglePwd()">
                            <i class="bi bi-eye-slash" id="pwdIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-[#dc3545] text-[0.82rem] mt-1 block"></span>
                </div>

                <!-- Login Type -->
                <div class="mb-8">
                    <label class="block text-[0.85rem] font-semibold text-[#374151] mb-1"><i class="bi bi-people mr-1"></i>Login Type</label>
                    <div class="relative flex items-center border-[1.5px] border-[#e2e8f0] rounded-xl bg-white focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/20 transition-all duration-200">
                        <span class="pl-4 pr-3 text-[#6c757d]"><i class="bi bi-people"></i></span>
                        <select name="LoginType" id="LoginType" class="w-full bg-transparent border-none py-2.5 pr-10 text-[0.95rem] focus:outline-none focus:ring-0 appearance-none">
                            <option value="CORPORATE">CORPORATE</option>
                            <option value="CHANNELPARTNER">CHANNEL PARTNER</option>
                        </select>
                        <i class="bi bi-chevron-down absolute right-4 pointer-events-none text-[#6c757d] text-sm z-10"></i>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-to-br from-primary to-[#6c47ff] hover:opacity-90 text-white border-none rounded-xl py-3 font-semibold text-[1rem] cursor-pointer transition-opacity duration-200">
                    <i class="bi bi-box-arrow-in-right mr-2"></i>Sign In
                </button>
            </form>

            <div class="text-center mt-6 text-[#9ca3af] text-[0.8rem]">&copy; @DateTime.Now.Year VGN360 &mdash; All rights reserved</div>
        </div>
    </div>

    <script>
        function togglePwd() {
            var pwd = document.getElementById('PasswordInput');
            var icon = document.getElementById('pwdIcon');
            pwd.type = pwd.type === 'password' ? 'text' : 'password';
            icon.className = pwd.type === 'text' ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
        var alertBox = document.getElementById('alertBox');
        if (alertBox) {
            setTimeout(function () {
                alertBox.style.opacity = '0';
                setTimeout(function () { alertBox.style.display = 'none'; }, 500);
            }, 4000);
        }
        var inputs = document.querySelectorAll('input[name="UserId"], input[name="Password"]');
        inputs.forEach(function (inp) {
            inp.addEventListener('input', function () {
                if (alertBox) {
                    alertBox.style.opacity = '0';
                    setTimeout(function () { alertBox.style.display = 'none'; }, 300);
                }
            });
        });
    </script>

    @if (ViewBag.KickedOut == true)
    {
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.all.min.js"></script>
        <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.min.css" rel="stylesheet">
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                Swal.fire({
                    icon: 'warning',
                    title: 'Session Ended',
                    text: 'Same userid logged in using another system.',
                    confirmButtonColor: '#4680FF',
                    customClass: {
                        popup: 'rounded-2xl shadow-2xl border-0',
                        confirmButton: 'inline-flex items-center justify-center rounded-xl px-6 py-2 font-bold text-white cursor-pointer'
                    }
                });
            });
        </script>
    }
</body>
</html>
