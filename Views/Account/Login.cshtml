@model VGN_CRM_CORE.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — VGN360</title>
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root { --primary: #4680FF; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #e8eeff 0%, #f8f0ff 50%, #e8f4ff 100%);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .login-wrapper {
            display: grid; grid-template-columns: 1fr 1fr;
            width: 900px; max-height: 96vh; min-height: 480px;
            border-radius: 24px; overflow: hidden;
            box-shadow: 0 32px 80px rgba(70,128,255,.18), 0 4px 16px rgba(0,0,0,.08);
        }
        .login-brand { position: relative; overflow: hidden; }
        .login-brand video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
        .login-brand-overlay {
            position: absolute; inset: 0; background: rgba(0,0,0,.30);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
        }
        .login-brand-overlay img { max-width: 200px; object-fit: contain; filter: drop-shadow(0 4px 16px rgba(0,0,0,.4)); }
        .login-form-panel {
            background: #fff; display: flex; flex-direction: column;
            justify-content: center; padding: 3rem 3.5rem;
        }
        .login-title { font-size: 1.75rem; font-weight: 700; color: #1a1a2e; }
        .login-sub { color: #6c757d; font-size: .9rem; margin-top: .3rem; }
        .form-control {
            border-radius: 12px; border: 1.5px solid #e2e8f0;
            padding: .65rem 1rem; font-size: .95rem;
            transition: border-color .2s, box-shadow .2s; width: 100%;
        }
        .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(70,128,255,.12); outline: none; }
        .form-label { font-size: .85rem; font-weight: 600; color: #374151; margin-bottom: .3rem; }
        .input-group-text {
            border-radius: 12px 0 0 12px; border: 1.5px solid #e2e8f0;
            border-right: none; background: #f8f9fa; color: #6c757d;
        }
        .input-group .form-control { border-radius: 0 12px 12px 0; }
        .input-group:focus-within .input-group-text { border-color: var(--primary); }
        .input-group:focus-within .form-control { border-color: var(--primary); box-shadow: none; }
        .btn-login {
            background: linear-gradient(135deg, var(--primary), #6c47ff);
            color: #fff; border: none; border-radius: 12px;
            padding: .8rem; font-weight: 600; font-size: 1rem;
            width: 100%; cursor: pointer; transition: opacity .2s;
        }
        .btn-login:hover { opacity: .9; }
        .text-danger-msg { color: #dc3545; font-size: .82rem; margin-top: .25rem; display: block; }
        .alert-err {
            background: #fff5f5; border: 1px solid #fecaca; border-radius: 10px;
            padding: .75rem 1rem; font-size: .88rem; color: #dc3545;
            margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem;
        }
        .pwd-wrapper { position: relative; }
        .pwd-toggle {
            position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
            background: none; border: none; color: #9ca3af; cursor: pointer; padding: 0; font-size: 1rem;
        }
        .footer-txt { text-align: center; margin-top: 1.5rem; color: #9ca3af; font-size: .8rem; }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- LEFT: Video -->
        <div class="login-brand">
            <video autoplay muted loop playsinline>
                <source src="~/videos/VGN Aspire.mp4" type="video/mp4" />
            </video>
            <div class="login-brand-overlay"></div>
        </div>

        <!-- RIGHT: Form -->
        <div class="login-form-panel">
            <div class="d-flex align-items-center gap-3 mb-1">
                <img src="~/images/VGN360.png" alt="VGN360" style="height:56px;object-fit:contain;" />
                <div class="login-title">Welcome Back &#128075;</div>
            </div>
            <div class="login-sub mb-4">Sign in to your VGN360 account</div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
            {
                <div class="alert-err" id="alertBox">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @foreach (var err in ViewData.ModelState[""].Errors)
                    {<span>@err.ErrorMessage</span>}
                </div>
            }

            <form asp-action="Login" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ReturnUrl" value="@ViewBag.ReturnUrl" />

                <!-- User ID -->
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-person me-1"></i>User ID</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input asp-for="UserId" id="UserId" class="form-control"
                               placeholder="Enter your User ID" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserId" class="text-danger-msg"></span>
                </div>

                <!-- Password -->
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                    <div class="pwd-wrapper">
                        <input asp-for="Password" id="PasswordInput" class="form-control"
                               placeholder="Enter your password"
                               autocomplete="current-password" style="padding-right:2.5rem" />
                        <button type="button" class="pwd-toggle" onclick="togglePwd()">
                            <i class="bi bi-eye-slash" id="pwdIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger-msg"></span>
                </div>

                <!-- Login Type -->
                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-people me-1"></i>Login Type</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-people"></i></span>
                        <select name="LoginType" id="LoginType" class="form-control">
                            <option value="CORPORATE">CORPORATE</option>
                            <option value="CHANNELPARTNER">CHANNEL PARTNER</option>
                        </select>
                    </div>
                </div>

                <!-- Remember me -->
                <div class="d-flex align-items-center mb-4">
                    <input asp-for="RememberMe" id="RememberMe" class="form-check-input me-2" />
                    <label for="RememberMe" class="form-check-label small text-muted">Remember me</label>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>

            <div class="footer-txt">&copy; @DateTime.Now.Year VGN360 &mdash; All rights reserved</div>
        </div>
    </div>

    <script>
        function togglePwd() {
            var pwd = document.getElementById('PasswordInput');
            var icon = document.getElementById('pwdIcon');
            pwd.type = pwd.type === 'password' ? 'text' : 'password';
            icon.className = pwd.type === 'text' ? 'bi bi-eye' : 'bi bi-eye-slash';
        }
        var alertBox = document.getElementById('alertBox');
        if (alertBox) {
            setTimeout(function () {
                alertBox.style.transition = 'opacity 0.5s';
                alertBox.style.opacity = '0';
                setTimeout(function () { alertBox.style.display = 'none'; }, 500);
            }, 4000);
        }
        var inputs = document.querySelectorAll('input[name="UserId"], input[name="Password"]');
        inputs.forEach(function (inp) {
            inp.addEventListener('input', function () {
                if (alertBox) {
                    alertBox.style.transition = 'opacity 0.3s';
                    alertBox.style.opacity = '0';
                    setTimeout(function () { alertBox.style.display = 'none'; }, 300);
                }
            });
        });
    </script>
</body>
</html>
