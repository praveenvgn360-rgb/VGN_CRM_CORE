                { Id: 102, Name: "Meera Krishnan", Contact: "9710987654", Project: "VGN Fairlight", Stage: "Negotiation", Status: "Warm", Amount: 32000000, Date: "2026-07-10" },
                { Id: 103, Name: "Stephen Joseph", Contact: "9884112233", Project: "VGN Stafford", Stage: "Booked", Status: "Deal", Amount: 18000000, Date: "2026-07-05" },
                { Id: 104, Name: "Karan Johar", Contact: "9840556677", Project: "VGN Fairlight", Stage: "Enquiry", Status: "Cold", Amount: 40000000, Date: "2026-07-14" },
                { Id: 105, Name: "Divya Nair", Contact: "9790112233", Project: "VGN Stafford", Stage: "Visit Scheduled", Status: "Warm", Amount: 22000000, Date: "2026-07-13" },
                { Id: 106, Name: "Arun Kumar", Contact: "9840223344", Project: "VGN Monte Carlo", Stage: "Negotiation", Status: "Hot", Amount: 50000000, Date: "2026-07-11" },
                { Id: 107, Name: "Sneha Patel", Contact: "9876543210", Project: "VGN Coasta", Stage: "Enquiry", Status: "Cold", Amount: 65000000, Date: "2026-07-09" },
                { Id: 108, Name: "Vikram Singh", Contact: "9888776655", Project: "VGN Stafford", Stage: "Booked", Status: "Deal", Amount: 30000000, Date: "2026-07-08" },
                { Id: 109, Name: "Priya Sharma", Contact: "9840112233", Project: "VGN Fairlight", Stage: "Site Visit", Status: "Warm", Amount: 28000000, Date: "2026-07-07" },
                { Id: 110, Name: "Mohan Raj", Contact: "9790223344", Project: "VGN Monte Carlo", Stage: "Negotiation", Status: "Hot", Amount: 45000000, Date: "2026-07-06" }
            ];

            if (typeof $.fn.dxDataGrid !== 'undefined') {
                // Grid 1: Advanced with Export
                $('#dx-grid-advanced').dxDataGrid({
                    dataSource: gridData,
                    showBorders: true,
