                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            ['clean']
                        ]
                    }
                });
            }

            // ===== APEX CHARTS =====
            var primaryColor = getComputedStyle(document.documentElement).getPropertyValue('--primary').trim() || '#4680FF';

            // Area Chart
            new ApexCharts(document.querySelector("#apex-area"), {
                chart: { type: 'area', height: 200, toolbar: { show: false } },
                dataLabels: { enabled: false },
                stroke: { curve: 'smooth', width: 2 },
