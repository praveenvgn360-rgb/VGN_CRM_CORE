                                        .append($('<tr>')
                                            .append($('<td>').addClass('p-2').text(d.Date))
                                            .append($('<td>').addClass('p-2').text('Email'))
                                            .append($('<td>').addClass('p-2').text('Sent brochure and pricing.'))
                                        )
                                    )
                                ).appendTo(container);
                        }
                    },
                    export: { enabled: true, fileName: 'VGN_MasterDetail_Export' },
                    columns: [
                        { dataField: 'Name', caption: 'Client Name' },
                        { dataField: 'Project', caption: 'Project' },
                        { dataField: 'Stage', caption: 'Stage' },
                        { dataField: 'Status', caption: 'Status' },
                        { dataField: 'Amount', caption: 'Amount', format: 'currency', alignment: 'right' }
                    ]
                });
            }

            // ===== SCROLLSPY =====
            $(window).scroll(function() {
                var scrollPos = $(window).scrollTop() + 100;
                $('section').each(function(i) {
                    var top = $(this).offset().top;
                    var bottom = top + $(this).outerHeight();
                    if (scrollPos >= top && scrollPos < bottom) {
                        $('.showcase-sidebar a.active').removeClass('active');
                        $('.showcase-sidebar a').eq(i).addClass('active');
                    }
                });
            });

            // ===== SMOOTH SCROLL =====
            $('.showcase-sidebar a').click(function(e) {
                e.preventDefault();
                var dest = $(this).attr('href');
                $('html, body').animate({ scrollTop: $(dest).offset().top - 120 }, 400);
            });

        });

        // ===== SWEETALERT FUNCTIONS =====
        function swalSuccess() {
            Swal.fire({ title: 'Success!', text: 'Operation completed successfully.', icon: 'success', confirmButtonColor: '#10b981' });
        }
        function swalConfirm() {
            Swal.fire({ title: 'Are you sure?', text: 'This action cannot be undone.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#6b7280', confirmButtonText: 'Yes, delete!' }).then(function(r) { if (r.isConfirmed) Swal.fire('Deleted!', 'Record removed.', 'success'); });
        }
        function swalPrompt() {
            Swal.fire({ title: 'Enter Reason', input: 'text', inputPlaceholder: 'Type here...', showCancelButton: true, confirmButtonColor: '#4680FF', cancelButtonColor: '#6b7280', confirmButtonText: 'Submit' }).then(function(r) { if (r.value) Swal.fire('Submitted!', 'Reason: ' + r.value, 'success'); });
        }
        function swalWarning() {
            Swal.fire({ title: 'Warning!', text: 'Please review before proceeding.', icon: 'warning', confirmButtonColor: '#f59e0b' });
        }
        function swalInfo() {
            Swal.fire({ title: 'Information', text: 'New updates are available.', icon: 'info', confirmButtonColor: '#4680FF' });
        }

        // ===== CODE TOGGLE =====
        window.toggleCode = function(id) { $('#' + id).toggleClass('show'); };

        // ===== COPY SNIPPET =====
        window.copySnippet = function(id, btn) {
            var text = document.getElementById(id).textContent;
            navigator.clipboard.writeText(text).then(function() {
                var orig = $(btn).html();
                $(btn).html('<i class="fas fa-check"></i> Copied!');
                setTimeout(function() { $(btn).html(orig); }, 2000);
            });
        };

        // ===== LOADER FUNCTIONS =====
        function showLoader() {
            var loader = document.getElementById('full-page-loader');
            loader.classList.remove('hidden');
            loader.querySelector('.loader-spinner').style.display = 'block';
            loader.querySelector('.loader-progress-bar').style.display = 'none';
            loader.querySelector('.loader-text').textContent = 'Loading...';
            setTimeout(function() { loader.classList.add('hidden'); }, 5000);
        }
        function showLoaderWithProgress() {
            var loader = document.getElementById('full-page-loader');
            loader.classList.remove('hidden');
            loader.querySelector('.loader-spinner').style.display = 'block';
            loader.querySelector('.loader-progress-bar').style.display = 'block';
            var fill = loader.querySelector('.progress-fill');
            var width = 0;
            var interval = setInterval(function() {
                width += Math.random() * 10;
                if (width > 100) { width = 100; clearInterval(interval); }
                fill.style.width = width + '%';
                loader.querySelector('.loader-text').textContent = 'Processing... ' + Math.round(width) + '%';
            }, 200);
            setTimeout(function() {
                clearInterval(interval);
                fill.style.width = '100%';
                loader.querySelector('.loader-text').textContent = 'Complete!';
                setTimeout(function() { loader.classList.add('hidden'); fill.style.width = '0%'; }, 800);
            }, 4000);
        }
        function hideLoader() { document.getElementById('full-page-loader').classList.add('hidden'); }
    </script>
}