            // ===== QR CODE =====
            var qr = new QRious({
                element: document.getElementById('qr-canvas'),
                value: $('#qr-input').val(),
                size: 128,
                background: '#ffffff',
                foreground: '#000000',
                level: 'H'
            });
            window.updateQR = function() {
                qr.value = $('#qr-input').val();
            };

            // ===== QUILL EDITOR =====
            if (typeof Quill !== 'undefined') {
                new Quill('#quill-editor', {
                    theme: 'snow',
                    modules: {
                        toolbar: [
