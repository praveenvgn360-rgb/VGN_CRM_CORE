                series: [{ name: 'Leads', data: [45, 60, 52, 78, 65, 95, 110] }],
                xaxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'], labels: { style: { fontSize: '9px' } } },
                yaxis: { labels: { style: { fontSize: '9px' } } },
                grid: { borderColor: '#e5e7eb' },
                tooltip: { theme: 'light' }
