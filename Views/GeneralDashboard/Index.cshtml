@section Scripts {
    <script>
(function () {
    // ─────────────────────────────────────────────────────────────
    // GLOBAL HELPER: safely parse a response that MAY already be
    // a JS object (jQuery auto-parse) OR still a raw JSON string.
    // Use this everywhere instead of JSON.parse(data).
    // ─────────────────────────────────────────────────────────────
    function safeJson(data) {
        if (typeof data === 'string') {
            try { return JSON.parse(data); } catch (e) { return null; }
        }
        return data; // already an object – return as-is
    }

    // ── Indian number format (e.g. 1,81,346) ────────────────────
    function toIndianFormat(n) {
        if (n === null || n === undefined || isNaN(n)) return '0';
        n = Math.round(n);
        var s = n.toString();
        if (s.length <= 3) return s;
        var last3 = s.slice(-3);
        var rest   = s.slice(0, -3);
        var result = rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',');
        return result + ',' + last3;
    }

    // ── Attendance Calendar ──────────────────────────────────────
    const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    let currentDate = new Date();
    let calData     = [];

    function monthLabel(d) { return MONTHS[d.getMonth()] + '-' + d.getFullYear(); }

    function timeToMinutes(t) {
        if (!t) return -1;
        const m = t.match(/(\d+):(\d+)\s*(AM|PM)/i);
        if (!m) return -1;
        let h = parseInt(m[1]), mn = parseInt(m[2]);
        if (m[3].toUpperCase() === 'PM' && h !== 12) h += 12;
        if (m[3].toUpperCase() === 'AM' && h === 12) h = 0;
        return h * 60 + mn;
    }

    function classifyInTime(t) {
        const mins = timeToMinutes(t);
        if (mins < 0)    return 'no-data';
        if (mins <= 570) return 'on-time';
        if (mins <= 585) return 'slight-late';
        return 'late';
    }

    function renderCalendar() {
        const grid  = document.getElementById('att_grid_body');
        const label = document.getElementById('cal_month_label');
        if (!grid || !label) return;
        grid.innerHTML = '';
        label.textContent = monthLabel(currentDate);

        const year  = currentDate.getFullYear();
        const month = currentDate.getMonth();
        const first = new Date(year, month, 1).getDay();
        const total = new Date(year, month + 1, 0).getDate();
        const today = new Date();
        const isCurrentMonth = today.getFullYear() === year && today.getMonth() === month;

        for (let i = 0; i < first; i++) {
            const blank = document.createElement('div');
            blank.className = 'att-day-cell empty';
            grid.appendChild(blank);
        }

        let cntOn = 0, cntSlight = 0, cntLate = 0, cntAbsent = 0;
        let todayIn = '', todayOut = '';

        for (let d = 1; d <= total; d++) {
            const dayData = calData.find(x => x.day === d) || {};
            const cls     = classifyInTime(dayData.inTime);
            const dayOfW  = new Date(year, month, d).getDay();
            const isToday = isCurrentMonth && d === today.getDate();

            if (cls === 'on-time')          cntOn++;
            else if (cls === 'slight-late') cntSlight++;
            else if (cls === 'late')        cntLate++;
            else if (d <= (isCurrentMonth ? today.getDate() : total) && dayOfW !== 0 && dayOfW !== 6)
                cntAbsent++;

            if (isToday) { todayIn = dayData.inTime || ''; todayOut = dayData.outTime || ''; }

            let dur = dayData.duration || dayData.Duration;
            let sts = dayData.status   || dayData.Status;
            let durStr = (dur !== undefined && dur !== null && String(dur).trim() !== '' && String(dur).trim() !== '0' && String(dur).trim() !== '0.00') ? String(dur).trim() : '';
            let stsStr = (sts !== undefined && sts !== null && String(sts).trim() !== '') ? String(sts).trim() : '';

            let extraHtml = '';
            if (durStr !== '' || stsStr !== '') {
                extraHtml = `<div style="display:flex;justify-content:space-between;align-items:center;margin-top:2px;font-size:.62rem;">
                    <span style="color:var(--primary);font-weight:700;">${stsStr ? 'Sts: ' + stsStr : ''}</span>
                    <span style="color:#334155;font-weight:700;">${durStr ? 'Hr: ' + durStr : ''}</span>
                </div>`;
            }

            const cell = document.createElement('div');
            cell.className = 'att-day-cell ' + cls + (isToday ? ' today' : '');
            cell.title     = `${d} ${monthLabel(currentDate)}\nIn: ${dayData.inTime||'--'}  Out: ${dayData.outTime||'--'}`;
            cell.innerHTML = `
                <div><span class="att-day-num">${d}</span><span class="att-day-name">${DAYS[dayOfW].substring(0,1)}</span></div>
                <div class="att-punch">
                    ${dayData.inTime  ? `<span class="att-in">▲ ${dayData.inTime}</span>`  : ''}
                    ${dayData.outTime ? `<span class="att-out">▼ ${dayData.outTime}</span>` : ''}
                    ${extraHtml}
                </div>`;
            grid.appendChild(cell);
        }

        document.getElementById('cnt_ontime').textContent     = cntOn;
        document.getElementById('cnt_slightlate').textContent = cntSlight;
        document.getElementById('cnt_late').textContent       = cntLate;
        document.getElementById('cnt_absent').textContent     = cntAbsent;

        if (isCurrentMonth) {
            document.getElementById('kpi_intime').textContent  = todayIn  || '--:-- --';
            document.getElementById('kpi_outtime').textContent = todayOut || '--:-- --';
        }
    }

    function loadCalendar() {
        fetch('/GeneralDashboard/LoadAttendanceCalendar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Month: monthLabel(currentDate) })
        })
        .then(r => r.json())
        .then(res => { calData = (res.status && res.data) ? res.data : []; renderCalendar(); })
        .catch(() => { calData = []; renderCalendar(); });
    }

    const calPrev = document.getElementById('cal_prev');
    if (calPrev) {
        calPrev.addEventListener('click', function () {
            currentDate = new Date(currentDate.getFullYear(), currentDate.getMonth() - 1, 1);
            loadCalendar();
        });
    }

    const calNext = document.getElementById('cal_next');
    if (calNext) {
        calNext.addEventListener('click', function () {
            const now  = new Date();
            const next = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 1);
            if (next <= now) { currentDate = next; loadCalendar(); }
        });
    }

    const calExport = document.getElementById('cal_export');
    if (calExport) {
        calExport.addEventListener('click', function () {
            let csv = 'Day,Date,InTime,OutTime\n';
            const year = currentDate.getFullYear(), month = currentDate.getMonth();
            const total = new Date(year, month + 1, 0).getDate();
            for (let d = 1; d <= total; d++) {
                const row = calData.find(x => x.day === d) || {};
                const dt  = new Date(year, month, d);
                csv += `${DAYS[dt.getDay()]},${String(d).padStart(2,'0')}-${MONTHS[month]}-${year},"${row.inTime||''}","${row.outTime||''}"\n`;
            }
            const a = document.createElement('a');
            a.href = 'data:text/csv,' + encodeURIComponent(csv);
            a.download = 'Attendance_' + monthLabel(currentDate) + '.csv';
            a.click();
        });
    }

    function applyDeptSections() {
        const role = '@userRole'.toUpperCase();
        const userDept = '@departmentId'.toUpperCase();
        document.querySelectorAll('.dept-section').forEach(function (sec) {
            const depts = (sec.dataset.dept || 'ALL').toUpperCase().split(' ');
            const visible = depts.includes('ALL') || depts.some(d => role.includes(d) || userDept.includes(d));
            if (visible) sec.classList.remove('d-section-hidden');
            else         sec.classList.add('d-section-hidden');
        });
    }

    // ── Document Ready ───────────────────────────────────────────
    $(function () {
        var isPresentation = '@isPresentationUser' === 'True';
        if (isPresentation) return;

        var userRole = '@Html.Raw(userRole)'.toUpperCase();

        if (userRole.includes('CHANNEL') || userRole.includes('CHANNELPARTNER')) {
            // ── Channel Partner init ──
            Project_Layout();
            LoadClientId();
            ParentSource_load();
            LoadLeads();
            CpLeadFunction([]);
        } else {
            if (document.getElementById('att_grid_body'))  loadCalendar();
            applyDeptSections();
            if (document.getElementById('gridContainer1')) loadDaybookGrid();
            if (document.getElementById('gridContainer2')) loadAssignmentExtensionGrid();
        }
    });

    // ── Daybook Grid ─────────────────────────────────────────────
    function updateFooterText1(gridInstance, totalCount) {
        var currentPage  = gridInstance.pageIndex() + 1;
        var pageSize     = gridInstance.pageSize();
        var startRow     = (currentPage - 1) * pageSize + 1;
        var endRow       = Math.min(startRow + pageSize - 1, totalCount);
        var $footer      = $("#gridContainer1").find(".dx-datagrid-total-footer");
        if ($footer.length === 0) $footer = $("<div>").addClass("dx-datagrid-total-footer").appendTo($("#gridContainer1"));
        $footer.text("Showing " + toIndianFormat(startRow) + " - " + toIndianFormat(endRow) + " of " + toIndianFormat(totalCount) + " rows");
    }

    function GeneralJobUpdation(TitleId, AssignmentType, GeneralJobId, TitleName) {
        window.open("/AssignmentUpdationEntry?HeadTitleId=" + encodeURIComponent(TitleId) +
            "&Processflag=GENERAL&AssignmentType=" + encodeURIComponent(AssignmentType) +
            "&GeneralJobId=" + encodeURIComponent(GeneralJobId) +
            "&Title=" + encodeURIComponent(TitleName), "_blank", "noreferrer");
    }

    function Extension_update(TitleId, StageId, substageId, JobId, EmpId, SubTitleId, EmpJobId, JobExtensionApproveId, JobType) {
        window.open("/ProjectProcessflow?HeadTitleId=" + encodeURIComponent(TitleId) +
            "&SubTitleID=" + encodeURIComponent(SubTitleId) +
            "&JobId=" + encodeURIComponent(JobId) +
            "&EmpJobId=" + encodeURIComponent(EmpJobId) +
            "&From=Crm_Dashboard", "_blank", "noreferrer");
    }

    function loadDaybookGrid() {
        $.ajax({
            type: 'GET',
            url: '/GeneralDashboard/LoadDaybookData',
            success: function (res) {
                // safeJson not needed here – controller uses return Json()
                var orders = (res && res.status && res.data) ? res.data : [];
                $('#gridContainer1').dxDataGrid({
                    dataSource: orders, keyExpr: 'TitleId', width: '100%',
                    columnAutoWidth: false, columnMinWidth: 80,
                    allowColumnReordering: true, allowColumnResizing: true,
                    filterRow: { visible: false }, filterPanel: { visible: true },
                    headerFilter: { visible: true }, showBorders: true,
                    noDataText: "No data available", hoverStateEnabled: true,
                    scrolling: { mode: "standard", useNative: true },
                    paging: { enabled: false },
                    columnChooser: { enabled: true, mode: 'select' },
                    searchPanel: { visible: true, width: 240, placeholder: 'Search...' },
                    export: { enabled: true },
                    onExporting: function(e) {
                        if (typeof ExcelJS !== 'undefined') {
                            const wb = new ExcelJS.Workbook();
                            const ws = wb.addWorksheet('DayBook');
                            DevExpress.excelExporter.exportDataGrid({ component: e.component, worksheet: ws, autoFilterEnabled: true })
                                .then(() => wb.xlsx.writeBuffer().then(buf => saveAs(new Blob([buf], { type: 'application/octet-stream' }), 'DayBook.xlsx')));
                            e.cancel = true;
                        }
                    },
                    columns: [
                        { dataField: 'Sno',            caption: 'SL.NO',          width: 90,  alignment: 'center' },
                        { dataField: 'Title',           caption: 'TITLE',           width: 200, alignment: 'left' },
                        { dataField: 'Assignmenttype',  caption: 'ASSIGNMENT TYPE', width: 200 },
                        {
                            dataField: 'NoofJobs', caption: 'NO OF JOBS', width: 140, alignment: 'center', cssClass: 'Color1',
                            cellTemplate: function (c, o) { $("<div>").text(o.value).on('dxclick', function () { GeneralJobUpdation(o.data.TitleId, o.data.Assignmenttype, o.data.GeneralJobId, o.data.TitleName); }).appendTo(c); }
                        },
                        {
                            dataField: 'Followup', caption: 'FOLLOWUP JOBS', width: 140, alignment: 'center', cssClass: 'Color2',
                            cellTemplate: function (c, o) { $("<div>").text(o.value).on('dxclick', function () { GeneralJobUpdation(o.data.TitleId, o.data.Assignmenttype, o.data.GeneralJobId, o.data.TitleName); }).appendTo(c); }
                        },
                        {
                            dataField: 'Completed', caption: 'COMPLETED JOBS', width: 140, alignment: 'center', cssClass: 'Color3',
                            cellTemplate: function (c, o) { $("<div>").text(o.value).on('dxclick', function () { GeneralJobUpdation(o.data.TitleId, o.data.Assignmenttype, o.data.GeneralJobId, o.data.TitleName); }).appendTo(c); }
                        },
                        {
                            dataField: 'To_Start', caption: 'TO START JOBS', width: 140, alignment: 'center',
                            cellTemplate: function (c, o) {
                                $('<button />', { html: '<i class="fas fa-edit" style="color:white !important;"></i>', click: function () { GeneralJobUpdation(o.data.TitleId, o.data.Assignmenttype, o.data.GeneralJobId, o.data.TitleName); } })
                                    .appendTo(c).css({ "background-color": "var(--primary)", "border": "none", "border-radius": "4px", "padding": "4px 8px", "cursor": "pointer" });
                            }
                        },
                        { dataField: 'TitleId',      caption: 'TitleId',      width: 140, visible: false },
                        { dataField: 'TitleName',    caption: 'TITLE NAME',   width: 140, visible: false },
                        { dataField: 'GeneralJobId', caption: 'GENERALJOBID', width: 140, visible: false }
                    ],
                    onContentReady: function (e) { updateFooterText1(e.component, e.component.getDataSource().totalCount()); }
                }).dxDataGrid('instance');
            }
        });
    }

    // ── Assignment Extension Grid ────────────────────────────────
    function updateFooterText2(gridInstance, totalCount) {
        var currentPage = gridInstance.pageIndex() + 1;
        var pageSize    = gridInstance.pageSize();
        var startRow    = (currentPage - 1) * pageSize + 1;
        var endRow      = Math.min(startRow + pageSize - 1, totalCount);
        var $footer     = $("#gridContainer2").find(".dx-datagrid-total-footer");
        if ($footer.length === 0) $footer = $("<div>").addClass("dx-datagrid-total-footer").appendTo($("#gridContainer2"));
        $footer.text("Showing " + toIndianFormat(startRow) + " - " + toIndianFormat(endRow) + " of " + toIndianFormat(totalCount) + " rows");
    }

    function loadAssignmentExtensionGrid() {
        $.ajax({
            type: 'GET',
            url: '/GeneralDashboard/LoadAssignmentExtensionData',
            success: function (res) {
                var orders = (res && res.status && res.data) ? res.data : [];
                $('#gridContainer2').dxDataGrid({
                    dataSource: orders, keyExpr: 'TitleId', width: '100%',
                    columnAutoWidth: false, columnMinWidth: 80,
                    allowColumnReordering: true, allowColumnResizing: true,
                    filterRow: { visible: false }, filterPanel: { visible: true },
                    headerFilter: { visible: true }, showBorders: true,
                    noDataText: "No data available", hoverStateEnabled: true,
                    scrolling: { mode: "standard", useNative: true },
                    paging: { enabled: false },
                    columnChooser: { enabled: true, mode: 'select' },
                    searchPanel: { visible: true, width: 240, placeholder: 'Search...' },
                    export: { enabled: true },
                    onExporting: function(e) {
                        if (typeof ExcelJS !== 'undefined') {
                            const wb = new ExcelJS.Workbook();
                            const ws = wb.addWorksheet('Assignment Extensions');
                            DevExpress.excelExporter.exportDataGrid({ component: e.component, worksheet: ws, autoFilterEnabled: true })
                                .then(() => wb.xlsx.writeBuffer().then(buf => saveAs(new Blob([buf], { type: 'application/octet-stream' }), 'Assignment Extensions.xlsx')));
                            e.cancel = true;
                        }
                    },
                    columns: [
                        { dataField: 'Sno',          caption: 'SL.NO',         width: 80,  alignment: 'left' },
                        { dataField: 'JobType',      caption: 'JOBTYPE',        width: 100, alignment: 'center' },
                        { dataField: 'Title',        caption: 'TITLE',          width: 190 },
                        { dataField: 'SubTitle',     caption: 'SUBTITLE',       width: 280 },
                        { dataField: 'EmpName',      caption: 'EMPLOYEE NAME',  width: 140, alignment: 'center' },
                        { dataField: 'NoofExtension',caption: 'EXT.',           width: 100, alignment: 'center' },
                        { dataField: 'Status',       caption: 'STATUS',         width: 110, alignment: 'center' },
                        {
                            dataField: 'Flag', caption: 'UPDATE', width: 100, alignment: 'center',
                            cellTemplate: function (c, o) {
                                $('<div />').dxButton({ icon: 'edit', onClick: function () { Extension_update(o.data.TitleId, o.data.StageId, o.data.substageId, o.data.JobId, o.data.EmpId, o.data.SubTitleId, o.data.EmpJobId, o.data.JobExtensionApproveId, o.data.JobType); } })
                                    .appendTo(c).css({ "background-color": "var(--primary)", "color": "white", "border": "none" });
                            }
                        },
                        { dataField: 'StageId',               visible: false },
                        { dataField: 'substageId',            visible: false },
                        { dataField: 'JobId',                 visible: false },
                        { dataField: 'EmpId',                 visible: false },
                        { dataField: 'TitleId',               visible: false },
                        { dataField: 'SubTitleId',            visible: false },
                        { dataField: 'EmpJobId',              visible: false },
                        { dataField: 'JobExtensionApproveId', visible: false }
                    ],
                    onContentReady: function (e) { updateFooterText2(e.component, e.component.getDataSource().totalCount()); }
                }).dxDataGrid('instance');
            }
        });
    }

    // ─────────────────────────────────────────────────────────────
    // CHANNEL PARTNER SECTION
    // ALL functions below use safeJson() — NO raw JSON.parse()
    // ─────────────────────────────────────────────────────────────

    // Prevent paste on mobile fields
    var _elMob = document.getElementById('txtMOBILENO');
    if (_elMob) {
        _elMob.addEventListener('paste', function (e) {
            e.preventDefault();
            $('#PtxtMOBILENO').text('Pasting is not allowed').css({ color: 'red', display: 'block' });
            setTimeout(function () { $('#PtxtMOBILENO').text('').hide(); }, 2000);
        });
    }
    var _elMob1 = document.getElementById('txtMOBILENO1');
    if (_elMob1) {
        _elMob1.addEventListener('paste', function (e) {
            e.preventDefault();
            $('#PtxtMOBILENO1').text('Pasting is not allowed').css({ color: 'red', display: 'block' });
            setTimeout(function () { $('#PtxtMOBILENO1').text('').hide(); }, 2000);
        });
    }

    // ── Project Layout ───────────────────────────────────────────
    function Project_Layout() {
        var Category = $("input[type=radio][name='EnquiryType']:checked").val();
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/LoadProject',
            data: { Category: Category },
            success: function (response) {
                var data = safeJson(response);           // ← safeJson everywhere
                if (!data) return;
                $('#dd_ProjectLayout').empty();
                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var rows = data.data.Table;
                    var opts = '';
                    for (var i = 0; i < rows.length; i++) {
                        opts += '<option value="' + rows[i].Projectid + '">' + rows[i].ProjectName + '</option>';
                    }
                    $('#dd_ProjectLayout').append(opts);
                }
            },
            error: function (xhr, s, e) { console.error('Project_Layout error:', e); }
        });
    }

    $('input[type=radio][name=EnquiryType]').change(function () { Project_Layout(); });

    // ── Load Client Auto-ID ──────────────────────────────────────
    function LoadClientId() {
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/LoadAutoId',
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var clientId = data.data.Table[0].ClientId;
                    $('#txtautoclientid').val('CP-' + (clientId || '1'));
                }
            },
            error: function (xhr, s, e) { console.error('LoadClientId error:', e); }
        });
    }

    // ── Parent Source ────────────────────────────────────────────
    function ParentSource_load() {
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/LoadParentSource',
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                $('#dd_SourceOfEnquiry').empty();
                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var rows = data.data.Table;
                    var opts = '';
                    for (var i = 0; i < rows.length; i++) {
                        opts += '<option value="' + rows[i].PSrcTranid + '">' + rows[i].PSrcEnquiry + '</option>';
                    }
                    $('#dd_SourceOfEnquiry').append(opts);
                    $('#dd_Soure_Enquiry').append(opts);
                    // Auto-load sub-source for the default selection
                    SubSource_load();
                }
            },
            error: function (xhr, s, e) { console.error('ParentSource_load error:', e); }
        });
    }

    $('#dd_SourceOfEnquiry').change(function () { SubSource_load(); });

    // ── Sub Source ───────────────────────────────────────────────
    function SubSource_load() {
        var PSrcTranid = $("#dd_SourceOfEnquiry option:selected").val() || 0;
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/LoadSubSource',
            data: { PSrcTranid: PSrcTranid },
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                $('#dd_SubSource').empty();
                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var rows = data.data.Table;
                    var opts = '';
                    for (var i = 0; i < rows.length; i++) {
                        opts += '<option value="' + rows[i].SrcTranid + '">' + rows[i].SrcEnquiry + '</option>';
                    }
                    $('#dd_SubSource').append(opts);
                }
            },
            error: function (xhr, s, e) { console.error('SubSource_load error:', e); }
        });
    }

    // ── Clear Form ───────────────────────────────────────────────
    $('#btnEnquiry_clear').click(function () { EnquiryClear(); });

    function EnquiryClear() {
        $('#txtCUSTOMERNAME').val('');
        $('#txtMOBILENO').val('');
        $('#txtMOBILENO1').val('');
        $('#txtPHONENO').val('');
        $('#dd_ProjectLayout').prop('selectedIndex', 0);
        $('#dd_SourceOfEnquiry').prop('selectedIndex', 0);
        $('#dd_SubSource').prop('selectedIndex', 0);
        $('#txt_LOCATION').val('');
        $('#txt_Remarks').val('');
        $('#txt_EMAIL').val('');
        $('#txt_PANNO').val('');
        $('#txt_Adr').val('');
        // Hide all validation messages
        $('[id^="P"]').hide().text('');
        LoadClientId();
        LoadLeads();
    }

    // ── Blur: Mobile 1 duplicate check ──────────────────────────
    $('#txtMOBILENO').on('blur', function () {
        var val = $.trim($(this).val());
        if (!val) return;
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/FindDuplicateMobile',
            data: { Mobile1: val },
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                if (data.status === false && data.msg === 'Session expired. Please login again.') {
                    window.location.href = '/login'; return;
                }
                if (data.msg === 'Success') {
                    alert('Mobile No already exists');
                    $('#txtMOBILENO').val('').focus();
                }
            },
            error: function (xhr, s, e) { console.error('Blur Mobile1 check error:', e); }
        });
    });

    // ── Blur: Mobile 2 duplicate check ──────────────────────────
    $('#txtMOBILENO1').on('blur', function () {
        var val = $.trim($(this).val());
        if (!val) return;
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/FindDuplicateMobile',
            data: { Mobile1: val },
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                if (data.status === false && data.msg === 'Session expired. Please login again.') {
                    window.location.href = '/login'; return;
                }
                if (data.msg === 'Success') {
                    alert('Mobile No 2 already exists');
                    $('#txtMOBILENO1').val('').focus();
                }
            },
            error: function (xhr, s, e) { console.error('Blur Mobile2 check error:', e); }
        });
    });

    // ── Save Button ──────────────────────────────────────────────
    $('#btnEnquiry_save').click(function () {
        $('#btnEnquiry_save').attr('disabled', true);

        var mob1 = $.trim($('#txtMOBILENO').val());
        if (mob1.length < 5) {
            $('#PtxtMOBILENO').text('Enter at least 5 digits').show();
            setTimeout(function () { $('#PtxtMOBILENO').hide(); }, 5000);
            $('#txtMOBILENO').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return false;
        }

        // Step 1: Check Mobile1 duplicate
        $.ajax({
            type: 'GET', url: '/GeneralDashboard/FindDuplicateMobile',
            data: { Mobile1: mob1 },
            success: function (response) {
                var data = safeJson(response);
                if (!data) { $('#btnEnquiry_save').attr('disabled', false); return; }

                if (data.status === false && data.msg === 'Session expired. Please login again.') {
                    window.location.href = '/login'; return;
                }
                if (data.msg === 'Success') {
                    alert('Mobile No 1 already exists');
                    $('#txtMOBILENO').val('').focus();
                    $('#btnEnquiry_save').attr('disabled', false);
                    return;
                }

                // Step 2: Check Mobile2 duplicate if provided
                var mob2 = $.trim($('#txtMOBILENO1').val());
                if (mob2 !== '') {
                    if (mob2.length < 5) {
                        $('#PtxtMOBILENO1').text('Enter at least 5 digits').show();
                        setTimeout(function () { $('#PtxtMOBILENO1').hide(); }, 5000);
                        $('#txtMOBILENO1').focus();
                        $('#btnEnquiry_save').attr('disabled', false);
                        return;
                    }
                    $.ajax({
                        type: 'GET', url: '/GeneralDashboard/FindDuplicateMobile',
                        data: { Mobile1: mob2 },
                        success: function (response2) {
                            var data2 = safeJson(response2);
                            if (!data2) { $('#btnEnquiry_save').attr('disabled', false); return; }

                            if (data2.status === false && data2.msg === 'Session expired. Please login again.') {
                                window.location.href = '/login'; return;
                            }
                            if (data2.msg === 'Success') {
                                alert('Mobile No 2 already exists');
                                $('#txtMOBILENO1').val('').focus();
                                $('#btnEnquiry_save').attr('disabled', false);
                                return;
                            }
                            SaveEnquiry();
                        },
                        error: function (xhr, s, e) {
                            console.error('Mobile2 check error:', e);
                            alert('Error checking Mobile 2. Please try again.');
                            $('#btnEnquiry_save').attr('disabled', false);
                        }
                    });
                } else {
                    SaveEnquiry();
                }
            },
            error: function (xhr, s, e) {
                console.error('Mobile1 check error:', e);
                if (xhr.status === 401) { window.location.href = '/login'; return; }
                alert('Error checking Mobile 1. Please try again.');
                $('#btnEnquiry_save').attr('disabled', false);
            }
        });
    });

    // ── Save Enquiry ─────────────────────────────────────────────
    function SaveEnquiry() {
        // Field validations
        if (!$.trim($('#txtCUSTOMERNAME').val())) {
            $('#PtxtCUSTOMERNAME').text('Enter Client Name').show();
            setTimeout(function () { $('#PtxtCUSTOMERNAME').hide(); }, 5000);
            $('#txtCUSTOMERNAME').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }
        if ($.trim($('#txtMOBILENO').val()).length < 5) {
            $('#PtxtMOBILENO').text('Enter at least 5 digits').show();
            setTimeout(function () { $('#PtxtMOBILENO').hide(); }, 5000);
            $('#txtMOBILENO').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }
        var mob2 = $.trim($('#txtMOBILENO1').val());
        if (mob2 && mob2.length < 5) {
            $('#PtxtMOBILENO1').text('Enter at least 5 digits').show();
            setTimeout(function () { $('#PtxtMOBILENO1').hide(); }, 5000);
            $('#txtMOBILENO1').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }
        if (!$('#dd_ProjectLayout').val() || $('#dd_ProjectLayout').val() === '0') {
            $('#Pdd_ProjectLayout').text('Select Project').show();
            setTimeout(function () { $('#Pdd_ProjectLayout').hide(); }, 5000);
            $('#dd_ProjectLayout').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }
        if (!$('#dd_SourceOfEnquiry').val() || $('#dd_SourceOfEnquiry').val() === '0') {
            $('#Pdd_SourceOfEnquiry').text('Select Source Of Enquiry').show();
            setTimeout(function () { $('#Pdd_SourceOfEnquiry').hide(); }, 5000);
            $('#dd_SourceOfEnquiry').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }
        if (!$('#dd_SubSource').val() || $('#dd_SubSource').val() === '0') {
            $('#Pdd_SubSource').text('Select Sub Source Of Enquiry').show();
            setTimeout(function () { $('#Pdd_SubSource').hide(); }, 5000);
            $('#dd_SubSource').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return;
        }

        var payload = {
            ClientName:      $('#txtCUSTOMERNAME').val(),
            Mobile1:         $('#txtMOBILENO').val(),
            Mobile2:         $('#txtMOBILENO1').val(),
            Category:        $("input[name='EnquiryType']:checked").val(),
            projectId:       $('#dd_ProjectLayout').val() || '0',
            SrcTranid:       $('#dd_SourceOfEnquiry').val() || '0',
            SubSrcEnquiryId: $('#dd_SubSource').val() || '0',
            Location:        $('#txt_LOCATION').val(),
            EmailId1:        $('#txt_EMAIL').val(),
            Panno:           $('#txt_PANNO').val(),
            AadharNo:        $('#txt_Adr').val(),
            Remarks:         $('#txt_Remarks').val(),
            CountryCode1:    ($('#countryCode_1').val() || '').replace('+', ''),
            CountryCode2:    ($('#countryCode_2').val() || '').replace('+', '')
        };

        $.ajax({
            type: 'POST', url: '/GeneralDashboard/SaveLeads',
            contentType: 'application/json; charset=UTF-8',
            data: JSON.stringify(payload),
            success: function (response) {
                var data = safeJson(response);
                if (!data) { alert('Unexpected response'); $('#btnEnquiry_save').attr('disabled', false); return; }

                if (data.status === true && data.msg === 'Success') {
                    alert('Lead saved successfully!');
                    EnquiryClear();
                } else {
                    alert(data.msg || 'Something went wrong');
                    // Focus and clear relevant field based on server message
                    if (data.msg && data.msg.toLowerCase().includes('project'))         $('#dd_ProjectLayout').focus();
                    else if (data.msg && data.msg.toLowerCase().includes('source'))     $('#dd_SourceOfEnquiry').focus();
                    else if (data.msg && data.msg.toLowerCase().includes('sub source')) $('#dd_SubSource').focus();
                    else if (data.msg && data.msg.toLowerCase().includes('client'))     $('#txtCUSTOMERNAME').focus();
                    else if (data.msg && data.msg.toLowerCase().includes('mobile'))     $('#txtMOBILENO').val('').focus();
                }
                $('#btnEnquiry_save').attr('disabled', false);
            },
            error: function (xhr, s, e) {
                console.error('SaveLeads error:', e);
                alert('An error occurred while saving. Please try again.');
                $('#btnEnquiry_save').attr('disabled', false);
            }
        });
    }

    // ── Load Leads Grid ──────────────────────────────────────────
    function LoadLeads() {
        $.ajax({
            type: 'POST', url: '/GeneralDashboard/LoadLeads',
            contentType: 'application/json; charset=UTF-8',
            data: JSON.stringify({ FromDate: '', ToDate: '', LandCategory: '', ZonalType: '', OwnershipType: '' }),
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;
                var orders = (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) ? data.data.Table : [];
                CpLeadFunction(orders);
            },
            error: function (xhr, s, e) { console.error('LoadLeads error:', e); }
        });
    }

   
    function CpLeadFunction(orders) {
    orders = orders || [];
    var $container = $('#gridContainer_cp');
    if (!$container.length) return;

    // ── Safe destroy ─────────────────────────────────────────────
    try {
        var existingInstance = $container.dxDataGrid('instance');
        if (existingInstance) {
            existingInstance.dispose();
            $container.empty();
        }
    } catch (e) {
        $container.empty();
    }

    // ── Initialize Grid ──────────────────────────────────────────
    $container.dxDataGrid({
        dataSource: orders,
        keyExpr: 'EnquiryID',
        columnsAutoWidth: true,
        showBorders: true,
        allowColumnReordering: true,
        allowColumnResizing: true,
        filterRow: { visible: false, applyFilter: 'auto' },
        filterPanel: { visible: true },
        headerFilter: { visible: true },
        filterBuilderPopup: {
            position: { of: window, at: 'top', my: 'top', offset: { y: 10 } }
        },
        hoverStateEnabled: true,
        scrolling: {
            mode: 'standard',
            useNative: true
        },
        paging: {
            enabled: false
        },
        columnChooser: {
            enabled: true,
            mode: 'select'
        },
        searchPanel: {
            visible: true,
            width: 240,
            placeholder: 'Search...'
        },
        export: {
            enabled: true
        },
        onExporting: function (e) {
            e.cancel = true;
            
            var columns = e.component.getVisibleColumns().filter(c => c.dataField);
            var dataSource = e.component.getDataSource();
            var options = dataSource.loadOptions() || {};
            
            options.skip = undefined;
            options.take = undefined;
            options.requireTotalCount = false;

            setTimeout(function() {
                dataSource.store().load(options).then(function (data) {
                    var chunks = [];
                    chunks.push('\uFEFF');
                    
                    var header = columns.map(c => `"${(c.caption || c.dataField).replace(/"/g, '""')}"`).join(',');
                    chunks.push(header + '\n');

                    for (var i = 0; i < data.length; i++) {
                        var row = [];
                        for (var j = 0; j < columns.length; j++) {
                            var col = columns[j];
                            var val = data[i][col.dataField];

                            if (val === null || val === undefined) {
                                val = '';
                            } else if (typeof col.customizeText === 'function') {
                                val = col.customizeText({ value: val, valueText: String(val) });
                            } else if (col.dataType === 'datetime' || col.dataType === 'date') {
                                var d = new Date(val);
                                if (!isNaN(d)) {
                                    var day = ('0' + d.getDate()).slice(-2);
                                    var month = ('0' + (d.getMonth() + 1)).slice(-2);
                                    var year = d.getFullYear();
                                    val = day + '/' + month + '/' + year;
                                }
                            }
                            
                            var str = String(val).replace(/"/g, '""');
                            str = str.replace(/\r?\n|\r/g, ' '); 
                            row.push(`"${str}"`);
                        }
                        chunks.push(row.join(',') + '\n');
                    }

                    var blob = new Blob(chunks, { type: 'text/csv;charset=utf-8;' });
                    var link = document.createElement("a");
                    var url = URL.createObjectURL(blob);
                    link.setAttribute("href", url);
                    link.setAttribute("download", "Channel_Partner_Leads.csv");
                    link.style.visibility = 'hidden';
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                });
            }, 50);
        },
        columns: [
            {
                dataField: 'EnquiryID',
                caption: 'ENQUIRY ID',
                width: 80,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'LeadRemarks',
                caption: 'VGN REMARKS',
                width: 80,
                alignment: 'center',
                headerFilter: { allowSearch: false },
                cellTemplate: function (container, options) {
                    var btn = $('<button>', {
                        type: 'button',
                        class: 'action-btn',
                        title: 'View Remarks',
                        html: '<i class="fas fa-comments"></i>'
                    });
                    
                    // Add subtle hover effect dynamically
                    btn.hover(
                        function() { jQuery(this).css('transform', 'scale(1.05)'); },
                        function() { jQuery(this).css('transform', 'scale(1)'); }
                    );

                    btn.on('click', function () {
                        // Pass EnquiryID instead of LeadRemarks
                                LeadRemarks(options.data.LeadRemarks);
                    });
                    container.append(btn);
                }
            },
            {
                dataField: 'CreatedDate',
                caption: 'CREATED DATE',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'CustomerName',
                caption: 'CLIENT NAME',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'Mobile1',
                caption: 'MOBILE',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'Email',
                caption: 'EMAIL ID',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'AgentName',
                caption: 'AGENT NAME',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'ProjectName',
                caption: 'PROJECT NAME',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'SrcEnquiry',
                caption: 'SUB SOURCE',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'PSrcEnquiry',
                caption: 'MAIN SOURCE',
                width: 140,
                headerFilter: { allowSearch: true }
            },
            {
                dataField: 'Remarks',
                caption: 'REMARKS',
                width: 140,
                headerFilter: { allowSearch: true }
            }
        ]
    }).dxDataGrid('instance');
}



    // ── Lead Remarks Modal ───────────────────────────────────────
    function LeadRemarks(clientId) {
        // Removed jQuery.noConflict() because it unsets the global $ variable and breaks other scripts.

        jQuery('#ExecutiveRemarks').modal('show');

        var objVal = { ClientId: clientId };

        // Reset fields
        jQuery('#EXECUTIVE_Rmks').val('').attr('disabled', true);
        jQuery('#Presales_Rmks').val('').attr('disabled', true);

        // 1. Load Presales Remarks (Independent Call)
        jQuery.ajax({
            type: 'POST', url: '/GeneralDashboard/LoadPresalesPreviousRemarks',
            contentType: 'application/json; charset=UTF-8',
            data: JSON.stringify(objVal),
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;

                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var rows = data.data.Table;
                    if (rows && rows.length > 0) {
                        var txt = '';
                        jQuery.each(rows, function (i, emp) { txt += '\n' + emp.ExecutiveRemarks; });
                        jQuery('#Presales_Rmks').val(txt.trim()).attr('disabled', true);
                    }
                }
            },
            error: function (xhr, s, e) { 
                console.error('LoadPresalesRemarks error:', e); 
                alert('Unable to load Presales Remarks. Please try again later.');
            }
        });

        // 2. Load Sales Executive Remarks (Independent Call)
        jQuery.ajax({
            type: 'POST', url: '/GeneralDashboard/LoadSalesExecutivePreviousRemarks',
            contentType: 'application/json; charset=UTF-8',
            data: JSON.stringify(objVal),
            success: function (response) {
                var data = safeJson(response);
                if (!data) return;

                if (data.msg === 'Success' && !jQuery.isEmptyObject(data.data)) {
                    var rows = data.data.Table;
                    if (rows && rows.length > 0) {
                        var txt = '';
                        jQuery.each(rows, function (i, emp) { txt += '\n' + emp.EmpRemarks; });
                        jQuery('#EXECUTIVE_Rmks').val(txt.trim()).attr('disabled', true);
                    }
                }
            },
            error: function (xhr, s, e) { 
                console.error('LoadSalesExecRemarks error:', e); 
                alert('Unable to load Sales Executive Remarks. Please try again later.');
            }
        });
    }

})();
