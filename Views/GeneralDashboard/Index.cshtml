@{
    ViewBag.Title = "General Dashboard";
    ViewBag.ActiveMenu = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = ViewBag.UserId as string ?? "";
    var userRole = ViewBag.UserRole as string ?? "";
    var departmentId = ViewBag.DepartmentId as string ?? "";
    bool isPresentationUser = userId.ToUpper() == "MD" || userId.ToUpper() == "CEO" || userId.ToUpper() == "TEST" || userId.ToUpper() == "E1810";
    
    bool isExcludedDept = departmentId == "DEPT-5" || departmentId == "DEPT-28" || departmentId == "DEPT-31";
    bool isExcludedUser = userId.ToUpper() == "MD" || userId.ToUpper() == "CEO" || userId.ToUpper() == "D001" || userId.ToUpper() == "TEST" || userId.ToUpper() == "E1810" || userId.ToUpper() == "CHANNELPARTNER" || userId.ToUpper().StartsWith("MP");
    bool isExcludedRole = userRole.ToUpper().Contains("CHANNEL");
    
    // Daybook & Assignment Extension are hidden for excluded depts, but Attendance/Snapshot are visible to them.
    bool shouldShowDaybookAndExtension = !isExcludedDept && !isExcludedUser && !isExcludedRole;
    bool shouldShowAttendanceAndPunch = !isExcludedUser && !isExcludedRole;
}

<style>

    /* ── Compact Attendance Calendar ───────────────────── */
    .att-cal-wrap {
        background: var(--bg-card, var(--surface));
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }

    .att-cal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .6rem;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .att-cal-title {
        font-size: .92rem;
        font-weight: 700;
        color: var(--text);
    }

    .att-cal-nav {
        display: flex;
        gap: 6px;
    }

        .att-cal-nav button {
            width: 28px;
            height: 28px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--surface);
            color: var(--text);
            cursor: pointer;
            font-size: .85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s;
        }

            .att-cal-nav button:hover {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

    .att-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 3px;
    }

    .att-grid-head {
        text-align: center;
        font-size: .68rem;
        font-weight: 700;
        color: var(--text-muted);
        padding: 3px 0;
        letter-spacing: .4px;
    }

    .att-day-cell {
        border-radius: 7px;
        padding: 4px 3px 3px;
        min-height: 52px;
        font-size: .65rem;
        border: 1px solid transparent;
        position: relative;
        cursor: default;
        transition: transform .15s, box-shadow .15s;
    }

        .att-day-cell:hover {
            transform: scale(1.06);
            box-shadow: 0 3px 10px rgba(0,0,0,.12);
            z-index: 2;
        }

        .att-day-cell.empty {
            background: transparent;
            border: none;
        }

        .att-day-cell.no-data {
            background: var(--bg);
            border-color: var(--border);
        }

        .att-day-cell.on-time {
            background: #d1fae5;
            border-color: #6ee7b7;
        }

        .att-day-cell.slight-late {
            background: #fef9c3;
            border-color: #fde047;
        }

        .att-day-cell.late {
            background: #fee2e2;
            border-color: #fca5a5;
        }

        .att-day-cell.today {
            border-color: var(--primary) !important;
            border-width: 2px !important;
        }

    .att-day-num {
        font-weight: 700;
        color: var(--text);
        font-size: .72rem;
    }

    .att-day-name {
        float: right;
        color: var(--text-muted);
        font-size: .6rem;
    }

    .att-day-cell.on-time .att-day-num,
    .att-day-cell.slight-late .att-day-num,
    .att-day-cell.late .att-day-num {
        color: #1e293b !important;
    }

    .att-day-cell.on-time .att-day-name,
    .att-day-cell.slight-late .att-day-name,
    .att-day-cell.late .att-day-name {
        color: #475569 !important;
    }

    .att-punch {
        margin-top: 2px;
        line-height: 1.3;
    }

        .att-punch span {
            display: block;
            font-size: .6rem;
            white-space: nowrap;
        }

    .att-in {
        color: #059669;
    }

    .att-out {
        color: #6b7280;
    }

    .att-legend {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: .6rem;
    }

        .att-legend span {
            font-size: .68rem;
            display: flex;
            align-items: center;
            gap: 4px;
            color: var(--text-muted);
        }

            .att-legend span i {
                width: 10px;
                height: 10px;
                border-radius: 3px;
                display: inline-block;
            }

    .leg-green {
        background: #6ee7b7;
    }

    .leg-yellow {
        background: #fde047;
    }

    .leg-red {
        background: #fca5a5;
    }

    .leg-empty {
        background: var(--border);
    }

    .att-summary {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: .6rem;
    }

    .att-sum-pill {
        font-size: .7rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    .gdash-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.04);
        height: 100%;
    }

    .gdash-card-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .6px;
        margin-bottom: .75rem;
    }

    .dept-section {
        transition: opacity .35s ease, max-height .35s ease;
        overflow: hidden;
    }

        .dept-section.d-section-hidden {
            opacity: 0;
            max-height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
        }

    .grid-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .grid-table thead th {
            background: rgba(70,128,255,.08);
            color: var(--text);
            font-weight: 700;
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.4px;
        }

        .grid-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s ease;
        }

            .grid-table tbody tr:hover {
                background: rgba(70,128,255,.04);
            }

        .grid-table tbody td {
            padding: 0.75rem;
            color: var(--text);
        }

        .grid-table .text-center {
            text-align: center;
        }

        .grid-table .text-right {
            text-align: right;
        }

        .grid-table .action-btn {
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text);
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.15s ease;
        }

            .grid-table .action-btn:hover {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

    .grid-empty {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    /* ── Theme-Aware Card Components ───────────────────── */
    .erp-card-inner {
        background: var(--surface);
        border-radius: 14px;
        border: 1px solid var(--border);
        box-shadow: var(--card-shadow);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        transition: background var(--trans), border-color var(--trans);
    }

    .erp-card-header {
        border-bottom: 1px solid var(--border);
        background: rgba(var(--primary-rgb), 0.04);
        padding: 1rem 1.25rem;
    }

        .erp-card-header h3 {
            font-size: .875rem;
            font-weight: 700;
            color: var(--text);
            display: flex;
            align-items: center;
            text-transform: uppercase;
            letter-spacing: .5px;
            margin: 0;
        }

    .erp-card-body {
        padding: 1.25rem;
        flex: 1;
    }

    .erp-card-body-muted {
        padding: 1.25rem;
        flex: 1;
        font-size: .8125rem;
        color: var(--text-muted);
    }

    .erp-card-title {
        font-size: .8125rem;
        font-weight: 700;
        color: var(--text);
        display: flex;
        align-items: center;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: .5rem;
    }

    /* Theme-aware form controls override */
    .theme-form-control {
        background: var(--surface) !important;
        color: var(--text) !important;
        border: 1px solid var(--border) !important;
        border-radius: 6px;
        padding: 6px 8px;
        font-size: 12px;
        width: 100%;
        outline: none;
        transition: border-color var(--trans);
    }

        .theme-form-control:focus {
            border-color: var(--primary) !important;
            box-shadow: 0 0 0 3px rgba(var(--primary-rgb), 0.15);
        }

    .theme-label {
        display: block;
        margin-bottom: 4px;
        font-size: 11px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
    }

    .erp-stat-pill {
        padding: 10px 14px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--bg);
        transition: background var(--trans);
    }
</style>

@if (isPresentationUser)
{
    <style>
        .presentation-container {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            min-height: 100vh;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .hero-section {
            position: relative;
            height: 400px;
            background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.9));
        }

        .hero-content {
            position: relative;
            z-index: 10;
            color: white;
            padding: 0 20px;
        }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 1rem;
            background: linear-gradient(to right, #ffffff, #cbd5e1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            font-size: 1.25rem;
            color: #94a3b8;
            max-width: 800px;
            margin: 0 auto;
        }

        .content-section {
            padding: 4rem 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1e293b;
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: #3b82f6;
            border-radius: 2px;
        }

        .journey-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
        }

        .journey-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
        }

        .journey-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .journey-img {
            height: 200px;
            width: 100%;
            object-fit: cover;
        }

        .journey-body {
            padding: 2.5rem 2rem 2rem 2rem;
        }

        .journey-icon-wrap {
            position: absolute;
            top: 170px;
            right: 20px;
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            font-size: 1.5rem;
            color: #3b82f6;
        }

        .journey-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.5rem;
        }

        .journey-text {
            color: #64748b;
            line-height: 1.6;
        }

        .pillars-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .pillar-card {
            background: linear-gradient(145deg, #ffffff, #f8fafc);
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 2rem;
            text-align: center;
            transition: all 0.3s ease;
        }

        .pillar-card:hover {
            border-color: #3b82f6;
            box-shadow: 0 10px 15px -3px rgba(59, 130, 246, 0.1);
        }

        .pillar-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: inline-block;
        }

        .icon-marketing { color: #ec4899; }
        .icon-presales { color: #8b5cf6; }
        .icon-sales { color: #10b981; }
        .icon-crm { color: #f59e0b; }

        .pillar-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.5rem;
        }

        .pillar-text {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.5;
        }
        
        .success-banner {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border-radius: 16px;
            padding: 3rem 2rem;
            text-align: center;
            color: white;
            margin-top: 4rem;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 25px -5px rgba(16, 185, 129, 0.3);
        }
        
        .success-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 60%);
            pointer-events: none;
        }
        
        .success-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            display: inline-block;
        }
    </style>

    <div class="presentation-container animate-fade-in">
        <!-- Hero Section -->
        <div class="hero-section">
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <h1 class="hero-title">VGN HOMES Ecosystem</h1>
                <p class="hero-subtitle">A seamless journey from initial lead generation to the final handover, driven by integrated teams and powerful CRM capabilities.</p>
            </div>
        </div>

        <div class="content-section">
            <h2 class="section-title">The Customer Journey</h2>
            
            <div class="journey-grid">
                <!-- Step 1 -->
                <div class="journey-card">
                    <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Properties" class="journey-img">
                    <div class="journey-icon-wrap"><i class="bi bi-buildings"></i></div>
                    <div class="journey-body">
                        <h3 class="journey-title">Premium Offerings</h3>
                        <p class="journey-text">Providing high-quality Plots, Villas, and Flats. The foundation of our business starts with exceptional real estate projects tailored to our customers' dreams.</p>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="journey-card">
                    <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Lead Gen" class="journey-img">
                    <div class="journey-icon-wrap" style="color: #f59e0b;"><i class="bi bi-funnel"></i></div>
                    <div class="journey-body">
                        <h3 class="journey-title">Lead Generation</h3>
                        <p class="journey-text">Capturing potential buyers through robust multi-channel strategies including Online campaigns, Offline marketing, and dedicated Channel Partners (CP).</p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="journey-card">
                    <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Exec Assignment" class="journey-img">
                    <div class="journey-icon-wrap" style="color: #ec4899;"><i class="bi bi-person-check"></i></div>
                    <div class="journey-body">
                        <h3 class="journey-title">Executive Assignment</h3>
                        <p class="journey-text">Leads are strategically routed to our expert executives. Presales and Sales teams take ownership to nurture and guide the customer effectively.</p>
                    </div>
                </div>
            </div>

            <h2 class="section-title">The Core Pillars</h2>
            
            <div class="pillars-grid">
                <div class="pillar-card">
                    <i class="bi bi-megaphone pillar-icon icon-marketing"></i>
                    <h3 class="pillar-title">Marketing</h3>
                    <p class="pillar-text">Creating brand awareness, running campaigns, and driving the initial interest to generate high-quality leads.</p>
                </div>
                <div class="pillar-card">
                    <i class="bi bi-telephone-inbound pillar-icon icon-presales"></i>
                    <h3 class="pillar-title">Presales & Telesales</h3>
                    <p class="pillar-text">Engaging leads instantly, answering preliminary queries, and setting up crucial site visits.</p>
                </div>
                <div class="pillar-card">
                    <i class="bi bi-currency-rupee pillar-icon icon-sales"></i>
                    <h3 class="pillar-title">Sales</h3>
                    <p class="pillar-text">Guiding customers through site visits, negotiating terms, and driving the final conversions.</p>
                </div>
                <div class="pillar-card">
                    <i class="bi bi-headset pillar-icon icon-crm"></i>
                    <h3 class="pillar-title">CRM</h3>
                    <p class="pillar-text">Managing relationships, processing documentation, and ensuring absolute post-booking satisfaction.</p>
                </div>
            </div>
            
            <div class="success-banner">
                <i class="bi bi-check2-circle success-icon"></i>
                <h2 class="text-4xl font-bold mb-4">Conversion & Booking</h2>
                <p class="text-xl max-w-2xl mx-auto opacity-90">The ultimate goal of our ecosystem. A seamless handover from our core teams results in successful bookings and happy homeowners.</p>
            </div>
        </div>
    </div>
}
else
{

<div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mb-4">

    @if (shouldShowAttendanceAndPunch)
    {
    <div class="lg:col-span-4">
        <div class="erp-card-inner" style="padding:1.25rem;gap:.75rem;">
            <h3 class="erp-card-title mb-2">
                <i class="bi bi-lightning-charge text-yellow-500 text-lg mr-2"></i>Today's Snapshot
            </h3>
            <div class="flex gap-2">
                <div class="flex-1 p-3 rounded-3 text-center" style="background:#d1fae5;">
                    <div style="font-size:.7rem;color:#059669;font-weight:600">IN TIME</div>
                    <div id="kpi_intime" style="font-size:1.1rem;font-weight:800;color:#065f46;">--:-- --</div>
                </div>
                <div class="flex-1 p-3 rounded-3 text-center" style="background:#fee2e2;">
                    <div style="font-size:.7rem;color:#dc2626;font-weight:600">LAST OUT</div>
                    <div id="kpi_outtime" style="font-size:1.1rem;font-weight:800;color:#7f1d1d;">--:-- --</div>
                </div>
            </div>
            <div class="att-summary" id="att-summary-pills">
                <span class="att-sum-pill" style="background:#d1fae5;color:#065f46;">🟢 On Time: <span id="cnt_ontime">0</span></span>
                <span class="att-sum-pill" style="background:#fef9c3;color:#854d0e;">🟠 Slight Late: <span id="cnt_slightlate">0</span></span>
                <span class="att-sum-pill" style="background:#fee2e2;color:#7f1d1d;">🔴 Late: <span id="cnt_late">0</span></span>
                <span class="att-sum-pill" style="background:var(--bg);color:var(--text-muted);">⬜ No Punch: <span id="cnt_absent">0</span></span>
            </div>
            <div class="grid grid-cols-2 gap-2 mt-auto">
                <div class="col-span-1">
                    <div class="p-2 rounded-3" style="background:var(--bg)">
                        <div class="small" style="font-size:.68rem;color:var(--text-muted)">IP Address</div>
                        <div class="fw-semibold" style="font-size:.75rem;color:var(--text)">@ViewBag.IPAddress</div>
                    </div>
                </div>
                <div class="col-span-1">
                    <div class="p-2 rounded-3" style="background:var(--bg)">
                        <div class="small" style="font-size:.68rem;color:var(--text-muted)">Login Time</div>
                        <div class="fw-semibold" style="font-size:.75rem;color:var(--text)">@ViewBag.LoginTime</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    }

    @if (shouldShowAttendanceAndPunch)
    {
    <div class="lg:col-span-8">
        <div class="att-cal-wrap">
            <div class="att-cal-header">
                <div class="att-cal-title"><i class="bi bi-calendar3 me-1" style="color:var(--primary)"></i>Attendance Calendar</div>
                <div class="flex items-center gap-2 flex-wrap">
                    <div class="att-cal-nav">
                        <button id="cal_prev" title="Previous Month">&#8249;</button>
                        <button id="cal_next" title="Next Month">&#8250;</button>
                    </div>
                    <span id="cal_month_label" class="fw-semibold" style="font-size:.85rem;color:var(--text);min-width:90px;text-align:center"></span>
                    <button id="cal_export"
                            style="font-size:.72rem;padding:3px 10px;border:1px solid var(--border);background:var(--surface);color:var(--text);border-radius:8px;">
                        <i class="bi bi-download me-1"></i>CSV
                    </button>
                </div>
