<div class="row g-3 mb-3">

    <!-- Quick KPI Cards (col-lg-4) -->
    @if (!userRole.ToUpper().Contains("CHANNEL") && !userId.ToUpper().StartsWith("MP") && userId.ToUpper() != "CHANNELPARTNER" && userId.ToUpper() != "MD" && userId.ToUpper() != "CEO" && userId.ToUpper() != "D001" && userId.ToUpper() != "TEST")
    {
        <div class="col-lg-4">
            <div class="gdash-card d-flex flex-column gap-3">
                <div class="gdash-card-title"><i class="bi bi-lightning-charge me-1 text-warning"></i>Today's Snapshot</div>

                <!-- Today InTime / OutTime -->
                <div class="d-flex gap-2">
                    <div class="flex-fill p-3 rounded-3 text-center" style="background:#d1fae5;">
                        <div style="font-size:.7rem;color:#059669;font-weight:600">IN TIME</div>
                        <div id="kpi_intime" style="font-size:1.1rem;font-weight:800;color:#065f46;">--:-- --</div>
                    </div>
                    <div class="flex-fill p-3 rounded-3 text-center" style="background:#fee2e2;">
                        <div style="font-size:.7rem;color:#dc2626;font-weight:600">LAST OUT</div>
                        <div id="kpi_outtime" style="font-size:1.1rem;font-weight:800;color:#7f1d1d;">--:-- --</div>
                    </div>
                </div>

                <!-- Month summary pills -->
                <div class="att-summary" id="att-summary-pills">
                    <span class="att-sum-pill" style="background:#d1fae5;color:#065f46;" id="pill_ontime">🟢 On Time: <span id="cnt_ontime">0</span></span>
                    <span class="att-sum-pill" style="background:#fef9c3;color:#854d0e;" id="pill_late">🟠 Slight Late: <span id="cnt_slightlate">0</span></span>
                    <span class="att-sum-pill" style="background:#fee2e2;color:#7f1d1d;" id="pill_vlate">🔴 Late: <span id="cnt_late">0</span></span>
                    <span class="att-sum-pill" style="background:var(--bg);color:var(--text-muted);" id="pill_absent">⬜ No Punch: <span id="cnt_absent">0</span></span>
                </div>

                <!-- Session Info -->
                <div class="row g-2 mt-auto">
                    <div class="col-6">
                        <div class="p-2 rounded-3" style="background:var(--bg)">
                            <div class="small" style="font-size:.68rem;color:var(--text-muted)">IP Address</div>
                            <div class="fw-semibold" style="font-size:.75rem;color:var(--text)">@ViewBag.IPAddress</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 rounded-3" style="background:var(--bg)">
                            <div class="small" style="font-size:.68rem;color:var(--text-muted)">Login Time</div>
                            <div class="fw-semibold" style="font-size:.75rem;color:var(--text)">@ViewBag.LoginTime</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Attendance Calendar (col-lg-8) -->
    @if (userId.ToUpper() != "MD" && userId.ToUpper() != "CEO" && userId.ToUpper() != "D001" && userId.ToUpper() != "TEST" && !userRole.ToUpper().Contains("CHANNEL") && !userId.ToUpper().StartsWith("MP") && userId.ToUpper() != "CHANNELPARTNER")
    {
        <div class="col-lg-8">
            <div class="att-cal-wrap">
                <div class="att-cal-header">
                    <div class="att-cal-title"><i class="bi bi-calendar3 me-1" style="color:var(--primary)"></i>Attendance Calendar</div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="att-cal-nav">
                            <button id="cal_prev" title="Previous Month">&#8249;</button>
                            <button id="cal_next" title="Next Month">&#8250;</button>
                        </div>
                        <span id="cal_month_label" class="fw-semibold" style="font-size:.85rem;color:var(--text);min-width:90px;text-align:center"></span>
                        <button class="btn btn-sm" id="cal_export"
                                style="font-size:.72rem;padding:3px 10px;border:1px solid var(--border);background:var(--surface);color:var(--text);border-radius:8px;">
                            <i class="bi bi-download me-1"></i>CSV
                        </button>
                    </div>
                </div>

                <div class="att-grid" id="att_grid_head">
                    @foreach (var d in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                    {
                        <div class="att-grid-head">@d</div>
                    }
                </div>

                <div class="att-grid" id="att_grid_body" style="margin-top:3px;"></div>

                <div class="att-legend">
                    <span><i class="leg-green"></i> On Time (≤9:30)</span>
                    <span><i class="leg-yellow"></i> 9:31–9:45</span>
                    <span><i class="leg-red"></i> After 9:45</span>
                    <span><i class="leg-empty"></i> No Punch</span>
                </div>
            </div>
        </div>
    }
</div>

@if (userId.ToUpper() == "MD" || userId.ToUpper() == "CEO" || userId.ToUpper() == "D001")
{
    <!-- CMD Specific Cards -->
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="gdash-card">
                <div class="gdash-card-title"><i class="bi bi-person-badge text-primary me-1"></i>CMD Dashboard</div>
                <div class="row text-center mt-3">
                    <div class="col-md-3"><div class="p-3 bg-light rounded border"><div class="fs-4 text-success fw-bold">COM</div><small>Completed</small></div></div>
                    <div class="col-md-3"><div class="p-3 bg-light rounded border"><div class="fs-4 text-warning fw-bold">IN</div><small>In Progress</small></div></div>
                    <div class="col-md-3"><div class="p-3 bg-light rounded border"><div class="fs-4 text-info fw-bold">EX</div><small>Extension</small></div></div>
                    <div class="col-md-3"><div class="p-3 bg-light rounded border"><div class="fs-4 text-danger fw-bold">CAN</div><small>Cancelled</small></div></div>
                </div>
            </div>
        </div>
    </div>
}

@if (userRole.ToUpper().Contains("CHANNEL") || userId.ToUpper().StartsWith("MP") || userId.ToUpper() == "CHANNELPARTNER")
{
    <!-- Channel Partner Specific Cards -->
    <div class="row g-3 mb-3">
        <div class="col-md-6">
            <div class="gdash-card">
                <div class="gdash-card-title"><i class="bi bi-person-plus text-success me-1"></i>New Lead / Enquiry</div>
                <div class="row g-2">
                    <div class="col-12">
                        <label class="form-label" style="font-size:11px;">CUSTOMER NAME</label>
                        <input class="form-control form-control-sm" type="text" id="txtCUSTOMERNAME">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" style="font-size:11px;">COUNTRY CODE</label>
                        <select class="form-select form-select-sm" id="countryCode_1">
                            <option value="+91">+91 (India)</option>
                        </select>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label" style="font-size:11px;">MOBILE NO 1 <span class="text-danger">*</span></label>
                        <input class="form-control form-control-sm" type="text" id="txtMOBILENO" placeholder="Enter phone number">
                        <p id="PtxtMOBILENO" class="validate_errupb75" style="        color: red;"></p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">PROJECT CATEGORY <span class="text-danger">*</span></label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="EnquiryType" id="inlineRadio1" value="FLAT" checked>
                                <label class="form-check-label" style="font-size:11px;" for="inlineRadio1">FLAT</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="EnquiryType" id="inlineRadio2" value="PLOT">
                                <label class="form-check-label" style="font-size:11px;" for="inlineRadio2">PLOT</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="EnquiryType" id="inlineRadio3" value="VILLA">
                                <label class="form-check-label" style="font-size:11px;" for="inlineRadio3">VILLA</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">PROJECT NAME <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="dd_ProjectLayout"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">SOURCE OF ENQUIRY <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="dd_SourceOfEnquiry"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">SUB SOURCE <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm" id="dd_SubSource"></select>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="gdash-card d-flex flex-column h-100">
                <div class="gdash-card-title"><i class="bi bi-info-circle text-primary me-1"></i>Additional Details</div>
                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">EMAIL ID</label>
                        <input class="form-control form-control-sm" type="email" id="txt_EMAIL">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">LOCATION</label>
                        <input class="form-control form-control-sm" type="text" id="txt_LOCATION">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">PAN NO</label>
                        <input class="form-control form-control-sm" type="text" id="txt_PANNO">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" style="font-size:11px;">AADHAR NO</label>
                        <input class="form-control form-control-sm" type="text" id="txt_Adr">
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-size:11px;">REMARKS</label>
                        <textarea class="form-control form-control-sm" rows="2" id="txt_Remarks"></textarea>
                    </div>
                </div>
                <div class="mt-auto pt-3 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" id="btnEnquiry_clear"><i class="bi bi-eraser me-1"></i> CLEAR</button>
                    <button type="button" class="btn btn-sm btn-primary rounded-pill" id="btnEnquiry_save"><i class="bi bi-save me-1"></i> SAVE</button>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="gdash-card">
                <div class="gdash-card-title"><i class="bi bi-list-ul text-info me-1"></i>My Leads</div>
                <div id="grid_enq_upd">
                    <div id="gridContainer_cp" style="min-height: 400px;"></div>
                </div>
            </div>
        </div>
    </div>
