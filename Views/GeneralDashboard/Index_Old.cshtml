            $('#EXECUTIVE_Rmks').val('');
            $('#EXECUTIVE_Rmks').attr('disabled', true);

            if (data.msg == 'Success') {
                if (!jQuery.isEmptyObject(data.data)) {
                    var data2 = data.data.Table;
