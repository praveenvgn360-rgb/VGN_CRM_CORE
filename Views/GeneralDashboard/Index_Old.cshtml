function ParentSource_load() {
    $.ajax({
        async: true,
        type: 'GET',
        url: '/GeneralDashboard/LoadParentSource',
        contentType: 'application/json; charset=UTF-8',
        success: function (data) {
            // REMOVED: var data = JSON.parse(data);
            $('#dd_SourceOfEnquiry').empty();
            if (data.msg == 'Success') {
                if (!jQuery.isEmptyObject(data.data)) {
                    var data1 = data.data.Table;
                    var option = '';
                    for (var i = 0; i < data1.length; i++) {
                        option += '<option value=' + data1[i].PSrcTranid + '>' + data1[i].PSrcEnquiry + '</option>';
                    }
                    $('#dd_SourceOfEnquiry').append(option);
                    $('#dd_Soure_Enquiry').append(option);
