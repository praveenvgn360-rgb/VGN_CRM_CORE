function SaveEnquiry() {
    if ($.trim($('#txtCUSTOMERNAME').val()) == "") {
        $('#PtxtCUSTOMERNAME').show();
        $('#PtxtCUSTOMERNAME').fadeOut(8000);
        $('#PtxtCUSTOMERNAME').html('Enter Client Name');
        $('#txtCUSTOMERNAME').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }

    var mobileno_legth = $('#txtMOBILENO').val().length;
    if (mobileno_legth < 5 || $.trim($('#txtMOBILENO').val()) == "") {
        $('#PtxtMOBILENO').show();
        $('#PtxtMOBILENO').fadeOut(8000);
        $('#PtxtMOBILENO').html('Enter 5 Digits Number');
        $('#txtMOBILENO').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }

    if ($('#txtMOBILENO1').val() != "") {
        var mobileno_legth = $('#txtMOBILENO1').val().length;
        if (mobileno_legth < 5 || $.trim($('#txtMOBILENO1').val()) == "") {
            $('#PtxtMOBILENO1').show();
            $('#PtxtMOBILENO1').fadeOut(8000);
            $('#PtxtMOBILENO1').html('Enter 5 Digits Number');
            $('#txtMOBILENO1').focus();
            $('#btnEnquiry_save').attr('disabled', false);
            return false;
        }
    }

    if ($.trim($('#txtMOBILENO').val()) == "") {
        alert('Enter Mobile No')
        $('#btnEnquiry_save').attr('disabled', false);
        return;
    }

    if ($.trim($('#dd_ProjectLayout').val()) == "0") {
        $('#Pdd_ProjectLayout').show();
        $('#Pdd_ProjectLayout').fadeOut(8000);
        $('#Pdd_ProjectLayout').html('Select Project');
        $('#dd_ProjectLayout').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }
    if ($.trim($('#dd_SourceOfEnquiry').val()) == "0") {
        $('#Pdd_SourceOfEnquiry').show();
        $('#Pdd_SourceOfEnquiry').fadeOut(8000);
        $('#Pdd_SourceOfEnquiry').html('Select Source Of Enquiry');
        $('#dd_SourceOfEnquiry').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }
    if ($.trim($('#dd_SubSource').val()) == "0") {
        $('#Pdd_SubSource').show();
        $('#Pdd_SubSource').fadeOut(8000);
        $('#Pdd_SubSource').html('Select SubSource Of Enquiry');
        $('#dd_SubSource').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }

    var Save_Leads = {
        "ClientName": "", "Mobile1": "", "Category": "", "projectId": "", "SrcTranid": "", "SubSrcEnquiryId": "",
        "EmailId1": "", "Location": "", "Panno": "", "AadharNo": "", "Remarks": "", "Mobile2": "", "CountryCode1": "", "CountryCode2": ""
    }

    Save_Leads.ClientName = $('#txtCUSTOMERNAME').val();
    Save_Leads.Mobile1 = $("#txtMOBILENO").val();
    Save_Leads.Mobile2 = $("#txtMOBILENO1").val();
    Save_Leads.Category = $("input[name='EnquiryType']:checked").val();
    Save_Leads.projectId = $("#dd_ProjectLayout option:selected").val() || "0";
    Save_Leads.SrcTranid = $("#dd_SourceOfEnquiry option:selected").val() || "0";
    Save_Leads.SubSrcEnquiryId = $("#dd_SubSource option:selected").val() || "0";
    Save_Leads.Location = $("#txt_LOCATION").val();
    Save_Leads.EmailId1 = $("#txt_EMAIL").val();
    Save_Leads.Panno = $("#txt_PANNO").val();
    Save_Leads.AadharNo = $("#txt_Adr").val();
    Save_Leads.Remarks = $("#txt_Remarks").val();
    Save_Leads.CountryCode1 = $('#countryCode_1').val().replace('+', '');
    Save_Leads.CountryCode2 = $('#countryCode_2').val().replace('+', '');

    $.ajax({
        async: true,
        type: 'POST',
        url: '/GeneralDashboard/SaveLeads',
        contentType: 'application/json; charset=UTF-8',
        data: JSON.stringify(Save_Leads),
        success: function (response) {
            try {
                var data = typeof response === 'string' ? JSON.parse(response) : response;

                if (data.status === true) {
                    if (data.msg == 'Success') {
                        alert('Saved Successfully');
                        $('#btnEnquiry_save').attr('disabled', false);
                        EnquiryClear();
                    } else {
                        alert(data.msg);
                        $('#btnEnquiry_save').attr('disabled', false);
                    }
                }
                else if (data.status === false) {
                    alert(data.msg);
                    $('#btnEnquiry_save').attr('disabled', false);

                    // Focus and clear relevant field
                    if (data.msg.includes("Project")) {
                        $('#dd_ProjectLayout').focus();
                    } else if (data.msg.includes("Source of enquiry")) {
                        $('#dd_SourceOfEnquiry').focus();
                    } else if (data.msg.includes("Sub source")) {
                        $('#dd_SubSource').focus();
                    } else if (data.msg.includes("Client name")) {
                        $('#txtCUSTOMERNAME').focus();
                    } else if (data.msg.toLowerCase().includes("mobile")) {
                        $('#txtMOBILENO').val('').focus();
                    }
                }
                else {
                    // Legacy format
                    if (data.msg == 'Success') {
                        EnquiryClear();
                        alert('Saved Successfully');
                        $('#btnEnquiry_save').attr('disabled', false);

                    }
                    else {
                        alert(data.msg || 'Something went wrong');
                        $('#btnEnquiry_save').attr('disabled', false);
                    }
                }
            } catch (e) {
                alert('Error parsing response: ' + e.message);
                $('#btnEnquiry_save').attr('disabled', false);
            }
        },
        error: function (xhr, status, error) {
            alert('An error occurred: ' + error);
            $('#btnEnquiry_save').attr('disabled', false);
        }
    });
}

$('#btnEnquiry_save').click(function () {
    $('#btnEnquiry_save').attr('disabled', true);
    var mobileno_legth = $('#txtMOBILENO').val().length;

    if (mobileno_legth < 5 || $.trim($('#txtMOBILENO').val()) == "") {
        $('#PtxtMOBILENO').show();
        $('#PtxtMOBILENO').fadeOut(8000);
        $('#PtxtMOBILENO').html('Enter 5 Digits Number');
        $('#txtMOBILENO').focus();
        $('#btnEnquiry_save').attr('disabled', false);
        return false;
    }

    // First check Mobile1 duplication
    var MobNo1 = $('#txtMOBILENO').val();
    $.ajax({
        async: true,
        type: 'GET',
        url: '/GeneralDashboard/FindDuplicateMobile',
        contentType: 'application/json; charset=UTF-8',
        data: { Mobile1: MobNo1 },
        success: function (response, status, xhr) {
            try {
                var data = typeof response === 'string' ? JSON.parse(response) : response;

                if (data.status === false && data.msg === "Session expired. Please login again.") {
                    // Redirect to login page
                    window.location.href = '/login';
                    return;
                }

                if (data.msg == 'Success') {
                    alert('Mobile No 1 already exists');
                    $('#txtMOBILENO').val('').focus();
                    $('#btnEnquiry_save').attr('disabled', false);
                    return;
                }

                // Check Mobile2 if provided
                var MobNo2 = $('#txtMOBILENO1').val();
                if (MobNo2 && MobNo2.trim() !== "") {
                    // Validate Mobile2 length
                    if (MobNo2.length < 5) {
                        $('#PtxtMOBILENO1').show();
                        $('#PtxtMOBILENO1').fadeOut(8000);
                        $('#PtxtMOBILENO1').html('Enter 5 Digits Number');
                        $('#txtMOBILENO1').focus();
                        $('#btnEnquiry_save').attr('disabled', false);
                        return;
                    }

                    // Check Mobile2 duplication
                    $.ajax({
                        async: true,
                        type: 'GET',
                        url: '/GeneralDashboard/FindDuplicateMobile',
                        contentType: 'application/json; charset=UTF-8',
                        data: { Mobile1: MobNo2 },
                        success: function (response2, status2, xhr2) {
                            try {
                                var data2 = typeof response2 === 'string' ? JSON.parse(response2) : response2;

                                if (data2.status === false && data2.msg === "Session expired. Please login again.") {
                                    // Redirect to login page
                                    window.location.href = '/login';
                                    return;
                                }

                                if (data2.msg == 'Success') {
                                    alert('Mobile No 2 already exists');
                                    $('#txtMOBILENO1').val('').focus();
                                    $('#btnEnquiry_save').attr('disabled', false);
                                    return;
                                }

                                // Both mobile numbers are unique, proceed to save
                                SaveEnquiry();
                            } catch (e) {
                                console.error('Error checking mobile 2:', e);
                                alert('Error checking mobile 2. Please try again.');
                                $('#btnEnquiry_save').attr('disabled', false);
                            }
                        },
                        error: function (xhr2, status2, error2) {
                            console.error('AJAX Error checking mobile 2:', status2, error2);
                            alert('Error checking mobile 2 duplication. Please try again.');
                            $('#btnEnquiry_save').attr('disabled', false);
                        }
                    });
                } else {
                    // No Mobile2 provided, just save with Mobile1
                    SaveEnquiry();
                }
            } catch (e) {
                console.error('Error parsing mobile 1 response:', e);
                alert('Error checking mobile 1. Please try again.');
                $('#btnEnquiry_save').attr('disabled', false);
            }
        },
        error: function (xhr, status, error) {
            console.error('AJAX Error checking mobile 1:', status, error);

            // Check if it's a 500 error (server error)
            if (xhr.status === 500) {
                alert('Server error occurred. Please contact support.');
            }
            // Check if it's a 401 error (unauthorized)
            else if (xhr.status === 401) {
                window.location.href = '/login';
            }
            else {
                alert('Error checking mobile 1 duplication. Please try again.');
            }

            $('#btnEnquiry_save').attr('disabled', false);
        }
    });
});

