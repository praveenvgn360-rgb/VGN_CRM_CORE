@if (!userRole.ToUpper().Contains("CHANNEL") && !userId.ToUpper().StartsWith("MP") && userId.ToUpper() != "CHANNELPARTNER" && userId.ToUpper() != "MD" && userId.ToUpper() != "CEO" && userId.ToUpper() != "D001")
{
    @if (departmentId == "DEPT-5")
    {
        <!-- General Sales Dashboard Specific Cards -->
        <div class="row g-3 mb-3">
