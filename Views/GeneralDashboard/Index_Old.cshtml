                    <p class="text-muted small">Sales overview and metrics.</p>
                </div>
            </div>
        </div>
    }
    else if (departmentId == "DEPT-28" || departmentId == "DEPT-31")
    {
        <!-- Presales Dashboard Specific Cards -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="gdash-card">
                    <div class="gdash-card-title"><i class="bi bi-telephone-inbound text-primary me-1"></i>Presales Dashboard</div>
                    <p class="text-muted small">Presales calls and leads.</p>
                </div>
            </div>
        </div>
    }
    else if (departmentId == "DEPT-23")
    {
        <!-- CRM Executive Dashboard Specific Cards -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="gdash-card">
                    <div class="gdash-card-title"><i class="bi bi-headset text-info me-1"></i>CRM Executive Dashboard</div>
                    <p class="text-muted small">Customer relationships and follow-ups.</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- General Dashboard Specific Grids -->
        <!-- Daybook Grid Section -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="gdash-card">
                    <div class="gdash-card-title"><i class="bi bi-book me-1 text-info"></i>Daybook</div>
                    <div style="overflow-x: auto; width: 100%;">
                        <div id="gridContainer1" style="min-height: 400px; width: 100%;"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Assignment Extension Grid Section -->
        <div class="row g-3 mb-3">
            <div class="col-12">
                <div class="gdash-card">
                    <div class="gdash-card-title"><i class="bi bi-briefcase me-1 text-warning"></i>Assignment Extension</div>
                    <div style="overflow-x: auto; width: 100%;">
                        <div id="gridContainer2" style="min-height: 400px; width: 100%;"></div>
                    </div>
                </div>
            </div>
