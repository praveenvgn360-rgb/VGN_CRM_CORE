function Project_Layout() {
    Category = $("input[type=radio][name='EnquiryType']:checked").val();
    $.ajax({
        async: true,
        type: 'GET',
        url: '/GeneralDashboard/LoadProject',
        contentType: 'application/json; charset=UTF-8',
        data: { Category: Category },
        success: function (data) {
            // REMOVED: var data = JSON.parse(data);
            $('#dd_ProjectLayout').empty();
            if (data.msg == 'Success') {
                if (!jQuery.isEmptyObject(data.data)) {
                    var data1 = data.data.Table;
                    var option = '';
                    for (var i = 0; i < data1.length; i++) {
                        option += '<option value=' + data1[i].Projectid + '>' + data1[i].ProjectName + '</option>';
                    }
                    $('#dd_ProjectLayout').append(option);
                }
            } else {
                console.log(data);
            }
        }
    });
}

function LoadClientId() {
    $.ajax({
        async: true,
        type: 'GET',
        url: '/GeneralDashboard/LoadAutoId',
        contentType: 'application/json; charset=UTF-8',
        success: function (data) {
            // REMOVED: var data = JSON.parse(data);
            if (data.msg == 'Success') {
                if (!jQuery.isEmptyObject(data.data)) {
                    var data1 = data.data.Table[0];
                    var enquiryid = data1.ClientId;
                    if (!enquiryid) {
                        $('#txtautoclientid').val('CP-1');
                    } else {
                        $('#txtautoclientid').val('CP-' + data1.ClientId);
                    }
                }
            } else {
                console.log(data);
            }
        }
    });
}

$('input[type=radio][name=EnquiryType]').change(function () {

    Project_Layout();
});


