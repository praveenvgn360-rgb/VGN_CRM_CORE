@{
    ViewBag.Title = "General Dashboard";
    ViewBag.ActiveMenu = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userId = ViewBag.UserId as string ?? "";
    var userRole = ViewBag.UserRole as string ?? "";
    var departmentId = ViewBag.DepartmentId as string ?? "";
}



<style>

    /* ── Compact Attendance Calendar ───────────────────── */
    .att-cal-wrap {
        background: var(--bg-card, var(--surface));
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }

    .att-cal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .6rem;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .att-cal-title {
        font-size: .92rem;
        font-weight: 700;
        color: var(--text);
    }

    .att-cal-nav {
        display: flex;
        gap: 6px;
    }

        .att-cal-nav button {
            width: 28px;
            height: 28px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: var(--surface);
            color: var(--text);
            cursor: pointer;
            font-size: .85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s;
        }

            .att-cal-nav button:hover {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

    /* 7-column compact grid */
    .att-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 3px;
    }

    .att-grid-head {
        text-align: center;
        font-size: .68rem;
        font-weight: 700;
        color: var(--text-muted);
        padding: 3px 0;
        letter-spacing: .4px;
    }

    .att-day-cell {
        border-radius: 7px;
        padding: 4px 3px 3px;
        min-height: 52px;
        font-size: .65rem;
        border: 1px solid transparent;
        position: relative;
        cursor: default;
        transition: transform .15s, box-shadow .15s;
    }

        .att-day-cell:hover {
            transform: scale(1.06);
            box-shadow: 0 3px 10px rgba(0,0,0,.12);
            z-index: 2;
        }

        .att-day-cell.empty {
            background: transparent;
            border: none;
        }

        .att-day-cell.no-data {
            background: var(--bg);
            border-color: var(--border);
        }

        .att-day-cell.on-time {
            background: #d1fae5;
            border-color: #6ee7b7;
        }

        .att-day-cell.slight-late {
            background: #fef9c3;
            border-color: #fde047;
        }

        .att-day-cell.late {
            background: #fee2e2;
            border-color: #fca5a5;
        }

        .att-day-cell.today {
            border-color: var(--primary) !important;
            border-width: 2px !important;
        }

    .att-day-num {
        font-weight: 700;
        color: var(--text);
        font-size: .72rem;
    }

    .att-day-name {
        float: right;
        color: var(--text-muted);
        font-size: .6rem;
    }

    .att-day-cell.on-time .att-day-num,
    .att-day-cell.slight-late .att-day-num,
    .att-day-cell.late .att-day-num {
        color: #1e293b !important;
    }

    .att-day-cell.on-time .att-day-name,
    .att-day-cell.slight-late .att-day-name,
    .att-day-cell.late .att-day-name {
        color: #475569 !important;
    }

    .att-punch {
        margin-top: 2px;
        line-height: 1.3;
    }

        .att-punch span {
            display: block;
            font-size: .6rem;
            white-space: nowrap;
        }

    .att-in {
        color: #059669;
    }

    .att-out {
        color: #6b7280;
    }

    /* Legend */
    .att-legend {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: .6rem;
    }

        .att-legend span {
            font-size: .68rem;
            display: flex;
            align-items: center;
            gap: 4px;
            color: var(--text-muted);
        }

            .att-legend span i {
                width: 10px;
                height: 10px;
                border-radius: 3px;
                display: inline-block;
            }

    .leg-green {
        background: #6ee7b7;
    }

    .leg-yellow {
        background: #fde047;
    }

    .leg-red {
        background: #fca5a5;
    }

    .leg-empty {
        background: var(--border);
    }

    /* Summary badges */
    .att-summary {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: .6rem;
    }

    .att-sum-pill {
        font-size: .7rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    /* ── Glass card ──────────────────── */
    .gdash-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.04);
        height: 100%;
    }

    .gdash-card-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .6px;
        margin-bottom: .75rem;
    }

    /* ── Dept section show/hide ────────────────────────── */
    .dept-section {
        transition: opacity .35s ease, max-height .35s ease;
        overflow: hidden;
    }

        .dept-section.d-section-hidden {
            opacity: 0;
            max-height: 0 !important;
            margin: 0 !important;
            padding: 0 !important;
        }

    /* ── Grid Tables ─────────────────────────────────── */
    .grid-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

        .grid-table thead th {
            background: rgba(70,128,255,.08);
            color: var(--text);
            font-weight: 700;
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.4px;
        }

        .grid-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background 0.15s ease;
        }

            .grid-table tbody tr:hover {
                background: rgba(70,128,255,.04);
            }

        .grid-table tbody td {
            padding: 0.75rem;
            color: var(--text);
        }

        .grid-table .text-center {
            text-align: center;
        }

        .grid-table .text-right {
            text-align: right;
        }

        .grid-table .action-btn {
            padding: 0.4rem 0.75rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text);
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.15s ease;
        }

            .grid-table .action-btn:hover {
                background: var(--primary);
                color: #fff;
                border-color: var(--primary);
            }

    .grid-empty {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.875rem;
    }
</style>

