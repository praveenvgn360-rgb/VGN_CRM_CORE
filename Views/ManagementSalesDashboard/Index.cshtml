@{
    ViewBag.Title = "Management Sales Dashboard";
    ViewBag.ActiveMenu = "ManagementSalesDashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── Dashboard Layout ─────────────────────────────── */
    .mgmt-kpi-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.04);
        display: flex;
        flex-direction: column;
        gap: .35rem;
        transition: transform .18s, box-shadow .18s;
        position: relative;
        overflow: hidden;
    }

    .mgmt-kpi-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 4px;
        height: 100%;
        background: var(--kpi-accent, var(--primary));
        border-radius: 14px 0 0 14px;
    }

    .mgmt-kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 24px rgba(0,0,0,.10);
    }

    .mgmt-kpi-label {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: var(--text-muted);
    }

    .mgmt-kpi-value {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--text);
        line-height: 1.1;
    }

    .mgmt-kpi-sub {
        font-size: .72rem;
        color: var(--text-muted);
    }

    .mgmt-kpi-icon {
        position: absolute;
        top: .9rem;
        right: 1rem;
        font-size: 1.8rem;
        opacity: .5;
        color: var(--kpi-accent, var(--text-muted));
    }

    /* ── Section Card ─────────────────────────────────── */
    .mgmt-section-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.04);
    }

    .mgmt-section-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: .6px;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    /* ── Month Picker ─────────────────────────────────── */
    .mgmt-monthpicker {
        display: flex;
        align-items: center;
        gap: .5rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .mgmt-monthpicker label {
        font-size: .78rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .mgmt-monthpicker input[type="month"] {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        padding: .35rem .75rem;
        font-size: .82rem;
        outline: none;
    }

    .mgmt-monthpicker input[type="month"]:focus {
        border-color: var(--primary);
    }

    .mgmt-btn {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: var(--primary);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .38rem .9rem;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity .15s;
    }

    .mgmt-btn:hover { opacity: .88; }

    /* ── Tab Pills ─────────────────────────────────────── */
    .mgmt-tabs {
        display: flex;
        gap: .5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .mgmt-tab {
        font-size: .75rem;
        font-weight: 600;
        padding: .32rem .85rem;
        border-radius: 20px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        transition: all .15s;
    }

    .mgmt-tab.active,
    .mgmt-tab:hover {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
    }

    /* ── Main Navigation Tabs ──────────────────────────── */
    .mgmt-main-tabs {
        display: flex;
        gap: .25rem;
        border-bottom: 2px solid var(--border);
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
    }

    .mgmt-main-tab {
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: .85rem;
        font-weight: 600;
        padding: .75rem 1.25rem;
        cursor: pointer;
        position: relative;
        transition: color .2s;
        display: inline-flex;
        align-items: center;
        gap: .4rem;
    }

    .mgmt-main-tab:hover {
        color: var(--primary);
    }

    .mgmt-main-tab.active {
        color: var(--primary);
    }

    .mgmt-main-tab.active::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 100%;
        height: 3px;
        background: var(--primary);
        border-radius: 3px 3px 0 0;
    }
    
    .mgmt-tab-content {
        display: none;
        animation: fadeIn 0.3s ease;
    }
    .mgmt-tab-content.active {
        display: block;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Hyperlink Report Tiles ───────────────────────── */
    .report-link-tile {
        display: flex;
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 1.15rem;
        border-radius: 14px;
        box-shadow: 0 4px 16px rgba(0,0,0,.04);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        text-decoration: none;
        color: var(--text);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    /* Subtle gradient overlay for depth */
    .report-link-tile::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        pointer-events: none;
    }
    
    .report-link-tile:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 24px rgba(0,0,0,.12);
        border-color: var(--primary);
        color: var(--primary);
    }
    
    .report-icon-box {
        width: 50px;
        height: 50px;
        min-width: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        margin-right: 1.15rem;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .report-link-tile:hover .report-icon-box {
        transform: scale(1.1) rotate(-3deg);
    }
</style>

<!-- ── Page Header ────────────────────────────────────────── -->
<div class="flex items-center justify-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="text-xl font-bold" style="color:var(--text)">
            <i class="bi bi-speedometer2 me-2" style="color:var(--primary)"></i>Management Sales Dashboard
        </h1>
        <p class="text-sm mt-1" style="color:var(--text-muted)">Consolidated Dashboard & Legacy Reports</p>
    </div>
    <div class="mgmt-monthpicker">
        <label><i class="bi bi-calendar3 me-1"></i>Month</label>
        <input type="month" id="inp_month" value="@ViewBag.CurrentMonth" />
        <button class="btn-load" id="btn_refresh"><i class="bi bi-arrow-clockwise"></i> Refresh Data</button>
    </div>
</div>

<!-- ── KPI Cards (Always Visible) ────────────────────────── -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 mb-6" id="kpi_row">
    <div class="mgmt-kpi-card" style="--kpi-accent:#4680FF">
        <div class="mgmt-kpi-label">Total Leads</div>
        <div class="mgmt-kpi-value" id="kpi_total">--</div>
        <div class="mgmt-kpi-sub">All Sources</div>
        <i class="bi bi-people mgmt-kpi-icon"></i>
    </div>
    <div class="mgmt-kpi-card" style="--kpi-accent:#10b981">
        <div class="mgmt-kpi-label">Online</div>
        <div class="mgmt-kpi-value" id="kpi_online">--</div>
        <div class="mgmt-kpi-sub">Digital Sources</div>
        <i class="bi bi-globe mgmt-kpi-icon"></i>
    </div>
    <div class="mgmt-kpi-card" style="--kpi-accent:#f97316">
        <div class="mgmt-kpi-label">Offline</div>
        <div class="mgmt-kpi-value" id="kpi_offline">--</div>
        <div class="mgmt-kpi-sub">Walk-in / Print</div>
        <i class="bi bi-person-walking mgmt-kpi-icon"></i>
    </div>
    <div class="mgmt-kpi-card" style="--kpi-accent:#8b5cf6">
        <div class="mgmt-kpi-label">Channel</div>
        <div class="mgmt-kpi-value" id="kpi_channel">--</div>
        <div class="mgmt-kpi-sub">Partner Refs</div>
        <i class="bi bi-diagram-3 mgmt-kpi-icon"></i>
    </div>
    <div class="mgmt-kpi-card" style="--kpi-accent:#ec4899">
        <div class="mgmt-kpi-label">Others</div>
        <div class="mgmt-kpi-value" id="kpi_others">--</div>
        <div class="mgmt-kpi-sub">Miscellaneous</div>
        <i class="bi bi-three-dots mgmt-kpi-icon"></i>
    </div>
</div>

<!-- ── Main Navigation Hyperlinks (Tabs) ─────────────────── -->
<div class="mgmt-main-tabs">
    <!-- Legacy Hyperlinks Tabs -->
    <button class="mgmt-main-tab active" data-target="tab_sales_reports"><i class="bi bi-link-45deg"></i>Sales Reports</button>
    <button class="mgmt-main-tab" data-target="tab_presales_reports"><i class="bi bi-link-45deg"></i>Pre-Sales Reports</button>
    <button class="mgmt-main-tab" data-target="tab_telecaller_reports"><i class="bi bi-link-45deg"></i>Telecaller Reports</button>

    <!-- Consolidated Grid/Chart Tabs -->
    <button class="mgmt-main-tab" data-target="tab_overview"><i class="bi bi-pie-chart"></i>Charts & Overview</button>
    <button class="mgmt-main-tab" data-target="tab_target"><i class="bi bi-bullseye"></i>Target vs Achieved</button>
    <button class="mgmt-main-tab" data-target="tab_prospect"><i class="bi bi-binoculars"></i>Expected Prospect</button>
    <button class="mgmt-main-tab" data-target="tab_booked"><i class="bi bi-receipt"></i>Booked Data</button>
    <button class="mgmt-main-tab" data-target="tab_stock"><i class="bi bi-boxes"></i>Project Stock</button>
</div>

<!-- ── TAB CONTENT: Overview & Charts ────────────────────── -->
<div id="tab_overview" class="mgmt-tab-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <div class="mgmt-section-card">
            <div class="mgmt-section-title">
                <i class="bi bi-bar-chart-fill" style="color:var(--primary)"></i>Project-wise Target vs Achieved
            </div>
            <div id="chart_projectwise" style="height:320px;"></div>
        </div>
        <div class="mgmt-section-card">
            <div class="mgmt-section-title">
                <i class="bi bi-bar-chart-line-fill" style="color:#ec4899"></i>Team-wise Booking Abstract
            </div>
            <div id="chart_teamwise" style="height:320px;"></div>
        </div>
    </div>
</div>

<!-- ── TAB CONTENT: Target vs Achieved ───────────────────── -->
<div id="tab_target" class="mgmt-tab-content">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
        <!-- Project-wise Data Grid -->
        <div class="mgmt-section-card">
            <div class="mgmt-section-title">
                <i class="bi bi-building" style="color:var(--primary)"></i>Project-wise Target vs Achieved Grid
            </div>
            <div id="grid_projectwise" style="min-height:280px;"></div>
        </div>
        <!-- Team-wise Abstract Grid -->
        <div class="mgmt-section-card">
            <div class="mgmt-section-title">
                <i class="bi bi-people-fill" style="color:#ec4899"></i>Team-wise Booking Abstract Grid
            </div>
            <div id="grid_teamwise" style="min-height:280px;"></div>
        </div>
    </div>
    
    <!-- Executive-wise Booking Summary -->
    <div class="mgmt-section-card mb-4">
        <div class="mgmt-section-title">
            <i class="bi bi-person-badge" style="color:#10b981"></i>Executive-wise Booking Summary
        </div>
        <div id="grid_executivewise" style="min-height:280px;"></div>
    </div>
</div>

<!-- ── TAB CONTENT: Expected Prospect ────────────────────── -->
<div id="tab_prospect" class="mgmt-tab-content">
    <div class="mgmt-section-card mb-4">
        <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
            <div class="mgmt-section-title mb-0">
                <i class="bi bi-binoculars" style="color:#f97316"></i>Expected Prospect (Site Visits)
            </div>
            <div class="flex items-center gap-3 flex-wrap">
                <label style="font-size:.75rem;color:var(--text-muted)">From</label>
                <input type="date" id="inp_sv_from" class="mgmt-monthpicker input" style="border:1px solid var(--border);border-radius:8px;padding:.3rem .65rem;background:var(--surface);color:var(--text);font-size:.8rem;" />
                <label style="font-size:.75rem;color:var(--text-muted)">To</label>
                <input type="date" id="inp_sv_to" class="mgmt-monthpicker input" style="border:1px solid var(--border);border-radius:8px;padding:.3rem .65rem;background:var(--surface);color:var(--text);font-size:.8rem;" />
                <button class="btn-load" id="btn_sv_load"><i class="bi bi-search"></i> Load</button>
            </div>
        </div>
        <div class="mgmt-tabs" id="sv_tabs">
            <button class="mgmt-tab active" data-view="EXECUTIVEWISE">Executive-wise</button>
            <button class="mgmt-tab" data-view="PROJECTWISE">Project-wise</button>
            <button class="mgmt-tab" data-view="TEAMWISE">Team-wise</button>
        </div>
        <div id="grid_sitevisit" style="min-height:280px;"></div>
    </div>
</div>

<!-- ── TAB CONTENT: Booked Data ──────────────────────────── -->
<div id="tab_booked" class="mgmt-tab-content">
    <div class="mgmt-section-card mb-4">
        <div class="flex items-center justify-between flex-wrap gap-3 mb-3">
            <div class="mgmt-section-title mb-0">
                <i class="bi bi-receipt" style="color:#4680FF"></i>Booked Data Detailed View
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <input type="date" id="inp_bk_from" style="border:1px solid var(--border);border-radius:8px;padding:.3rem .65rem;background:var(--surface);color:var(--text);font-size:.78rem;" />
                <input type="date" id="inp_bk_to"   style="border:1px solid var(--border);border-radius:8px;padding:.3rem .65rem;background:var(--surface);color:var(--text);font-size:.78rem;" />
                <button class="btn-load" id="btn_bk_load"><i class="bi bi-search"></i> Load Data</button>
            </div>
        </div>
        <div id="grid_booked" style="min-height:350px;"></div>
    </div>
</div>

<!-- ── TAB CONTENT: Stock ────────────────────────────────── -->
<div id="tab_stock" class="mgmt-tab-content">
    <div class="mgmt-section-card mb-4">
        <div class="mgmt-section-title">
            <i class="bi bi-boxes" style="color:#8b5cf6"></i>Project-wise Stock Overview
        </div>
        <div id="grid_stock" style="min-height:350px;"></div>
    </div>
</div>

