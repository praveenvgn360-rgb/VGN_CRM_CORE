</div>

<!-- ── TAB CONTENT: Telecaller Reports ───────────────────── -->
<div id="tab_telecaller_reports" class="mgmt-tab-content">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-4">
        <a href="/ManagementSalesDashboard/TelecallerTargettReport" class="report-link-tile">
            <div class="report-icon-box" style="background:#4680FF"><i class="bi bi-bullseye"></i></div>
            <span class="font-semibold text-sm">Telecaller Target/Assigned Report</span>
        </a>
        <a href="/ManagementSalesDashboard/BookingAbstract_Report" class="report-link-tile">
            <div class="report-icon-box" style="background:#ef4444"><i class="bi bi-file-text"></i></div>
            <span class="font-semibold text-sm">Booking Abstract</span>
        </a>
        <a href="/ManagementSalesDashboard/LeadAbstract_Report" class="report-link-tile">
            <div class="report-icon-box" style="background:#f97316"><i class="bi bi-people"></i></div>
            <span class="font-semibold text-sm">Lead Abstract</span>
        </a>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    // ── Tab Navigation Logic ─────────────────────────────────
    document.querySelectorAll('.mgmt-main-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            // Remove active from all tabs
            document.querySelectorAll('.mgmt-main-tab').forEach(t => t.classList.remove('active'));
            // Add active to clicked
            tab.classList.add('active');

            // Hide all contents
            document.querySelectorAll('.mgmt-tab-content').forEach(c => c.classList.remove('active'));
            // Show target content
            var target = tab.getAttribute('data-target');
            document.getElementById(target).classList.add('active');

            // Refresh grid layout if DevExtreme grids exist in the newly shown tab
            setTimeout(function() {
                window.dispatchEvent(new Event('resize'));
            }, 50);
        });
    });

    // ── helpers ──────────────────────────────────────────────
    function fmt(n) {
        if (n == null || isNaN(n)) return '0';
        n = Math.round(n);
        var s = n.toString(), last3 = s.slice(-3), rest = s.slice(0, -3);
        return rest ? rest.replace(/\B(?=(\d{2})+(?!\d))/g, ',') + ',' + last3 : last3;
    }

    function safeJson(d) {
        if (typeof d === 'string') { try { return JSON.parse(d); } catch (e) { return null; } }
        return d;
    }

    function firstDayOfMonth() {
        var m = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        return m + '-01';
    }
    function lastDayOfMonth() {
        var m = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        var d = new Date(m + '-01');
        return new Date(d.getFullYear(), d.getMonth() + 1, 0).toISOString().slice(0, 10);
    }

    // ── DX grid factory ─────────────────────────────────────
    function makeDxGrid(containerId, columns, dataSource) {
        return DevExpress.ui.dxDataGrid.getInstance(document.getElementById(containerId)) ||
            new DevExpress.ui.dxDataGrid(document.getElementById(containerId), {
                dataSource: dataSource || [],
                columns: columns,
                showBorders: true,
                showRowLines: true,
                rowAlternationEnabled: true,
                filterRow: { visible: false },
                searchPanel: { visible: false },
                paging: { pageSize: 15 },
                pager: { showPageSizeSelector: true, allowedPageSizes: [10, 15, 25, 50] },
                headerFilter: { visible: false },
                sorting: { mode: 'single' },
                scrolling: { mode: 'standard' },
                height: 350,
                wordWrapEnabled: true
            });
    }

    // ── DX chart factory ────────────────────────────────────
    function updateDxChart(containerId, dataSource, argumentField, valueFields, title) {
        var chart = DevExpress.ui.dxChart.getInstance(document.getElementById(containerId));
        if(!chart) {
            var series = valueFields.map(function(vf) {
                return { valueField: vf.field, name: vf.name, color: vf.color };
            });
            chart = new DevExpress.ui.dxChart(document.getElementById(containerId), {
                dataSource: dataSource || [],
                palette: "Soft Pastel",
                commonSeriesSettings: {
                    argumentField: argumentField,
                    type: "bar",
                    hoverMode: "allArgumentPoints",
                    selectionMode: "allArgumentPoints",
                    label: {
                        visible: true,
                        format: { type: "fixedPoint", precision: 0 },
                        backgroundColor: "transparent",
                        font: { color: "var(--text-muted)", size: 10 }
                    },
                    cornerRadius: 4
                },
                series: series,
                legend: {
                    verticalAlignment: "bottom",
                    horizontalAlignment: "center",
                    itemTextPosition: "right",
                    font: { color: "var(--text)" }
                },
                valueAxis: {
                    label: { font: { color: "var(--text-muted)" } },
                    grid: { color: "var(--border)" }
                },
                argumentAxis: {
                    label: { font: { color: "var(--text-muted)" } }
                },
                tooltip: {
                    enabled: true,
                    shared: true,
                    format: { type: "fixedPoint", precision: 0 },
                    customizeTooltip: function (info) {
                        return {
                            html: "<div><div style='font-weight:bold;margin-bottom:5px;'>" + info.argumentText + "</div>" +
                                info.points.map(p => "<div>" + p.seriesName + ": " + p.valueText + "</div>").join("") + "</div>"
                        };
                    }
                }
            });
        } else {
            chart.option('dataSource', dataSource);
        }
    }

    // ── Load KPI Cards ───────────────────────────────────────
    function loadKpi() {
        var month = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        fetch('/ManagementSalesDashboard/LoadEnquiryCount', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Month: month })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            if (res && res.status && res.data) {
                var d = res.data;
                document.getElementById('kpi_total').textContent   = fmt(d.Total);
                document.getElementById('kpi_online').textContent  = fmt(d.Online);
                document.getElementById('kpi_offline').textContent = fmt(d.Offline);
                document.getElementById('kpi_channel').textContent = fmt(d.Channel);
                document.getElementById('kpi_others').textContent  = fmt(d.Others);
            }
        })
        .catch(function () {});
    }

    // ── Load Project-wise Summary & Chart ────────────────────
    var gridProject;
    function loadProjectwise() {
        var month = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        fetch('/ManagementSalesDashboard/LoadProjectwiseBookedSummary', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Month: month })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            
            // Grid
            if (!gridProject) {
                gridProject = makeDxGrid('grid_projectwise', [
                    { dataField: 'ProjectName',  caption: 'Project',  width: 140 },
                    { dataField: 'Target',        caption: 'Target',   dataType: 'number', width: 90 },
                    { dataField: 'Achieved',      caption: 'Achieved', dataType: 'number', width: 90 },
                    { dataField: 'Pending',       caption: 'Pending',  dataType: 'number', width: 90 },
                    { dataField: 'Achievement',   caption: 'Achv %',   width: 90, customizeText: function(e){ return e.value != null ? e.value + '%' : '--'; } }
                ], rows);
            } else {
                gridProject.option('dataSource', rows);
            }

            // Chart
            updateDxChart('chart_projectwise', rows, 'ProjectName', [
                { field: 'Target', name: 'Target', color: '#4680FF' },
                { field: 'Achieved', name: 'Achieved', color: '#10b981' }
            ]);
        })
        .catch(function () {});
    }

    // ── Load Executive-wise Summary ──────────────────────────
    var gridExec;
    function loadExecutivewise() {
        var month = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        fetch('/ManagementSalesDashboard/ExecutiveWiseBookingSummary', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Month: month })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            if (!gridExec) {
                gridExec = makeDxGrid('grid_executivewise', [
                    { dataField: 'ExecutiveName', caption: 'Executive', width: 140 },
                    { dataField: 'TeamName',      caption: 'Team',      width: 110 },
                    { dataField: 'Target',        caption: 'Target',    dataType: 'number', width: 80 },
                    { dataField: 'Achieved',      caption: 'Achieved',  dataType: 'number', width: 80 },
                    { dataField: 'Achievement',   caption: 'Achv %',    width: 80, customizeText: function(e){ return e.value != null ? e.value + '%' : '--'; } }
                ], rows);
            } else {
                gridExec.option('dataSource', rows);
            }
        })
        .catch(function () {});
    }

    // ── Load Team-wise Abstract & Chart ──────────────────────
    var gridTeam;
    function loadTeamwise() {
        var month = document.getElementById('inp_month').value || '@ViewBag.CurrentMonth';
        fetch('/ManagementSalesDashboard/TeamWiseAbstract', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ Month: month })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            
            // Grid
            if (!gridTeam) {
                gridTeam = makeDxGrid('grid_teamwise', [
                    { dataField: 'TeamName',  caption: 'Team',     width: 140 },
                    { dataField: 'Target',    caption: 'Target',   dataType: 'number', width: 90 },
                    { dataField: 'Achieved',  caption: 'Achieved', dataType: 'number', width: 90 },
                    { dataField: 'Pending',   caption: 'Pending',  dataType: 'number', width: 90 },
                    { dataField: 'Achievement', caption: 'Achv %', width: 90, customizeText: function(e){ return e.value != null ? e.value + '%' : '--'; } }
                ], rows);
            } else {
                gridTeam.option('dataSource', rows);
            }

            // Chart
            updateDxChart('chart_teamwise', rows, 'TeamName', [
                { field: 'Target', name: 'Target', color: '#ec4899' },
                { field: 'Achieved', name: 'Achieved', color: '#8b5cf6' }
            ]);
        })
        .catch(function () {});
    }

    // ── Load Site Visit (Expected Prospect) ──────────────────
    var gridSV;
    var currentSVView = 'EXECUTIVEWISE';
    function loadSiteVisit() {
        var from = document.getElementById('inp_sv_from').value;
        var to   = document.getElementById('inp_sv_to').value;
        fetch('/ManagementSalesDashboard/LoadExpectedProspect', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ FromDate: from, ToDate: to, ViewType: currentSVView })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            if (!gridSV) {
                gridSV = makeDxGrid('grid_sitevisit', [], rows);
            } else {
                gridSV.option('dataSource', rows);
            }
        })
        .catch(function () {});
    }

    // ── Load Booked Data ─────────────────────────────────────
    var gridBooked;
    function loadBooked() {
        var from = document.getElementById('inp_bk_from').value;
        var to   = document.getElementById('inp_bk_to').value;
        fetch('/ManagementSalesDashboard/LoadBookedData', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ FromDate: from, ToDate: to })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            if (!gridBooked) {
                gridBooked = makeDxGrid('grid_booked', [], rows);
            } else {
                gridBooked.option('dataSource', rows);
            }
        })
        .catch(function () {});
    }

    // ── Load Stock ───────────────────────────────────────────
    var gridStock;
    function loadStock() {
        fetch('/ManagementSalesDashboard/LoadStockData', { method: 'POST' })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            res = safeJson(res);
            var rows = (res && res.status && res.data) ? res.data : [];
            if (!gridStock) {
                gridStock = makeDxGrid('grid_stock', [], rows);
            } else {
                gridStock.option('dataSource', rows);
            }
        })
        .catch(function () {});
    }

    // ── Init defaults ────────────────────────────────────────
    var today = new Date();
    var y = today.getFullYear(), m = today.getMonth();
    var firstDay = new Date(y, m, 1).toISOString().slice(0, 10);
    var lastDay  = new Date(y, m + 1, 0).toISOString().slice(0, 10);

    document.getElementById('inp_sv_from').value = firstDay;
    document.getElementById('inp_sv_to').value   = lastDay;
    document.getElementById('inp_bk_from').value = firstDay;
    document.getElementById('inp_bk_to').value   = lastDay;

    // ── Event bindings ───────────────────────────────────────
    document.getElementById('btn_refresh').addEventListener('click', function () {
        loadKpi();
        loadProjectwise();
        loadExecutivewise();
        loadTeamwise();
    });

    document.getElementById('btn_sv_load').addEventListener('click', loadSiteVisit);
    document.getElementById('btn_bk_load').addEventListener('click', loadBooked);

    document.querySelectorAll('#sv_tabs .mgmt-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('#sv_tabs .mgmt-tab').forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            currentSVView = btn.dataset.view;
            loadSiteVisit();
        });
    });

    // ── Initial Load ─────────────────────────────────────────
    loadKpi();
    loadProjectwise();
    loadExecutivewise();
    loadTeamwise();
    loadSiteVisit();
    loadBooked();
    loadStock();

})();
</script>
}
